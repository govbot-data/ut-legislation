erson" level="1" amendtag="end">The office shall select a technical assistance provider that meets the following criteria:</amend><subsection ssid="3-628" dnum="_-o:a-i" numlevel="1" lineno="86" slineno="1-62" ea="amend" anum="0" owner="jchristopherson" style="1" level="2"><display><amend anum="0" ea="amend" pairid="1042" style="1" owner="i" level="1" amendtag="start">(a)</amend></display><amend anum="0" ea="amend" pairid="1952" groupid="74" style="1" owner="jchristopherson" level="1" amendtag="end">demonstrated ability and commitment to fundraise private dollars from national and <ln numlevel="1" lineno="87" slineno="1-63"/>local philanthropic entities;</amend></subsection><subsection ssid="3-656" dnum="_-o:b-i" numlevel="1" lineno="88" slineno="1-64" ea="amend" anum="0" owner="jchristopherson" style="1" level="2"><display><amend anum="0" ea="amend" pairid="1043" style="1" owner="i" level="1" amendtag="start">(b)</amend></display><amend anum="0" ea="amend" pairid="2081" groupid="173" style="1" owner="jchristopherson" level="1" amendtag="end">20 or more years of experience in grant making;</amend></subsection><subsection ssid="3-657" dnum="_-o:c-i" numlevel="1" lineno="89" slineno="1-65" ea="amend" anum="0" owner="jchristopherson" style="1" level="2"><display><amend anum="0" ea="amend" pairid="1044" style="1" owner="i" level="1" amendtag="start">(c)</amend></display><amend anum="0" ea="amend" pairid="2086" groupid="177" style="1" owner="jchristopherson" level="1" amendtag="end">at least five years of experience in supporting community-based, cross-sector <ln numlevel="1" lineno="90" slineno="1-66"/>partnerships in the state;</amend></subsection><subsection ssid="3-658" dnum="_-o:d-i" numlevel="1" lineno="91" slineno="1-67" ea="amend" anum="0" owner="jchristopherson" style="1" level="2"><display><amend anum="0" ea="amend" pairid="1045" style="1" owner="i" level="1" amendtag="start">(d)</amend></display><amend anum="0" ea="amend" pairid="2091" groupid="181" style="1" 