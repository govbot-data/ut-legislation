"end">outcome and performance measurement data; and</amend></subsection><subsection ssid="3-674" dnum="_-o:iii-i" numlevel="1" lineno="129" slineno="1-105" ea="amend" anum="0" owner="jchristopherson" style="1" level="3"><display><amend anum="0" ea="amend" pairid="1075" style="1" owner="i" level="1" amendtag="start">(iii)</amend></display><amend anum="0" ea="amend" pairid="2172" groupid="246" style="1" owner="jchristopherson" level="1" amendtag="end">demographic data.</amend></subsection></subsection><subsection ssid="3-675" dnum="_-o:c-i" numlevel="1" lineno="130" slineno="1-106" ea="amend" anum="0" owner="jchristopherson" style="1" level="2"><display><amend anum="0" ea="amend" pairid="1076" style="1" owner="i" level="1" amendtag="start">(c)</amend></display><amend anum="0" ea="amend" pairid="2177" groupid="250" style="1" owner="jchristopherson" level="1" amendtag="end">An agency or department described in Subsection (6)(a) that provides data shall:</amend><subsection ssid="3-676" dnum="_-o:i-i" numlevel="1" lineno="131" slineno="1-107" ea="amend" anum="0" owner="jchristopherson" style="1" level="3"><display><amend anum="0" ea="amend" pairid="1077" style="1" owner="i" level="1" amendtag="start">(i)</amend></display><amend anum="0" ea="amend" pairid="2182" groupid="254" style="1" owner="jchristopherson" level="1" amendtag="end">ensure that data sharing complies with all applicable state and federal privacy laws;</amend></subsection><subsection ssid="3-681" dnum="_-o:ii-i" numlevel="1" lineno="132" slineno="1-108" ea="amend" anum="0" owner="jchristopherson" style="1" level="3"><display><amend anum="0" ea="amend" pairid="1078" style="1" owner="i" level="1" amendtag="start">(ii)</amend></display><amend anum="0" ea="amend" pairid="2207" groupid="274" style="1" owner="jchristopherson" level="1" amendtag="end">ensure that the data is used solely for purposes authorized under this section;</amend></subsection><subsection ssid="3-677" dnum="_-o:iii-i" numlevel="1" lineno="133" slineno="1-109" ea="amend" anum="0" owner="jchristopherson" style="1" level="3"><display><amend anum="0" ea="amend" pairid="1079" style="1" owner="i" level="1" amendtag="start">(iii)</amend></display><amend anum="0" ea="amend" pairid="2187" groupid="258" style="1" owner="jchristopherson" level="1" amendtag="end">ensure that the data does not result in disclosure of individual-level information <ln numlevel="1" lineno="134" slineno="1-110"/>in any manner that would identify a participant, except as authorized by law; and</amend></subsection><subsection ssid="3-678" dnum="_-o:iv-i" numlevel="1" lineno="135" slineno="1-111" ea="amend" anum="0" owner="jchristopherson" style="1" level="3"><display><amend anum="0" ea="amend" pairid="1080" style="1" owner="i" level="1" amendtag="start">(iv)</amend></display><amend anum="0" ea="amend" pairid="2192" groupid="262" style="1" owner="jchristopherson" level="1" amendtag="end">follow standardized formats, data definitions, and reporting schedules that the <ln numlevel="1" lineno="136" slineno="1-112"/>office establishes in coordination with the technical assistance provider.</amend></subsection></subsection><subsection ssid="3-679" dnum="_-o:d-i" numlevel="1" lineno="137" slineno="1-113" ea="amend" anum="0" owner="jchristopherson" style="1" level="2"><display><amend anum="0" ea="amend" pairid="1081" style="1" owner="i" level="1" amendtag="start">(d)</amend></display><amend anum="0" ea="amend" pairid="2197" groupid="266" style="1" owner="jchristopherson" level="1" amendtag="end">The office shall allow the technical assistance provider and partnerships to use data <ln numlevel="1" lineno="138" slineno="1-114"/>provided under this section to:</amend><subsection ssid="3-682" dnum="_-o:i-i" numlevel="1" lineno="139" slineno="1-115" ea="amend" anum="0" owner="jchristopherson" style="1" level="3"><display><amend anum="0" ea="amend" pairid="1082" style="1" owner="i" level="1" amendtag="start">(i)</amend></display><amend anum="0" ea="amend" pairid="2212" groupid="278" style="1" owner="jchristopherson" level="1" amendtag="end">inform technical assistance, coaching, and capacity-building;</amend></subsection><subsection ssid="3-685" dnum="_-o:ii-i" numlevel="1" lineno="140" slineno="1-116" ea="amend" anum="0" owner="jchristopherson" style="1" level="3"><display><amend anum="0" ea="amend" pairid="1083" style="1" owner="i" level="1" amendtag="start">(ii)</amend></display><amend anum="0" ea="amend" pairid="2227" groupid="290" style="1" owner="jchristopherson" level="1" amendtag="end">analyze trends, identify gaps, and recommend improvements to policies or <ln numlevel="1" lineno="141" slineno="1-117"/>services;</amend></subsection><subsection ssid="3-683" dnum="_-o:iii-i" numlevel="1" lineno="142" slineno="1-118" ea="amend" anum="0" owner="jchristopherson" style="1" level="3"><display><amend anum="0" ea="amend" pairid="1084" style="1" owner="i" level="1" amendtag="start">(iii)</amend></display><amend anum="0" ea="amend" pairid="2217" groupid="282" style="1" owner="jchristopherson" level="1" amendtag="end">monitor progress on community indicators and partnership outcomes; and</amend></subsection><subsection ssid="3-684" dnum="_-o:iv-i" numlevel="1" lineno="143" slineno="1-119" ea="amend" anum="0" owner="jchristopherson" style="1" level="3"><display><amend anum="0" ea="amend" pairid="1085" style="1" owner="i" level="1" amendtag="start">(iv)</amend></display><amend anum="0" ea="amend" pairid="2222" groupid="286" style="1" owner="jchristopherson" level="1" amendtag="end">report aggregated findings publicly while maintaining confidentiality protections.</amend></subsection></subsection></subsection><subsection ssid="3-650" dnum="_-o:7-i" numlevel="1" lineno="144" slineno="1-120" ea="amend" anum="0" owner="jchristopherson" style="1" level="1"><display><amend anum="0" ea="amend" pairid="1086" style="1" owner="i" level="1" amendtag="start">(7)</amend></display><amend anum="0" ea="amend" pairid="2051" groupid="150" style="1" owner="jchristopherson" level="1" amendtag="end">A partnership may accept grants, gifts, donations, or other private funding to support <ln numlevel="1" lineno="145" slineno="1-121"/>partnership activities.</amend></subsection><subsection ssid="3-651" dnum="_-o:8-i" numlevel="1" lineno="146" slineno="1-122" ea="amend" anum="0" owner="jchristopherson" style="1" level="1"><display><amend anum="0" ea="amend" pairid="1087" style="1" owner="i" level="1" amendtag="start">(8)</amend></display><amend anum="0" ea="amend" pairid="2054" groupid="152" style="1" owner="jchristopherson" level="1" amendtag="end">Upon request of the Economic Development and Workforce Services Interim <ln numlevel="1" lineno="147" slineno="1-123"/>Committee or the Education Interim Committee, the office shall collaborate with the <ln numlevel="1" lineno="148" slineno="1-124"/>technical assistance provider to report to the committee on:</amend><subsection ssid="3-652" dnum="_-o:a-i" numlevel="1" lineno="149" slineno="1-125" ea="amend" anum="0" owner="jchristopherson" style="1" level="2"><display><amend anum="0" ea="amend" pairid="1088" style="1" owner="i" level="1" amendtag="start">(a)</amend></display><amend anum="0" ea="amend" pairid="2061" groupid="157" style="1" owner="jchristopherson" level="1" amendtag="end">the number and characteristics of communities participating in the program;</amend></subsection><subsection ssid="3-653" dnum="_-o:b-i" numlevel="1" lineno="150" slineno="1-126" ea="amend" anum="0" owner="jchristopherson" style="1" level="2"><display><amend anum="0" ea="amend" pairid="1089" style="1" owner="i" level="1" amendtag="start">(b)</amend></display><amend anum="0" ea="amend" pairid="2066" groupid="161" style="1" owner="jchristopherson" level="1" amendtag="end">partnership activities and outcomes;</amend></subsection><subsection ssid="3-654" dnum="_-o:c-i" numlevel="1" lineno="151" slineno="1-127" ea="amend" anum="0" owner="jchristopherson" style="1" level="2"><display><amend anum="0" ea="amend" pairid="1090" style="1" owner="i" level="1" amendtag="start">(c)</amend></display><amend anum="0" ea="amend" pairid="2071" groupid="165" style="1" owner="jchristopherson" level="1" amendtag="end">the extent of private investment leveraged; and </amend></subsection><subsection ssid="3-655" dnum="_-o:d-i" numlevel="1" lineno="152" slineno="1-128" ea="amend" anum="0" owner="jchristopherson" style="1" level="2"><display><amend anum="0" ea="amend" pairid="1091" style="1" owner="i" level="1" amendtag="start">(d)</amend></display><amend anum="0" ea="amend" pairid="2076" groupid="169" style="1" owner="jchristopherson" level="1" amendtag="end">recommendations for sustaining and scaling partnership approaches.</amend></subsection></subsection></section></bsec><bsec buid="4" type="uncod" untype="effdate" src="uncod" uid="EF0000" sort="UZEFF" langlock="true" numlevel="1" lineno="153" slineno="2-1" sn="2"><section type="uncod" untype="effdate" display="false" src="uncod"><secline lineno="153">Section 2.  <bold>Effective Date.</bold></secline><sectionText lineno="154"><amend anum="0" ea="amend" pairid="1" groupid="1" style="1" owner="jchristopherson" level="1" amendtag="both">This bill takes effect on <effdate uid="code" date="5/6/2026">May 6, 2026</effdate>.</amend></sectionText></section></bsec></bdy><foot><rev><tm>3-5-26 10:01 AM</tm></rev></foot></leg>