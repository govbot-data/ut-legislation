" lineno="16" slineno="0-16">Be it enacted by the Legislature of the state of Utah:</enact><bdy><bsec buid="1" type="uncod" untype="uncod" src="uncod" uid="UN0000" sort="UA0000000" langlock="false" numlevel="1" lineno="17" slineno="1-1" sn="1"><section type="uncod" untype="uncod" display="false" src="uncod"><secline lineno="17">Section 1.  <bold>Rules reauthorization.</bold></secline><sectionText lineno="18"><amend anum="0" ea="amend" pairid="2" groupid="2" style="1" owner="ahaskell" level="1" amendtag="both">All rules of Utah state agencies are reauthorized except for the following:</amend></sectionText><subsection ssid="1-1" dnum="_-o:1-i" numlevel="1" lineno="19" slineno="1-3" ea="amend" anum="0" owner="ahaskell" style="1" level="1"><display><amend anum="0" ea="amend" pairid="1000" style="1" owner="i" level="1" amendtag="start">(1)</amend></display><amend anum="0" ea="amend" pairid="25" groupid="19" style="1" owner="ahaskell" level="1" amendtag="end">R156-28-302b(1)(b) and (c<marker pairid="33">)</marker><marker pairid="34">;</marker></amend></subsection><subsection ssid="1-3" dnum="_-o:2-i" numlevel="1" lineno="20" slineno="1-4" ea="amend" anum="0" owner="ahaskell" style="1" level="1"><display><amend anum="0" ea="amend" pairid="1001" style="1" owner="i" level="1" amendtag="start">(2)</amend></display><amend anum="0" ea="amend" pairid="19" groupid="14" style="1" owner="ahaskell" level="1" amendtag="end">R156-55d-302c(5);</amend></subsection><subsection ssid="1-2" dnum="_-o:3-i" numlevel="1" lineno="21" slineno="1-5" ea="amend" anum="0" owner="ahaskell" style="1" level="1"><display><amend anum="0" ea="amend" pairid="1002" style="1" owner="i" level="1" amendtag="start">(3)</amend></display><amend anum="0" ea="amend" pairid="12" groupid="9" style="1" owner="ahaskell" level="1" amendtag="end">R156-55e-302a(1)(b);</amend></subsection><subsection ssid="1-4" dnum="_-o:4-i" numlevel="1" lineno="22" slineno="1-6" ea="amend" anum="0" owner="ahaskell" style="1" level="1"><d