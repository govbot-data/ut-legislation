<leg xml:space="preserve" billnum="HB0202" sponsor="Kristen Chevrier" designation="HB" otherSponsor="" otherHouse="Senate" sess="2026GS" fileno="2026FL0209" date="1/8/2026 16:01:783" printDate="01-08 16:01" subVer="0" minVer="0" office="LEGISLATIVE GENERAL COUNSEL" actionDate="" impact="code"><info><nextbuid>9</nextbuid><aminfo anum="0" effdate="05/06/2026"><seclist><sect action="A" src="code" buid="1" uid="C58-72-S302_2026050620260506" fromuid="C58-72-S302_2020051220200512" sort="58 72 03020020260506" mtype="section" effdate="05/06/2026">58-72-302</sect><sect src="uncod" untype="effdate" buid="8" uid="EF0000" sort="UZEFF" mtype="uncod" effdate="05/06/2026"/></seclist></aminfo></info><tbox><sinfo><nextpairid>0</nextpairid></sinfo><st numlevel="1" lineno="1" slineno="0-1">Acupuncturist Licensing Amendments</st><sessionhead>2026 GENERAL SESSION</sessionhead><statehead>STATE OF UTAH</statehead><sponsorhead>Chief Sponsor: Kristen Chevrier</sponsorhead><otherSponsorhead>Senate Sponsor: </otherSponsorhead></tbox><lt numlevel="1" lineno="2" slineno="0-2"><lthead lineno="3">LONG TITLE</lthead><gdhead lineno="4">General Description:</gdhead><gd numlevel="1" lineno="5" slineno="0-5">This bill modifies the Acupuncture Licensing Act.</gd><hphead lineno="6">Highlighted Provisions:</hphead><hp numlevel="1" lineno="7" slineno="0-7">This bill:<hl numlevel="1" lineno="8" slineno="0-8" level="1">creates an alternate path for licensure as an acupuncturist; and</hl><hl numlevel="1" lineno="9" slineno="0-9" level="1">makes technical and conforming changes. </hl></hp><moni numlevel="1" lineno="10" slineno="0-10" display="none">Money Appropriated in this Bill:</moni><moniNone lineno="11">None</moniNone><oc numlevel="1" lineno="12" slineno="0-12">Other Special Clauses:</oc><ocNone lineno="13">None</ocNone><sa numlevel="1" lineno="14" slineno="0-14">Utah Code Sections Affected:<saamd numlevel="1" lineno="15" slineno="0-15"><snhead>AMENDS:</snhead><sn num="58-72-302" src="code" uid="C58-72-S302_2026050620260506" buid="1" sort="58 72 03020020260506" numlevel="1" lineno="16" slineno="0-16"><bold>58-72-302</bold>, as last amended by Laws of Utah 2020, Chapter 339</sn></saamd></sa></lt><enacthead lineno="17"/><enact numlevel="1" lineno="18" slineno="0-18">Be it enacted by the Legislature of the state of Utah:</enact><bdy><bsec buid="1" num="58-72-302" type="amend" src="code" uid="C58-72-S302_2026050620260506" sort="58 72 03020020260506" numlevel="1" lineno="19" slineno="1-1" sn="1"><section number="58-72-302" numlevel="1" lineno="20" slineno="1-2" type="amend"><secline lineno="19">Section 1. Section <bold>58-72-302</bold> is amended to read:</secline><catline lineno="20"><bold>58-72-302<parens/>. Qualifications for licensure.</bold></catline><sectionText lineno="21"><tab/>An applicant for licensure as a licensed acupuncturist shall:</sectionText><subsection ssid="1-null-1" dnum="1-o" numlevel="1" lineno="22" slineno="1-4" level="1"><display>(1)</display>submit an application in a form <amendoutstart style="2"/><amend anum="0" ea="erase" pairid="47" groupid="34" style="2" owner="jchristopherson" level="1" deltag="both">prescribed by </amend><amendoutend style="2"/>the division<amend anum="0" ea="amend" pairid="45" groupid="32" style="1" owner="jchristopherson" level="1" amendtag="both"> approves</amend>;</subsection><subsection ssid="1-null-2" dnum="2-o" numlevel="1" lineno="23" slineno="1-5" level="1"><display>(2)</display>pay a fee <amendoutstart style="2"/><amend anum="0" ea="erase" pairid="48" groupid="35" style="2" owner="jchristopherson" level="1" deltag="both">determined by the department under</amend><amendoutend style="2"/><amend anum="0" ea="amend" pairid="46" groupid="33" style="1" owner="jchristopherson" level="1" amendtag="both" space="true">the department determines in accordance <ln numlevel="1" lineno="24" slineno="1-6"/>with</amend> Section <xref depth="3" refnumber="63J-1-504" start="0">63J-1-504</xref>;</subsection><subsection ssid="1-26" dnum="_-o:3-i" numlevel="1" lineno="25" slineno="1-7" ea="amend" anum="0" owner="jchristopherson" style="1" level="1"><display><amend anum="0" ea="amend" pairid="1002" style="1" owner="i" level="1" amendtag="start">(3)</amend></display><amend anum="0" ea="amend" pairid="121" groupid="93" style="1" owner="jchristopherson" level="1" amendtag="end">pass the examination the division requires by rule made in accordance with Title 63G, <ln numlevel="1" lineno="26" slineno="1-8"/>Chapter 3, Utah Administrative Rulemaking Act;</amend></subsection><subsection ssid="1-27" dnum="_-o:4-i" numlevel="1" lineno="27" slineno="1-9" ea="amend" anum="0" owner="jchristopherson" style="1" level="1"><display><amend anum="0" ea="amend" pairid="1003" style="1" owner="i" level="1" amendtag="start">(4)</amend></display><amend anum="0" ea="amend" pairid="124" groupid="95" style="1" owner="jchristopherson" level="1" amendtag="end">as the division requires by rule the division makes in accordance with Title 63G, <ln numlevel="1" lineno="28" slineno="1-10"/>Chapter 3, Utah Administrative Rulemaking Act, establish procedures to collect a <ln numlevel="1" lineno="29" slineno="1-11"/>patient's informed consent for treatment;</amend></subsection><subsection ssid="1-28" dnum="_-o:5-i" numlevel="1" lineno="30" slineno="1-12" ea="amend" anum="0" owner="jchristopherson" style="1" level="1"><display><amend anum="0" ea="amend" pairid="1004" style="1" owner="i" level="1" amendtag="start">(5)</amend></display><amend anum="0" ea="amend" pairid="127" groupid="97" style="1" owner="jchristopherson" level="1" amendtag="end">at the board's request, meet with the board for evaluation of the applicant's <ln numlevel="1" lineno="31" slineno="1-13"/>qualifications for licensure; and</amend></subsection><subsection ssid="1-null-3" dnum="3-o:6-i" numlevel="1" lineno="32" slineno="1-14" level="1" space="false"><display><amendoutstart style="2"/><amend anum="0" ea="erase" pairid="1005" style="2" owner="o" level="1" deltag="both">(3)</amend><amendoutend style="2"/><amend anum="0" ea="amend" pairid="1006" style="1" owner="i" level="1" amendtag="start" space="true">(6)</amend></display><subsection ssid="1-8" dnum="_-o:a-i" ea="amend" anum="0" owner="jchristopherson" style="1" level="2" placement="sameline"><display><amend anum="0" ea="amend" pairid="1006" style="1" owner="i" level="1" amendtag="end">(a)</amend></display><amendoutstart style="2"/><amend anum="0" ea="erase" pairid="58" groupid="44" style="2" owner="jchristopherson" level="1" deltag="both">meet the requirements for current active </amend><amendoutend style="2"/><amend anum="0" ea="amend" pairid="54" groupid="40" style="1" owner="jchristopherson" level="1" amendtag="both" space="true">submit evidence of a current </amend><ln numlevel="1" lineno="33" slineno="1-15"/>certification in acupuncture under guidelines <amendoutstart style="2"/><amend anum="0" ea="erase" pairid="59" groupid="45" style="2" owner="jchristopherson" level="1" deltag="both">established by the National <ln numlevel="1" lineno="34" slineno="1-16"/>Commission for the Certification of Acupuncture and Oriental Medicine (NCCAOM) <ln numlevel="1" lineno="35" slineno="1-17"/>as demonstrated through a current certificate or other appropriate documentation</amend><amendoutend style="2"/><amend anum="0" ea="amend" pairid="135" groupid="104" style="1" owner="jchristopherson" level="1" amendtag="both" space="true">that <ln numlevel="1" lineno="36" slineno="1-18"/>the National Certification Board for Acupuncture and Herbal Medicine makes</amend>;<amend anum="0" ea="amend" pairid="9" groupid="8" style="1" owner="jchristopherson" level="1" amendtag="both"> or</amend></subsection><subsection ssid="1-7" dnum="_-o:b-i" numlevel="1" lineno="37" slineno="1-19" ea="amend" anum="0" owner="jchristopherson" style="1" level="2"><display><amend anum="0" ea="amend" pairid="1007" style="1" owner="i" level="1" amendtag="start">(b)</amend></display><amend anum="0" ea="amend" pairid="15" groupid="11" style="1" owner="jchristopherson" level="1" amendtag="end">submit evidence of completing an acupuncture curriculum that:</amend><subsection ssid="1-16" dnum="_-o:i-i" numlevel="1" lineno="38" slineno="1-20" ea="amend" anum="0" owner="jchristopherson" style="1" level="3"><display><amend anum="0" ea="amend" pairid="1008" style="1" owner="i" level="1" amendtag="start">(i)</amend></display><amend anum="0" ea="amend" pairid="66" groupid="50" style="1" owner="jchristopherson" level="1" amendtag="end">is at least two years in length;</amend></subsection><subsection ssid="1-18" dnum="_-o:ii-i" numlevel="1" lineno="39" slineno="1-21" ea="amend" anum="0" owner="jchristopherson" style="1" level="3"><display><amend anum="0" ea="amend" pairid="1009" style="1" owner="i" level="1" amendtag="start">(ii)</amend></display><amend anum="0" ea="amend" pairid="76" groupid="58" style="1" owner="jchristopherson" level="1" amendtag="end">includes:</amend><subsection ssid="1-19" dnum="_-o:A-i" numlevel="1" lineno="40" slineno="1-22" ea="amend" anum="0" owner="jchristopherson" style="1" level="4"><display><amend anum="0" ea="amend" pairid="1010" style="1" owner="i" level="1" amendtag="start">(A)</amend></display><amend anum="0" ea="amend" pairid="81" groupid="62" style="1" owner="jchristopherson" level="1" amendtag="end">450 hours of instruction in East Asian medical theory, diagnosis and treatment <ln numlevel="1" lineno="41" slineno="1-23"/>in acupuncture, and related studies;</amend></subsection><subsection ssid="1-20" dnum="_-o:B-i" numlevel="1" lineno="42" slineno="1-24" ea="amend" anum="0" owner="jchristopherson" style="1" level="4"><display><amend anum="0" ea="amend" pairid="1011" style="1" owner="i" level="1" amendtag="start">(B)</amend></display><amend anum="0" ea="amend" pairid="86" groupid="66" style="1" owner="jchristopherson" level="1" amendtag="end">75 hours of clinical observation;</amend></subsection><subsection ssid="1-21" dnum="_-o:C-i" numlevel="1" lineno="43" slineno="1-25" ea="amend" anum="0" owner="jchristopherson" style="1" level="4"><display><amend anum="0" ea="amend" pairid="1012" style="1" owner="i" level="1" amendtag="start">(C)</amend></display><amend anum="0" ea="amend" pairid="91" groupid="70" style="1" owner="jchristopherson" level="1" amendtag="end">500 hours of instruction in a clinical internship that a licensed acupuncturist <ln numlevel="1" lineno="44" slineno="1-26"/>supervises;</amend></subsection><subsection ssid="1-22" dnum="_-o:D-i" numlevel="1" lineno="45" slineno="1-27" ea="amend" anum="0" owner="jchristopherson" style="1" level="4"><display><amend anum="0" ea="amend" pairid="1013" style="1" owner="i" level="1" amendtag="start">(D)</amend></display><amend anum="0" ea="amend" pairid="96" groupid="74" style="1" owner="jchristopherson" level="1" amendtag="end">225 hours of instruction in biomedical clinical sciences; and</amend></subsection><subsection ssid="1-23" dnum="_-o:E-i" numlevel="1" lineno="46" slineno="1-28" ea="amend" anum="0" owner="jchristopherson" style="1" level="4"><display><amend anum="0" ea="amend" pairid="1014" style="1" owner="i" level="1" amendtag="start">(E)</amend></display><amend anum="0" ea="amend" pairid="101" groupid="78" style="1" owner="jchristopherson" level="1" amendtag="end">100 hours of instruction in counseling, communication, ethics, and practice <ln numlevel="1" lineno="47" slineno="1-29"/>management; and</amend></subsection></subsection><subsection ssid="1-24" dnum="_-o:iii-i" numlevel="1" lineno="48" slineno="1-30" ea="amend" anum="0" owner="jchristopherson" style="1" level="3"><display><amend anum="0" ea="amend" pairid="1015" style="1" owner="i" level="1" amendtag="start">(iii)</amend></display><amend anum="0" ea="amend" pairid="106" groupid="82" style="1" owner="jchristopherson" level="1" amendtag="end"> meets any other requirements the division makes by rule the division makes in <ln numlevel="1" lineno="49" slineno="1-31"/>accordance with Title 63G, Chapter 3, Utah Administrative Rulemaking Act.</amend></subsection></subsection></subsection><subsection ssid="1-null-4" dnum="4-o:_-i" numlevel="1" lineno="50" slineno="1-32" ea="erase" anum="0" owner="jchristopherson" style="2" level="1"><display><amendoutstart style="2"/><amend anum="0" ea="erase" pairid="1016" style="2" owner="o" level="1" deltag="start">(4)</amend></display><amend anum="0" ea="erase" pairid="109" groupid="84" style="2" owner="jchristopherson" level="1" deltag="end">pass the examination required by the division by rule;</amend><amendoutend style="2"/></subsection><subsection ssid="1-null-5" dnum="5-o:_-i" numlevel="1" lineno="51" slineno="1-33" ea="erase" anum="0" owner="jchristopherson" style="2" level="1"><display><amendoutstart style="2"/><amend anum="0" ea="erase" pairid="1017" style="2" owner="o" level="1" deltag="start">(5)</amend></display><amend anum="0" ea="erase" pairid="112" groupid="86" style="2" owner="jchristopherson" level="1" deltag="end">establish procedures, as defined by rule, which shall enable patients to give informed <ln numlevel="1" lineno="52" slineno="1-34"/>consent to treatment; and</amend><amendoutend style="2"/></subsection><subsection ssid="1-null-6" dnum="6-o:_-i" numlevel="1" lineno="53" slineno="1-35" ea="erase" anum="0" owner="jchristopherson" style="2" level="1"><display><amendoutstart style="2"/><amend anum="0" ea="erase" pairid="1018" style="2" owner="o" level="1" deltag="start">(6)</amend></display><amend anum="0" ea="erase" pairid="115" groupid="88" style="2" owner="jchristopherson" level="1" deltag="end">meet with the board, if requested, for the purpose of evaluating the applicant's <ln numlevel="1" lineno="54" slineno="1-36"/>qualifications for licensure.</amend><amendoutend style="2"/></subsection></section></bsec><bsec buid="8" type="uncod" untype="effdate" src="uncod" uid="EF0000" sort="UZEFF" langlock="true" numlevel="1" lineno="55" slineno="2-1" sn="2"><section type="uncod" untype="effdate" display="false" src="uncod"><secline lineno="55">Section 2.  <bold>Effective Date.</bold></secline><sectionText lineno="56"><amend anum="0" ea="amend" pairid="1" groupid="1" style="1" owner="jchristopherson" level="1" amendtag="both">This bill takes effect on <effdate uid="code" date="5/6/2026">May 6, 2026</effdate>.</amend></sectionText></section></bsec></bdy><foot><rev><tm>1-8-26 4:01 PM</tm></rev></foot></leg>