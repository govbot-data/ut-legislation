<leg xml:space="preserve" billnum="HB0468" sponsor="Christine F. Watkins" designation="HB" otherSponsor="" otherHouse="Senate" sess="2026GS" fileno="2026FL1449" date="2/3/2026 12:02:970" printDate="02-03 12:46" subVer="0" minVer="0" office="LEGISLATIVE GENERAL COUNSEL" actionDate="" impact="code"><info><nextbuid>3</nextbuid><aminfo anum="0" effdate="05/06/2026"><seclist><sect action="E" src="code" buid="1" uid="C31A-22-S630.1_2025050720250507" sort="31A22 06300120250507" mtype="section" effdate="05/06/2026">31A-22-630.1</sect><sect src="uncod" untype="effdate" buid="2" uid="EF0000" sort="UZEFF" mtype="uncod" effdate="05/06/2026"/></seclist></aminfo></info><tbox><sinfo><nextpairid>0</nextpairid></sinfo><st numlevel="1" lineno="1" slineno="0-1">Breast Cancer Prevention Amendments</st><sessionhead>2026 GENERAL SESSION</sessionhead><statehead>STATE OF UTAH</statehead><sponsorhead>Chief Sponsor: Christine F. Watkins</sponsorhead><otherSponsorhead>Senate Sponsor: </otherSponsorhead></tbox><lt numlevel="1" lineno="2" slineno="0-2"><lthead lineno="3">LONG TITLE</lthead><gdhead lineno="4">General Description:</gdhead><gd numlevel="1" lineno="5" slineno="0-5">This bill amends provisions related to health insurance and breast examinations that detect <ln numlevel="1" lineno="6" slineno="0-6"/>breast cancer.</gd><hphead lineno="7">Highlighted Provisions:</hphead><hp numlevel="1" lineno="8" slineno="0-8">This bill:<hl numlevel="1" lineno="9" slineno="0-9" level="1">defines terms; and</hl><hl numlevel="1" lineno="10" slineno="0-10" level="1">prohibits a health benefit plan from implementing a cost-sharing requirement for certain <ln numlevel="1" lineno="11" slineno="0-11"/>breast examinations that detect breast cancer.</hl></hp><moni numlevel="1" lineno="12" slineno="0-12" display="none">Money Appropriated in this Bill:</moni><moniNone lineno="13">None</moniNone><oc numlevel="1" lineno="14" slineno="0-14">Other Special Clauses:</oc><ocNone lineno="15">None</ocNone><sa numlevel="1" lineno="16" slineno="0-16">Utah Code Sections Affected:<saent numlevel="1" lineno="17" slineno="0-17"><snhead>ENACTS:</snhead><sn num="31A-22-630.1" src="code" uid="C31A-22-S630.1_2025050720250507" buid="1" sort="31A22 06300120250507" numlevel="1" lineno="18" slineno="0-18"><bold>31A-22-630.1</bold>, Utah Code Annotated 1953</sn></saent></sa></lt><enacthead lineno="19"/><enact numlevel="1" lineno="20" slineno="0-20">Be it enacted by the Legislature of the state of Utah:</enact><bdy><bsec buid="1" num="31A-22-630.1" type="enact" src="code" uid="C31A-22-S630.1_2025050720250507" sort="31A22 06300120250507" numlevel="1" lineno="21" slineno="1-1" sn="1"><section number="31A-22-630.1" numlevel="1" lineno="22" slineno="1-2" type="enact"><secline lineno="21">Section 1. Section <bold>31A-22-630.1</bold> is enacted to read:</secline><catline lineno="22"><bold>31A-22-630.1<parens/>. Breast exam cost sharing.</bold></catline><subsection ssid="1-null-37" dnum="_-o:1-i" numlevel="1" lineno="23" slineno="1-3" ea="amend" anum="0" owner="jchristopherson" style="1" level="1" placement="noreturn"><display><amend anum="0" ea="amend" pairid="1000" style="1" owner="i" level="1" amendtag="start">(1)</amend></display><amend anum="0" ea="amend" pairid="13" groupid="10" style="1" owner="jchristopherson" level="1" amendtag="end">As used in this section:</amend><subsection ssid="1-null-38" dnum="_-o:a-i" numlevel="1" lineno="24" slineno="1-4" ea="amend" anum="0" owner="jchristopherson" style="1" level="2"><display><amend anum="0" ea="amend" pairid="1001" style="1" owner="i" level="1" amendtag="start">(a)</amend></display><amend anum="0" ea="amend" pairid="15" groupid="12" style="1" owner="jchristopherson" level="1" amendtag="end">"Cost-sharing requirement"  means any copayment, coinsurance, deductible, or <ln numlevel="1" lineno="25" slineno="1-5"/>annual limitation on out-of-pocket expenses required by a health benefit plan for a <ln numlevel="1" lineno="26" slineno="1-6"/>specific health care service covered by the health benefit plan.</amend></subsection><subsection ssid="1-null-39" dnum="_-o:b-i" numlevel="1" lineno="27" slineno="1-7" ea="amend" anum="0" owner="jchristopherson" style="1" level="2" space="false"><display><amend anum="0" ea="amend" pairid="1002" style="1" owner="i" level="1" amendtag="start">(b)</amend></display><subsection ssid="1-null-40" dnum="_-o:i-i" ea="amend" anum="0" owner="jchristopherson" style="1" level="3" placement="sameline"><display><amend anum="0" ea="amend" pairid="1003" style="1" owner="i" level="1">(i)</amend></display><amend anum="0" ea="amend" pairid="45" groupid="36" style="1" owner="jchristopherson" level="1" amendtag="end">"Breast examination" means a medical examination of the breast conducted by <ln numlevel="1" lineno="28" slineno="1-8"/>a health care professional.</amend></subsection><subsection ssid="1-null-41" dnum="_-o:ii-i" numlevel="1" lineno="29" slineno="1-9" ea="amend" anum="0" owner="jchristopherson" style="1" level="3"><display><amend anum="0" ea="amend" pairid="1004" style="1" owner="i" level="1" amendtag="start">(ii)</amend></display><amend anum="0" ea="amend" pairid="50" groupid="40" style="1" owner="jchristopherson" level="1" amendtag="end">"Breast examination" includes:</amend><subsection ssid="1-null-42" dnum="_-o:A-i" numlevel="1" lineno="30" slineno="1-10" ea="amend" anum="0" owner="jchristopherson" style="1" level="4"><display><amend anum="0" ea="amend" pairid="1005" style="1" owner="i" level="1" amendtag="start">(A)</amend></display><amend anum="0" ea="amend" pairid="56" groupid="45" style="1" owner="jchristopherson" level="1" amendtag="end">contrast-enhanced mammography;</amend></subsection><subsection ssid="1-null-43" dnum="_-o:B-i" numlevel="1" lineno="31" slineno="1-11" ea="amend" anum="0" owner="jchristopherson" style="1" level="4"><display><amend anum="0" ea="amend" pairid="1006" style="1" owner="i" level="1" amendtag="start">(B)</amend></display><amend anum="0" ea="amend" pairid="61" groupid="49" style="1" owner="jchristopherson" level="1" amendtag="end">diagnostic mammography;</amend></subsection><subsection ssid="1-null-44" dnum="_-o:C-i" numlevel="1" lineno="32" slineno="1-12" ea="amend" anum="0" owner="jchristopherson" style="1" level="4"><display><amend anum="0" ea="amend" pairid="1007" style="1" owner="i" level="1" amendtag="start">(C)</amend></display><amend anum="0" ea="amend" pairid="72" groupid="58" style="1" owner="jchristopherson" level="1" amendtag="end">breast magnetic resonance imaging; and</amend></subsection><subsection ssid="1-null-45" dnum="_-o:D-i" numlevel="1" lineno="33" slineno="1-13" ea="amend" anum="0" owner="jchristopherson" style="1" level="4"><display><amend anum="0" ea="amend" pairid="1008" style="1" owner="i" level="1" amendtag="start">(D)</amend></display><amend anum="0" ea="amend" pairid="66" groupid="53" style="1" owner="jchristopherson" level="1" amendtag="end">breast ultrasound.</amend></subsection></subsection></subsection><subsection ssid="1-null-46" dnum="_-o:c-i" numlevel="1" lineno="34" slineno="1-14" ea="amend" anum="0" owner="jchristopherson" style="1" level="2"><display><amend anum="0" ea="amend" pairid="1009" style="1" owner="i" level="1" amendtag="start">(c)</amend></display><amend anum="0" ea="amend" pairid="19" groupid="15" style="1" owner="jchristopherson" level="1" amendtag="end">"Diagnostic breast examination" means a medically necessary breast examination <ln numlevel="1" lineno="35" slineno="1-15"/>that is used to evaluate an abnormality that was detected or suspected after another <ln numlevel="1" lineno="36" slineno="1-16"/>means of examination, including a previous breast examination.</amend></subsection><subsection ssid="1-null-47" dnum="_-o:d-i" numlevel="1" lineno="37" slineno="1-17" ea="amend" anum="0" owner="jchristopherson" style="1" level="2"><display><amend anum="0" ea="amend" pairid="1010" style="1" owner="i" level="1" amendtag="start">(d)</amend></display><amend anum="0" ea="amend" pairid="24" groupid="19" style="1" owner="jchristopherson" level="1" amendtag="end">"Supplemental breast examination" means a medically necessary breast examination <ln numlevel="1" lineno="38" slineno="1-18"/>that is used to screen for breast cancer:</amend><subsection ssid="1-null-48" dnum="_-o:i-i" numlevel="1" lineno="39" slineno="1-19" ea="amend" anum="0" owner="jchristopherson" style="1" level="3"><display><amend anum="0" ea="amend" pairid="1011" style="1" owner="i" level="1" amendtag="start">(i)</amend></display><amend anum="0" ea="amend" pairid="30" groupid="24" style="1" owner="jchristopherson" level="1" amendtag="end">when there is no prior indication that a breast health abnormality exists or is <ln numlevel="1" lineno="40" slineno="1-20"/>suspected;</amend></subsection><subsection ssid="1-null-49" dnum="_-o:ii-i" numlevel="1" lineno="41" slineno="1-21" ea="amend" anum="0" owner="jchristopherson" style="1" level="3"><display><amend anum="0" ea="amend" pairid="1012" style="1" owner="i" level="1" amendtag="start">(ii)</amend></display><amend anum="0" ea="amend" pairid="35" groupid="28" style="1" owner="jchristopherson" level="1" amendtag="end">based on personal or family medical history; or</amend></subsection><subsection ssid="1-null-50" dnum="_-o:iii-i" numlevel="1" lineno="42" slineno="1-22" ea="amend" anum="0" owner="jchristopherson" style="1" level="3"><display><amend anum="0" ea="amend" pairid="1013" style="1" owner="i" level="1" amendtag="start">(iii)</amend></display><amend anum="0" ea="amend" pairid="83" groupid="66" style="1" owner="jchristopherson" level="1" amendtag="end">based on additional factors that increase an individual's risk of breast cancer.</amend></subsection></subsection></subsection><subsection ssid="1-null-51" dnum="_-o:2-i" numlevel="1" lineno="43" slineno="1-23" ea="amend" anum="0" owner="jchristopherson" style="1" level="1"><display><amend anum="0" ea="amend" pairid="1014" style="1" owner="i" level="1" amendtag="start">(2)</amend></display><amend anum="0" ea="amend" pairid="78" groupid="62" style="1" owner="jchristopherson" level="1" amendtag="end">A health benefit plan that provides benefits with respect to diagnostic breast <ln numlevel="1" lineno="44" slineno="1-24"/>examinations or supplemental breast examinations may not require an enrollee to pay a <ln numlevel="1" lineno="45" slineno="1-25"/>cost-sharing requirement for a diagnostic breast examination or a supplemental breast <ln numlevel="1" lineno="46" slineno="1-26"/>examination.</amend></subsection><subsection ssid="1-null-52" dnum="_-o:3-i" numlevel="1" lineno="47" slineno="1-27" ea="amend" anum="0" owner="jchristopherson" style="1" level="1"><display><amend anum="0" ea="amend" pairid="1015" style="1" owner="i" level="1" amendtag="start">(3)</amend></display><amend anum="0" ea="amend" pairid="89" groupid="71" style="1" owner="jchristopherson" level="1" amendtag="end">A diagnostic breast examination or a supplemental breast examination is medically <ln numlevel="1" lineno="48" slineno="1-28"/>necessary if the examination is provided in accordance with the National <ln numlevel="1" lineno="49" slineno="1-29"/>Comprehensive Cancer Network Guidelines.</amend></subsection></section></bsec><bsec buid="2" type="uncod" untype="effdate" src="uncod" uid="EF0000" sort="UZEFF" langlock="true" numlevel="1" lineno="50" slineno="2-1" sn="2"><section type="uncod" untype="effdate" display="false" src="uncod"><secline lineno="50">Section 2.  <bold>Effective Date.</bold></secline><sectionText lineno="51"><amend anum="0" ea="amend" pairid="1" groupid="1" style="1" owner="jchristopherson" level="1" amendtag="both">This bill takes effect on <effdate uid="code" date="5/6/2026">May 6, 2026</effdate>.</amend></sectionText></section></bsec></bdy><foot><rev><tm>2-3-26 12:46 PM</tm></rev></foot></leg>