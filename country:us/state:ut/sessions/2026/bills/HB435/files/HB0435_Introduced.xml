<leg xml:space="preserve" billnum="HB0435" sponsor="Karianne Lisonbee" designation="HB" otherSponsor="Keven J. Stratton" otherHouse="Senate" sess="2026GS" fileno="2026FL1423" date="1/30/2026 09:01:850" printDate="02-03 14:11" subVer="0" minVer="0" office="LEGISLATIVE GENERAL COUNSEL" actionDate="" impact="code"><info><nextbuid>3</nextbuid><aminfo anum="0" effdate="05/06/2026"><seclist><sect action="E" src="code" buid="1" uid="C63G-34-S101_2026050620260506" sort="63G34 01010020260506" mtype="section" effdate="05/06/2026">63G-34-101</sect><sect src="uncod" untype="effdate" buid="2" uid="EF0000" sort="UZEFF" mtype="uncod" effdate="05/06/2026"/></seclist></aminfo></info><tbox><sinfo><nextpairid>0</nextpairid></sinfo><st numlevel="1" lineno="1" slineno="0-1">State Policy on Judea and Samaria</st><sessionhead>2026 GENERAL SESSION</sessionhead><statehead>STATE OF UTAH</statehead><sponsorhead>Chief Sponsor: Karianne Lisonbee</sponsorhead><otherSponsorhead>Senate Sponsor: Keven J. Stratton</otherSponsorhead></tbox><lt numlevel="1" lineno="2" slineno="0-2"><lthead lineno="3">LONG TITLE</lthead><gdhead lineno="4">General Description:</gdhead><gd numlevel="1" lineno="5" slineno="0-5">This bill establishes a state policy of referring to certain land controlled by Israel as Judea <ln numlevel="1" lineno="6" slineno="0-6"/>and Samaria.</gd><hphead lineno="7">Highlighted Provisions:</hphead><hp numlevel="1" lineno="8" slineno="0-8">This bill:<hl numlevel="1" lineno="9" slineno="0-9" level="1">defines terms;</hl><hl numlevel="1" lineno="10" slineno="0-10" level="1">makes it state policy to refer to the land, restored to Israel from Jordan during the 1967 <ln numlevel="1" lineno="11" slineno="0-11"/>Six-Day War, by the land's historical names of Judea and Samaria; and</hl><hl numlevel="1" lineno="12" slineno="0-12" level="1">prohibits a state agency or official government material from referring to the land <ln numlevel="1" lineno="13" slineno="0-13"/>described in the preceding paragraph as "West Bank." </hl></hp><moni numlevel="1" lineno="14" slineno="0-14" display="none">Money Appropriated in this Bill:</moni><moniNone lineno="15">None</moniNone><oc numlevel="1" lineno="16" slineno="0-16">Other Special Clauses:</oc><ocNone lineno="17">None</ocNone><sa numlevel="1" lineno="18" slineno="0-18">Utah Code Sections Affected:<saent numlevel="1" lineno="19" slineno="0-19"><snhead>ENACTS:</snhead><sn num="63G-34-101" src="code" uid="C63G-34-S101_2026050620260506" buid="1" sort="63G34 01010020260506" numlevel="1" lineno="20" slineno="0-20"><bold>63G-34-101</bold>, Utah Code Annotated 1953</sn></saent></sa></lt><enacthead lineno="21"/><enact numlevel="1" lineno="22" slineno="0-22">Be it enacted by the Legislature of the state of Utah:</enact><bdy><bsec buid="1" num="63G-34-101" type="enact" src="code" uid="C63G-34-S101_2026050620260506" sort="63G34 01010020260506" numlevel="1" lineno="23" slineno="1-1" sn="1"><section numlevel="1" lineno="25" slineno="1-3" number="63G-34-101" type="enact"><secline lineno="23">Section 1. Section <bold>63G-34-101</bold> is enacted to read:</secline><headchap number="63G-34" numlevel="1" lineno="24" slineno="1-2">34. State Policies and Requirements</headchap><catline lineno="25"><bold>63G-34-101<parens/>. Reference to Judea and Samaria by a state agency.</bold></catline><subsection ssid="1-1" dnum="_-o:1-i" numlevel="1" lineno="26" slineno="1-4" ea="amend" anum="0" owner="jchristopherson" style="1" level="1" placement="noreturn"><display><amend anum="0" ea="amend" pairid="1000" style="1" owner="i" level="1" amendtag="start">(1)</amend></display><amend anum="0" ea="amend" pairid="3" groupid="3" style="1" owner="jchristopherson" level="1" amendtag="end">As used in this section:</amend><subsection ssid="1-5" dnum="_-o:a-i" numlevel="1" lineno="27" slineno="1-5" ea="amend" anum="0" owner="jchristopherson" style="1" level="2"><display><amend anum="0" ea="amend" pairid="1001" style="1" owner="i" level="1" amendtag="start">(a)</amend></display><amend anum="0" ea="amend" pairid="25" groupid="20" style="1" owner="jchristopherson" level="1" amendtag="end">"Official government material" means any material prepared or produced by a state <ln numlevel="1" lineno="28" slineno="1-6"/>agency, whether written, printed, electronic, or in another medium, including:</amend><subsection ssid="1-6" dnum="_-o:i-i" numlevel="1" lineno="29" slineno="1-7" ea="amend" anum="0" owner="jchristopherson" style="1" level="3"><display><amend anum="0" ea="amend" pairid="1002" style="1" owner="i" level="1" amendtag="start">(i)</amend></display><amend anum="0" ea="amend" pairid="30" groupid="24" style="1" owner="jchristopherson" level="1" amendtag="end">a rule;</amend></subsection><subsection ssid="1-7" dnum="_-o:ii-i" numlevel="1" lineno="30" slineno="1-8" ea="amend" anum="0" owner="jchristopherson" style="1" level="3"><display><amend anum="0" ea="amend" pairid="1003" style="1" owner="i" level="1" amendtag="start">(ii)</amend></display><amend anum="0" ea="amend" pairid="35" groupid="28" style="1" owner="jchristopherson" level="1" amendtag="end">a press release;</amend></subsection><subsection ssid="1-8" dnum="_-o:iii-i" numlevel="1" lineno="31" slineno="1-9" ea="amend" anum="0" owner="jchristopherson" style="1" level="3"><display><amend anum="0" ea="amend" pairid="1004" style="1" owner="i" level="1" amendtag="start">(iii)</amend></display><amend anum="0" ea="amend" pairid="40" groupid="32" style="1" owner="jchristopherson" level="1" amendtag="end">a communication;</amend></subsection><subsection ssid="1-9" dnum="_-o:iv-i" numlevel="1" lineno="32" slineno="1-10" ea="amend" anum="0" owner="jchristopherson" style="1" level="3"><display><amend anum="0" ea="amend" pairid="1005" style="1" owner="i" level="1" amendtag="start">(iv)</amend></display><amend anum="0" ea="amend" pairid="45" groupid="36" style="1" owner="jchristopherson" level="1" amendtag="end">a briefing;</amend></subsection><subsection ssid="1-10" dnum="_-o:v-i" numlevel="1" lineno="33" slineno="1-11" ea="amend" anum="0" owner="jchristopherson" style="1" level="3"><display><amend anum="0" ea="amend" pairid="1006" style="1" owner="i" level="1" amendtag="start">(v)</amend></display><amend anum="0" ea="amend" pairid="50" groupid="40" style="1" owner="jchristopherson" level="1" amendtag="end">guidance; or</amend></subsection><subsection ssid="1-11" dnum="_-o:vi-i" numlevel="1" lineno="34" slineno="1-12" ea="amend" anum="0" owner="jchristopherson" style="1" level="3"><display><amend anum="0" ea="amend" pairid="1007" style="1" owner="i" level="1" amendtag="start">(vi)</amend></display><amend anum="0" ea="amend" pairid="55" groupid="44" style="1" owner="jchristopherson" level="1" amendtag="end">a publication.</amend></subsection></subsection><subsection ssid="1-12" dnum="_-o:b-i" numlevel="1" lineno="35" slineno="1-13" ea="amend" anum="0" owner="jchristopherson" style="1" level="2"><display><amend anum="0" ea="amend" pairid="1008" style="1" owner="i" level="1" amendtag="start">(b)</amend></display><amend anum="0" ea="amend" pairid="60" groupid="48" style="1" owner="jchristopherson" level="1" amendtag="end">"State agency" means a department, division, office, commission, or other institution <ln numlevel="1" lineno="36" slineno="1-14"/>of the state.</amend></subsection></subsection><subsection ssid="1-2" dnum="_-o:2-i" numlevel="1" lineno="37" slineno="1-15" ea="amend" anum="0" owner="jchristopherson" style="1" level="1"><display><amend anum="0" ea="amend" pairid="1009" style="1" owner="i" level="1" amendtag="start">(2)</amend></display><amend anum="0" ea="amend" pairid="18" groupid="14" style="1" owner="jchristopherson" level="1" amendtag="end">It is the policy of the state to refer to the land restored to Israel from Jordan during the <ln numlevel="1" lineno="38" slineno="1-16"/>1967 Six-Day War, by the land's historical names of Judea and Samaria, with the land s<ln numlevel="1" lineno="39" slineno="1-17"/>outh of Jerusalem considered Judea and the land north of Jerusalem considered Samaria.</amend></subsection><subsection ssid="1-3" dnum="_-o:3-i" numlevel="1" lineno="40" slineno="1-18" ea="amend" anum="0" owner="jchristopherson" style="1" level="1"><display><amend anum="0" ea="amend" pairid="1010" style="1" owner="i" level="1" amendtag="start">(3)</amend></display><amend anum="0" ea="amend" pairid="20" groupid="16" style="1" owner="jchristopherson" level="1" amendtag="end">A state agency may not use the term "West Bank," or use state funds to create official <ln numlevel="1" lineno="41" slineno="1-19"/>government material that uses the term "West Bank," to refer to the land described in <ln numlevel="1" lineno="42" slineno="1-20"/>Subsection <xref depth="4" refnumber="63G-34-101(2)">(2</xref>).</amend></subsection></section></bsec><bsec buid="2" type="uncod" untype="effdate" src="uncod" uid="EF0000" sort="UZEFF" langlock="true" numlevel="1" lineno="43" slineno="2-1" sn="2"><section type="uncod" untype="effdate" display="false" src="uncod"><secline lineno="43">Section 2.  <bold>Effective Date.</bold></secline><sectionText lineno="44"><amend anum="0" ea="amend" pairid="1" groupid="1" style="1" owner="jchristopherson" level="1" amendtag="both">This bill takes effect on <effdate uid="code" date="5/6/2026">May 6, 2026</effdate>.</amend></sectionText></section></bsec></bdy><foot><rev><tm>1-30-26 9:37 AM</tm></rev></foot></leg>