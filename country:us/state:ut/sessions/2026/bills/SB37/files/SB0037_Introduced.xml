<leg xml:space="preserve" billnum="SB0037" sponsor="Calvin R. Musselman" designation="SB" otherSponsor="Matthew H. Gwynn" otherHouse="House" sess="2026GS" fileno="2026FL0617" date="12/19/2025 16:12:913" printDate="02-02 12:08" subVer="0" minVer="0" office="LEGISLATIVE GENERAL COUNSEL" actionDate="" impact="code"><info><nextbuid>3</nextbuid><aminfo anum="0" effdate="05/06/2026"><seclist><sect action="E" src="code" buid="1" uid="C72-4-S224_2026050620260506" sort="72 04 02240020260506" mtype="section" effdate="05/06/2026">72-4-224</sect><sect src="uncod" untype="effdate" buid="2" uid="EF0000" sort="UZEFF" mtype="uncod" effdate="05/06/2026"/></seclist></aminfo></info><tbox><sinfo><nextpairid>0</nextpairid></sinfo><st numlevel="1" lineno="1" slineno="0-1">George E. Wahlen Memorial Highway Designation</st><sessionhead>2026 GENERAL SESSION</sessionhead><statehead>STATE OF UTAH</statehead><sponsorhead>Chief Sponsor: Calvin R. Musselman</sponsorhead><otherSponsorhead>House Sponsor: Matthew H. Gwynn</otherSponsorhead></tbox><lt numlevel="1" lineno="2" slineno="0-2"><lthead lineno="3">LONG TITLE</lthead><cn numlevel="1" lineno="4" slineno="0-4">Committee Note:<comrec voteid="38375" comcode="INTTRA" numlevel="1" lineno="5" slineno="0-5"> The Transportation Interim Committee recommended this bill.<legvote numlevel="1" lineno="6" slineno="0-6">Legislative Vote:<yes>12 voting for</yes><no>0 voting against</no><abs>6 absent</abs></legvote></comrec></cn><gdhead lineno="7">General Description:</gdhead><gd numlevel="1" lineno="8" slineno="0-8">This bill enacts provisions related to the name of Route 126 in Weber County.</gd><hphead lineno="9">Highlighted Provisions:</hphead><hp numlevel="1" lineno="10" slineno="0-10">This bill:<hl numlevel="1" lineno="11" slineno="0-11" level="1">establishes the name of Route 126 in Weber County as the George E. Wahlen Memorial <ln numlevel="1" lineno="12" slineno="0-12"/>Highway.</hl></hp><moni numlevel="1" lineno="13" slineno="0-13" display="none">Money Appropriated in this Bill:</moni><moniNone lineno="14">None</moniNone><oc numlevel="1" lineno="15" slineno="0-15">Other Special Clauses:</oc><ocNone lineno="16">None</ocNone><sa numlevel="1" lineno="17" slineno="0-17">Utah Code Sections Affected:<saent numlevel="1" lineno="18" slineno="0-18"><snhead>ENACTS:</snhead><sn num="72-4-224" src="code" uid="C72-4-S224_2026050620260506" buid="1" sort="72 04 02240020260506" numlevel="1" lineno="19" slineno="0-19"><bold>72-4-224</bold>, Utah Code Annotated 1953</sn></saent></sa></lt><enacthead lineno="20"/><enact numlevel="1" lineno="21" slineno="0-21">Be it enacted by the Legislature of the state of Utah:</enact><bdy><bsec buid="1" num="72-4-224" type="enact" src="code" uid="C72-4-S224_2026050620260506" sort="72 04 02240020260506" numlevel="1" lineno="22" slineno="1-1" sn="1"><section numlevel="1" lineno="23" slineno="1-2" number="72-4-224" type="enact"><secline lineno="22">Section 1. Section <bold>72-4-224</bold> is enacted to read:</secline><catline lineno="23"><bold>72-4-224<parens/>. George E. Wahlen Memorial Highway.</bold></catline><subsection ssid="1-1" dnum="_-o:1-i" numlevel="1" lineno="24" slineno="1-3" ea="amend" anum="0" owner="jchristopherson" style="1" level="1" placement="noreturn"><display><amend anum="0" ea="amend" pairid="1000" style="1" owner="i" level="1" amendtag="start">(1)</amend></display><amend anum="0" ea="amend" pairid="6" groupid="5" style="1" owner="jchristopherson" level="1" amendtag="end">There is established the George E. Wahlen Memorial Highway composed of the portion <ln numlevel="1" lineno="25" slineno="1-4"/>of existing Route 126 contained within Weber County.</amend></subsection><subsection ssid="1-2" dnum="_-o:2-i" numlevel="1" lineno="26" slineno="1-5" ea="amend" anum="0" owner="jchristopherson" style="1" level="1"><display><amend anum="0" ea="amend" pairid="1001" style="1" owner="i" level="1" amendtag="start">(2)</amend></display><amend anum="0" ea="amend" pairid="10" groupid="8" style="1" owner="jchristopherson" level="1" amendtag="end">In addition to other official designations, the Department of Transportation shall <ln numlevel="1" lineno="27" slineno="1-6"/>designate the portion of the highway identified in Subsection <xref depth="4" refnumber="72-4-224(1)">(1)</xref> as the George E. <ln numlevel="1" lineno="28" slineno="1-7"/>Wahlen Memorial Highway on future state highway maps.</amend></subsection><subsection ssid="1-3" dnum="_-o:3-i" numlevel="1" lineno="29" slineno="1-8" ea="amend" anum="0" owner="jchristopherson" style="1" level="1"><display><amend anum="0" ea="amend" pairid="1002" style="1" owner="i" level="1" amendtag="start">(3)</amend></display><amend anum="0" ea="amend" pairid="14" groupid="11" style="1" owner="jchristopherson" level="1" amendtag="end">As soon as practicable, the Department of Transportation shall install appropriate signs <ln numlevel="1" lineno="30" slineno="1-9"/>along portions of the highway indicating the designation as the George E. Wahlen <ln numlevel="1" lineno="31" slineno="1-10"/>Memorial Highway as described in Subsection <xref depth="4" refnumber="72-4-224(1)">(1)</xref>.</amend></subsection></section></bsec><bsec buid="2" type="uncod" untype="effdate" src="uncod" uid="EF0000" sort="UZEFF" langlock="true" numlevel="1" lineno="32" slineno="2-1" sn="2"><section type="uncod" untype="effdate" display="false" src="uncod"><secline lineno="32">Section 2.  <bold>Effective Date.</bold></secline><sectionText lineno="33"><amend anum="0" ea="amend" pairid="1" groupid="1" style="1" owner="jchristopherson" level="1" amendtag="both">This bill takes effect on <effdate uid="code" date="5/6/2026">May 6, 2026</effdate>.</amend></sectionText></section></bsec></bdy><foot><rev><tm>12-19-25 4:39 PM</tm></rev></foot></leg>