<?xml version="1.0" encoding="UTF-16"?>
<leg xml:space="preserve" billnum="SB0074" sponsor="Calvin R. Musselman" designation="SB" otherSponsor="" otherHouse="House" subNumber="02" subSponsor="Calvin R. Musselman" sess="2026GS" fileno="2026FL1052" date="2/11/2026 09:02:487" printDate="02-11 09:59" subVer="2" minVer="0" office="LEGISLATIVE GENERAL COUNSEL" actionDate="" impact="code"><info><nextbuid>6</nextbuid><aminfo anum="0" effdate="05/06/2026"><seclist><sect action="E" src="code" buid="3" uid="C31A-22-S323_2026050620260506" sort="31A22 03230020260506" mtype="section" effdate="05/06/2026">31A-22-323</sect><sect src="uncod" untype="effdate" buid="5" uid="EF0000" sort="UZEFF" mtype="uncod" effdate="05/06/2026"/></seclist></aminfo></info><tbox><sinfo><nextpairid>0</nextpairid></sinfo><st numlevel="1" lineno="1" slineno="0-1">Motor Vehicle Civil Action Amendments</st><sessionhead>2026 GENERAL SESSION</sessionhead><statehead>STATE OF UTAH</statehead><sponsorhead>Chief Sponsor: Calvin R. Musselman</sponsorhead><otherSponsorhead>House Sponsor: </otherSponsorhead></tbox><lt numlevel="1" lineno="2" slineno="0-2"><lthead lineno="3">LONG TITLE</lthead><gdhead lineno="4">General Description:</gdhead><gd numlevel="1" lineno="5" slineno="0-5">This bill enacts requirements for a time-limited demand letter.</gd><hphead lineno="6">Highlighted Provisions:</hphead><hp numlevel="1" lineno="7" slineno="0-7">This bill:<hl numlevel="1" lineno="8" slineno="0-8" level="1">enacts requirements for a time-limited demand letter related to a motor vehicle insurance <ln numlevel="1" lineno="9" slineno="0-9"/>claim;</hl><hl numlevel="1" lineno="10" slineno="0-10" level="1">provides parameters and timing for a time-limited demand letter; and</hl><hl numlevel="1" lineno="11" slineno="0-11" level="1">addresses an insurer's duties and an insured's rights and remedies in relation to a <ln numlevel="1" lineno="12" slineno="0-12"/>time-limited demand letter.</hl></hp><moni numlevel="1" lineno="13" slineno="0-13" display="none">Money Appropriated in this Bill:</moni><moniNone lineno="14">None</moniNone><oc numlevel="1" lineno="15" slineno="0-15">Other Special Clauses:</oc><ocNone lineno="16">None</ocNone><sa numlevel="1" lineno="17" slineno="0-17">Utah Code Sections Affected:<saent numlevel="1" lineno="18" slineno="0-18"><snhead>ENACTS:</snhead><sn num="31A-22-323" src="code" uid="C31A-22-S323_2026050620260506" buid="3" sort="31A22 03230020260506" numlevel="1" lineno="19" slineno="0-19"><bold>31A-22-323</bold>, Utah Code Annotated 1953</sn></saent></sa></lt><enacthead lineno="20"/><enact numlevel="1" lineno="21" slineno="0-21">Be it enacted by the Legislature of the state of Utah:</enact><bdy><bsec buid="3" num="31A-22-323" type="enact" src="code" uid="C31A-22-S323_2026050620260506" sort="31A22 03230020260506" numlevel="1" lineno="22" slineno="1-1" sn="1"><section numlevel="1" lineno="23" slineno="1-2" number="31A-22-323" type="enact"><secline lineno="22">Section 1. Section <bold>31A-22-323</bold> is enacted to read:</secline><catline lineno="23"><bold>31A-22-323<parens/>. Time-limited demand letter -- Requirements.</bold></catline><subsection ssid="3-1" dnum="_-o:1-i" numlevel="1" lineno="24" slineno="1-3" ea="amend" anum="0" owner="ahaskell" style="1" level="1" placement="noreturn"><display><amend anum="0" ea="amend" pairid="1000" style="1" owner="i" level="1" amendtag="start">(1)</amend></display><amend anum="0" ea="amend" pairid="13" groupid="10" style="1" owner="ahaskell" level="1" amendtag="end">A person issuing a time-limited demand to settle any claim under this part shall ensure <ln numlevel="1" lineno="25" slineno="1-4"/>that the letter:</amend><subsection ssid="3-2" dnum="_-o:a-i" numlevel="1" lineno="26" slineno="1-5" ea="amend" anum="0" owner="ahaskell" style="1" level="2"><display><amend anum="0" ea="amend" pairid="1001" style="1" owner="i" level="1" amendtag="start">(a)</amend></display><amend anum="0" ea="amend" pairid="36" groupid="28" style="1" owner="ahaskell" level="1" amendtag="end">is in writing;</amend></subsection><subsection ssid="3-4" dnum="_-o:b-i" numlevel="1" lineno="27" slineno="1-6" ea="amend" anum="0" owner="ahaskell" style="1" level="2"><display><amend anum="0" ea="amend" pairid="1002" style="1" owner="i" level="1" amendtag="start">(b)</amend></display><amend anum="0" ea="amend" pairid="28" groupid="21" style="1" owner="ahaskell" level="1" amendtag="end">is labeled as a time-limited demand to settle;</amend></subsection><subsection ssid="3-3" dnum="_-o:c-i" numlevel="1" lineno="28" slineno="1-7" ea="amend" anum="0" owner="ahaskell" style="1" level="2"><display><amend anum="0" ea="amend" pairid="1003" style="1" owner="i" level="1" amendtag="start">(c)</amend></display><amend anum="0" ea="amend" pairid="37" groupid="29" style="1" owner="ahaskell" level="1" amendtag="end">references this section; and</amend></subsection><subsection ssid="3-5" dnum="_-o:d-i" numlevel="1" lineno="29" slineno="1-8" ea="amend" anum="0" owner="ahaskell" style="1" level="2"><display><amend anum="0" ea="amend" pairid="1004" style="1" owner="i" level="1" amendtag="start">(d)</amend></display><amend anum="0" ea="amend" pairid="35" groupid="27" style="1" owner="ahaskell" level="1" amendtag="end">contains material terms, including:</amend><subsection ssid="3-6" dnum="_-o:i-i" numlevel="1" lineno="30" slineno="1-9" ea="amend" anum="0" owner="ahaskell" style="1" level="3"><display><amend anum="0" ea="amend" pairid="1005" style="1" owner="i" level="1" amendtag="start">(i)</amend></display><amend anum="0" ea="amend" pairid="42" groupid="32" style="1" owner="ahaskell" level="1" amendtag="end">the time period within which the demand is required to be accepted, which shall <ln numlevel="1" lineno="31" slineno="1-10"/>be no fewer than 45 days from the date on which the letter is received by certified <ln numlevel="1" lineno="32" slineno="1-11"/>mail;</amend></subsection><subsection ssid="3-10" dnum="_-o:ii-i" numlevel="1" lineno="33" slineno="1-12" ea="amend" anum="0" owner="ahaskell" style="1" level="3"><display><amend anum="0" ea="amend" pairid="1006" style="1" owner="i" level="1" amendtag="start">(ii)</amend></display><amend anum="0" ea="amend" pairid="62" groupid="48" style="1" owner="ahaskell" level="1" amendtag="end">a clear and unequivocal offer to settle all claims within policy limits, including <ln numlevel="1" lineno="34" slineno="1-13"/>the satisfaction of all known liens;</amend></subsection><subsection ssid="3-11" dnum="_-o:iii-i" numlevel="1" lineno="35" slineno="1-14" ea="amend" anum="0" owner="ahaskell" style="1" level="3"><display><amend anum="0" ea="amend" pairid="1007" style="1" owner="i" level="1" amendtag="start">(iii)</amend></display><amend anum="0" ea="amend" pairid="68" groupid="53" style="1" owner="ahaskell" level="1" amendtag="end">an offer for a complete release from the claimant of all present and future claims <ln numlevel="1" lineno="36" slineno="1-15"/>arising from the occurrence against the insured;</amend></subsection><subsection ssid="3-12" dnum="_-o:iv-i" numlevel="1" lineno="37" slineno="1-16" ea="amend" anum="0" owner="ahaskell" style="1" level="3"><display><amend anum="0" ea="amend" pairid="1008" style="1" owner="i" level="1" amendtag="start">(iv)</amend></display><amend anum="0" ea="amend" pairid="73" groupid="57" style="1" owner="ahaskell" level="1" amendtag="end">the date and location of the loss;</amend></subsection><subsection ssid="3-13" dnum="_-o:v-i" numlevel="1" lineno="38" slineno="1-17" ea="amend" anum="0" owner="ahaskell" style="1" level="3"><display><amend anum="0" ea="amend" pairid="1009" style="1" owner="i" level="1" amendtag="start">(v)</amend></display><amend anum="0" ea="amend" pairid="78" groupid="61" style="1" owner="ahaskell" level="1" amendtag="end">the claim number, if known;</amend></subsection><subsection ssid="3-14" dnum="_-o:vi-i" numlevel="1" lineno="39" slineno="1-18" ea="amend" anum="0" owner="ahaskell" style="1" level="3"><display><amend anum="0" ea="amend" pairid="1010" style="1" owner="i" level="1" amendtag="start">(vi)</amend></display><amend anum="0" ea="amend" pairid="83" groupid="65" style="1" owner="ahaskell" level="1" amendtag="end">a description of all known injuries alleged to have been sustained by the claimant;</amend></subsection><subsection ssid="3-18" dnum="_-o:vii-i" numlevel="1" lineno="40" slineno="1-19" ea="amend" anum="0" owner="ahaskell" style="1" level="3"><display><amend anum="0" ea="amend" pairid="1011" style="1" owner="i" level="1" amendtag="start">(vii)</amend></display><amend anum="0" ea="amend" pairid="108" groupid="85" style="1" owner="ahaskell" level="1" amendtag="end">reasonable proof of injury sufficient to demonstrate that the claimant sustained <ln numlevel="1" lineno="41" slineno="1-20"/>an actual injury arising from the occurrence, including:</amend><subsection ssid="3-19" dnum="_-o:A-i" numlevel="1" lineno="42" slineno="1-21" ea="amend" anum="0" owner="ahaskell" style="1" level="4"><display><amend anum="0" ea="amend" pairid="1012" style="1" owner="i" level="1" amendtag="start">(A)</amend></display><amend anum="0" ea="amend" pairid="115" groupid="90" style="1" owner="ahaskell" level="1" amendtag="end">medical records;</amend></subsection><subsection ssid="3-20" dnum="_-o:B-i" numlevel="1" lineno="43" slineno="1-22" ea="amend" anum="0" owner="ahaskell" style="1" level="4"><display><amend anum="0" ea="amend" pairid="1013" style="1" owner="i" level="1" amendtag="start">(B)</amend></display><amend anum="0" ea="amend" pairid="120" groupid="94" style="1" owner="ahaskell" level="1" amendtag="end">billing statements; and</amend></subsection><subsection ssid="3-21" dnum="_-o:C-i" numlevel="1" lineno="44" slineno="1-23" ea="amend" anum="0" owner="ahaskell" style="1" level="4"><display><amend anum="0" ea="amend" pairid="1014" style="1" owner="i" level="1" amendtag="start">(C)</amend></display><amend anum="0" ea="amend" pairid="125" groupid="98" style="1" owner="ahaskell" level="1" amendtag="end">sworn statements or other documentation supporting the existence of the <ln numlevel="1" lineno="45" slineno="1-24"/>injury; and</amend></subsection></subsection><subsection ssid="3-22" dnum="_-o:viii-i" numlevel="1" lineno="46" slineno="1-25" ea="amend" anum="0" owner="ahaskell" style="1" level="3"><display><amend anum="0" ea="amend" pairid="1015" style="1" owner="i" level="1" amendtag="start">(viii)</amend></display><amend anum="0" ea="amend" pairid="126" groupid="99" style="1" owner="ahaskell" level="1" amendtag="end">if the demand references or suggests the possibility of placing a judicial lien <ln numlevel="1" lineno="47" slineno="1-26"/>against personal property, a plain-language explanation of the process for <ln numlevel="1" lineno="48" slineno="1-27"/>obtaining a judicial lien and a statement advising the insured of the insured's right <ln numlevel="1" lineno="49" slineno="1-28"/>to consult independent legal counsel.</amend></subsection></subsection></subsection><subsection ssid="3-23" dnum="_-o:2-i" numlevel="1" lineno="50" slineno="1-29" ea="amend" anum="0" owner="ahaskell" style="1" level="1"><display><amend anum="0" ea="amend" pairid="1016" style="1" owner="i" level="1" amendtag="start">(2)</amend></display><amend anum="0" ea="amend" pairid="129" groupid="101" style="1" owner="ahaskell" level="1" amendtag="end">The reasonable proof of injury described in Subsection <xref depth="4" refnumber="31A-22-323(1)(a)(vii)">(1)(a)(vii)</xref> does not require <ln numlevel="1" lineno="51" slineno="1-30"/>proof, valuation, or quantification of non-economic damages, including pain and <ln numlevel="1" lineno="52" slineno="1-31"/>suffering.</amend></subsection><subsection ssid="3-24" dnum="_-o:3-i" numlevel="1" lineno="53" slineno="1-32" ea="amend" anum="0" owner="ahaskell" style="1" level="1"><display><amend anum="0" ea="amend" pairid="1017" style="1" owner="i" level="1" amendtag="start">(3)</amend></display><amend anum="0" ea="amend" pairid="142" groupid="108" style="1" owner="ahaskell" level="1" amendtag="end">If the insurer or insured reasonably determines that a demand letter fails to include <ln numlevel="1" lineno="54" slineno="1-33"/>required material information, the insurer or insured may provide written notice <ln numlevel="1" lineno="55" slineno="1-34"/>identifying the deficiency, and the response period is tolled until the deficiency is cured.</amend></subsection><subsection ssid="3-28" dnum="_-o:4-i" numlevel="1" lineno="56" slineno="1-35" ea="amend" anum="0" owner="ahaskell" style="1" level="1" space="false"><display><amend anum="0" ea="amend" pairid="1018" style="1" owner="i" level="1" amendtag="start">(4)</amend></display><subsection ssid="3-29" dnum="_-o:a-i" ea="amend" anum="0" owner="ahaskell" style="1" level="2" placement="sameline"><display><amend anum="0" ea="amend" pairid="1019" style="1" owner="i" level="1">(a)</amend></display><amend anum="0" ea="amend" pairid="151" groupid="115" style="1" owner="ahaskell" level="1" amendtag="end">Within a reasonable time after receipt of a time-limited demand letter that <ln numlevel="1" lineno="57" slineno="1-36"/>complies with this section, the liability insurer shall provide the insured with a <ln numlevel="1" lineno="58" slineno="1-37"/>written disclosure stating:</amend><subsection ssid="3-30" dnum="_-o:i-i" numlevel="1" lineno="59" slineno="1-38" ea="amend" anum="0" owner="ahaskell" style="1" level="3" tab="1"><display><amend anum="0" ea="amend" pairid="1020" style="1" owner="i" level="1" amendtag="start">(i)</amend></display><amend anum="0" ea="amend" pairid="156" groupid="119" style="1" owner="ahaskell" level="1" amendtag="end">whether the insurer agrees to defend the insured against the claim; and</amend></subsection><subsection ssid="3-31" dnum="_-o:ii-i" numlevel="1" lineno="60" slineno="1-39" ea="amend" anum="0" owner="ahaskell" style="1" level="3" tab="1"><display><amend anum="0" ea="amend" pairid="1021" style="1" owner="i" level="1" amendtag="start">(ii)</amend></display><amend anum="0" ea="amend" pairid="161" groupid="123" style="1" owner="ahaskell" level="1" amendtag="end">whether the insurer agrees to indemnify the insured for any judgment or <ln numlevel="1" lineno="61" slineno="1-40"/>settlement arising from the claim, including whether such indemnification is <ln numlevel="1" lineno="62" slineno="1-41"/>limited to the applicable policy limits.</amend></subsection></subsection><subsection ssid="3-32" dnum="_-o:b-i" numlevel="1" lineno="63" slineno="1-42" ea="amend" anum="0" owner="ahaskell" style="1" level="2"><display><amend anum="0" ea="amend" pairid="1022" style="1" owner="i" level="1" amendtag="start">(b)</amend></display><amend anum="0" ea="amend" pairid="166" groupid="127" style="1" owner="ahaskell" level="1" amendtag="end">A disclosure made under this Subsection <xref depth="4" refnumber="31A-22-323(4)">(4)</xref>:</amend><subsection ssid="3-33" dnum="_-o:i-i" numlevel="1" lineno="64" slineno="1-43" ea="amend" anum="0" owner="ahaskell" style="1" level="3"><display><amend anum="0" ea="amend" pairid="1023" style="1" owner="i" level="1" amendtag="start">(i)</amend></display><amend anum="0" ea="amend" pairid="171" groupid="131" style="1" owner="ahaskell" level="1" amendtag="end">does not expand, reduce, or modify coverage under the insurance policy; and</amend></subsection><subsection ssid="3-34" dnum="_-o:ii-i" numlevel="1" lineno="65" slineno="1-44" ea="amend" anum="0" owner="ahaskell" style="1" level="3"><display><amend anum="0" ea="amend" pairid="1024" style="1" owner="i" level="1" amendtag="start">(ii)</amend></display><amend anum="0" ea="amend" pairid="176" groupid="135" style="1" owner="ahaskell" level="1" amendtag="end">is intended solely to provide clarity to the insured regarding the insurer's position.</amend></subsection></subsection></subsection><subsection ssid="3-17" dnum="_-o:5-i" numlevel="1" lineno="66" slineno="1-45" ea="amend" anum="0" owner="ahaskell" style="1" level="1" space="false"><display><amend anum="0" ea="amend" pairid="1025" style="1" owner="i" level="1" amendtag="start">(5)</amend></display><subsection ssid="3-35" dnum="_-o:a-i" ea="amend" anum="0" owner="ahaskell" style="1" level="2" placement="sameline"><display><amend anum="0" ea="amend" pairid="1026" style="1" owner="i" level="1">(a)</amend></display><amend anum="0" ea="amend" pairid="187" groupid="144" style="1" owner="ahaskell" level="1" amendtag="end">A time-limited demand to settle a claim under this section may not include <ln numlevel="1" lineno="67" slineno="1-46"/>demands for economic damages in amounts that exceed the economic damages <ln numlevel="1" lineno="68" slineno="1-47"/>reasonably supported by the documentation provided with the demand.</amend></subsection><subsection ssid="3-37" dnum="_-o:b-i" numlevel="1" lineno="69" slineno="1-48" ea="amend" anum="0" owner="ahaskell" style="1" level="2"><display><amend anum="0" ea="amend" pairid="1027" style="1" owner="i" level="1" amendtag="start">(b)</amend></display><amend anum="0" ea="amend" pairid="192" groupid="148" style="1" owner="ahaskell" level="1" amendtag="end">Nothing in this subsection requires documentation or valuation of non-economic <ln numlevel="1" lineno="70" slineno="1-49"/>damages.</amend></subsection></subsection><subsection ssid="3-38" dnum="_-o:6-i" numlevel="1" lineno="71" slineno="1-50" ea="amend" anum="0" owner="ahaskell" style="1" level="1"><display><amend anum="0" ea="amend" pairid="1028" style="1" owner="i" level="1" amendtag="start">(6)</amend></display><amend anum="0" ea="amend" pairid="196" groupid="151" style="1" owner="ahaskell" level="1" amendtag="end">Nothing in this section may be construed to alter, limit, or waive:</amend><subsection ssid="3-39" dnum="_-o:a-i" numlevel="1" lineno="72" slineno="1-51" ea="amend" anum="0" owner="ahaskell" style="1" level="2"><display><amend anum="0" ea="amend" pairid="1029" style="1" owner="i" level="1" amendtag="start">(a)</amend></display><amend anum="0" ea="amend" pairid="201" groupid="155" style="1" owner="ahaskell" level="1" amendtag="end">an insurer's duty to act in good faith and deal fairly with the insurer's insured; or</amend></subsection><subsection ssid="3-40" dnum="_-o:b-i" numlevel="1" lineno="73" slineno="1-52" ea="amend" anum="0" owner="ahaskell" style="1" level="2"><display><amend anum="0" ea="amend" pairid="1030" style="1" owner="i" level="1" amendtag="start">(b)</amend></display><amend anum="0" ea="amend" pairid="206" groupid="159" style="1" owner="ahaskell" level="1" amendtag="end">any rights or remedies available to an insured arising from an insurer's failure to <ln numlevel="1" lineno="74" slineno="1-53"/>accept a reasonable settlement offer within applicable policy limits.</amend></subsection></subsection></section></bsec><bsec buid="5" type="uncod" untype="effdate" src="uncod" uid="EF0000" sort="UZEFF" langlock="true" numlevel="1" lineno="75" slineno="2-1" sn="2"><section type="uncod" untype="effdate" display="false" src="uncod"><secline lineno="75">Section 2.  <bold>Effective Date.</bold></secline><sectionText lineno="76"><amend anum="0" ea="amend" pairid="1" groupid="1" style="1" owner="ahaskell" level="1" amendtag="both">This bill takes effect on <effdate uid="code" date="5/6/2026">May 6, 2026</effdate>.</amend></sectionText></section></bsec></bdy><foot><rev><tm>2-11-26 9:59 AM</tm></rev></foot></leg>