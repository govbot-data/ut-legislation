<leg xml:space="preserve" billnum="SB0108" sponsor="Lincoln Fillmore" designation="SB" otherSponsor="Doug Fiefia" otherHouse="House" sess="2026GS" fileno="2026FL0335" date="1/8/2026 15:01:613" printDate="01-08 15:19" subVer="0" minVer="0" office="LEGISLATIVE GENERAL COUNSEL" actionDate="" impact="code"><info><nextbuid>15</nextbuid><aminfo anum="0" effdate="05/06/2026"><seclist><sect action="E" src="code" buid="5" uid="C11-72-S101_2026050620260506" sort="11 72 01010020260506" mtype="section" effdate="05/06/2026">11-72-101</sect><sect src="uncod" untype="effdate" buid="14" uid="EF0000" sort="UZEFF" mtype="uncod" effdate="05/06/2026"/></seclist></aminfo></info><tbox><sinfo><nextpairid>0</nextpairid></sinfo><st numlevel="1" lineno="1" slineno="0-1">Online Marketplace Amendments</st><sessionhead>2026 GENERAL SESSION</sessionhead><statehead>STATE OF UTAH</statehead><sponsorhead>Chief Sponsor: Lincoln Fillmore</sponsorhead><otherSponsorhead>House Sponsor: Doug Fiefia</otherSponsorhead></tbox><lt numlevel="1" lineno="2" slineno="0-2"><lthead lineno="3">LONG TITLE</lthead><gdhead lineno="4">General Description:</gdhead><gd numlevel="1" lineno="5" slineno="0-5">This bill prohibits a municipality or county from regulating an online marketplace.</gd><hphead lineno="6">Highlighted Provisions:</hphead><hp numlevel="1" lineno="7" slineno="0-7">This bill:<hl numlevel="1" lineno="8" slineno="0-8" level="1">defines terms; and</hl><hl numlevel="1" lineno="9" slineno="0-9" level="1">prohibits a municipality or county from regulating an online marketplace.</hl></hp><moni numlevel="1" lineno="10" slineno="0-10" display="none">Money Appropriated in this Bill:</moni><moniNone lineno="11">None</moniNone><oc numlevel="1" lineno="12" slineno="0-12">Other Special Clauses:</oc><ocNone lineno="13">None</ocNone><sa numlevel="1" lineno="14" slineno="0-14">Utah Code Sections Affected:<saent numlevel="1" lineno="15" slineno="0-15"><snhead>ENACTS:</snhead><sn num="11-72-101" src="code" uid="C11-72-S101_2026050620260506" buid="5" sort="11 72 01010020260506" numlevel="1" lineno="16" slineno="0-16"><bold>11-72-101</bold>, Utah Code Annotated 1953</sn></saent></sa></lt><enacthead lineno="17"/><enact numlevel="1" lineno="18" slineno="0-18">Be it enacted by the Legislature of the state of Utah:</enact><bdy><bsec buid="5" num="11-72-101" type="enact" src="code" uid="C11-72-S101_2026050620260506" sort="11 72 01010020260506" numlevel="1" lineno="19" slineno="1-1" sn="1"><section numlevel="1" lineno="20" slineno="1-2" number="11-72-101" type="enact"><secline lineno="19">Section 1. Section <bold>11-72-101</bold> is enacted to read:</secline><catline lineno="20"><bold>11-72-101<parens/>. Online marketplaces.</bold></catline><subsection ssid="5-1" dnum="_-o:1-i" numlevel="1" lineno="21" slineno="1-3" ea="amend" anum="0" owner="jchristopherson" style="1" level="1" placement="noreturn"><display><amend anum="0" ea="amend" pairid="1000" style="1" owner="i" level="1" amendtag="start">(1)</amend></display><amend anum="0" ea="amend" pairid="3" groupid="3" style="1" owner="jchristopherson" level="1" amendtag="end">As used in this section, "online marketplace" means a person that:</amend><subsection ssid="5-10" dnum="_-o:a-i" numlevel="1" lineno="22" slineno="1-4" ea="amend" anum="0" owner="jchristopherson" style="1" level="2"><display><amend anum="0" ea="amend" pairid="1001" style="1" owner="i" level="1" amendtag="start">(a)</amend></display><amend anum="0" ea="amend" pairid="48" groupid="36" style="1" owner="jchristopherson" level="1" amendtag="end">provides, for consideration, regardless of whether the consideration is deducted as a <ln numlevel="1" lineno="23" slineno="1-5"/>fee from a transaction, an online application, platform, program, software, system, <ln numlevel="1" lineno="24" slineno="1-6"/>website, or other medium through which a good or service is advertised in this state <ln numlevel="1" lineno="25" slineno="1-7"/>or is offered to the public as available in this state; and</amend></subsection><subsection ssid="5-11" dnum="_-o:b-i" numlevel="1" lineno="26" slineno="1-8" ea="amend" anum="0" owner="jchristopherson" style="1" level="2"><display><amend anum="0" ea="amend" pairid="1002" style="1" owner="i" level="1" amendtag="start">(b)</amend></display><amend anum="0" ea="amend" pairid="47" groupid="35" style="1" owner="jchristopherson" level="1" amendtag="end">provides, directly or indirectly, a system that:</amend><subsection ssid="5-12" dnum="_-o:i-i" numlevel="1" lineno="27" slineno="1-9" ea="amend" anum="0" owner="jchristopherson" style="1" level="3"><display><amend anum="0" ea="amend" pairid="1003" style="1" owner="i" level="1" amendtag="start">(i)</amend></display><amend anum="0" ea="amend" pairid="54" groupid="40" style="1" owner="jchristopherson" level="1" amendtag="end">facilitates a transaction between two persons;</amend></subsection><subsection ssid="5-13" dnum="_-o:ii-i" numlevel="1" lineno="28" slineno="1-10" ea="amend" anum="0" owner="jchristopherson" style="1" level="3"><display><amend anum="0" ea="amend" pairid="1004" style="1" owner="i" level="1" amendtag="start">(ii)</amend></display><amend anum="0" ea="amend" pairid="59" groupid="44" style="1" owner="jchristopherson" level="1" amendtag="end">transmits or otherwise communicates the offer or acceptance of a transaction <ln numlevel="1" lineno="29" slineno="1-11"/>between two persons; or</amend></subsection><subsection ssid="5-14" dnum="_-o:iii-i" numlevel="1" lineno="30" slineno="1-12" ea="amend" anum="0" owner="jchristopherson" style="1" level="3"><display><amend anum="0" ea="amend" pairid="1005" style="1" owner="i" level="1" amendtag="start">(iii)</amend></display><amend anum="0" ea="amend" pairid="64" groupid="48" style="1" owner="jchristopherson" level="1" amendtag="end">allows two or more persons to communicate or connect with each other.</amend></subsection></subsection></subsection><subsection ssid="5-17" dnum="_-o:2-i" numlevel="1" lineno="31" slineno="1-13" ea="amend" anum="0" owner="jchristopherson" style="1" level="1"><display><amend anum="0" ea="amend" pairid="1006" style="1" owner="i" level="1" amendtag="start">(2)</amend></display><amend anum="0" ea="amend" pairid="76" groupid="56" style="1" owner="jchristopherson" level="1" amendtag="end">A municipality or county may not regulate the operation of an online marketplace.</amend></subsection></section></bsec><bsec buid="14" type="uncod" untype="effdate" src="uncod" uid="EF0000" sort="UZEFF" langlock="true" numlevel="1" lineno="32" slineno="2-1" sn="2"><section type="uncod" untype="effdate" display="false" src="uncod"><secline lineno="32">Section 2.  <bold>Effective Date.</bold></secline><sectionText lineno="33"><amend anum="0" ea="amend" pairid="1" groupid="1" style="1" owner="jchristopherson" level="1" amendtag="both">This bill takes effect on <effdate uid="code" date="5/6/2026">May 6, 2026</effdate>.</amend></sectionText></section></bsec></bdy><foot><rev><tm>1-8-26 3:19 PM</tm></rev></foot></leg>