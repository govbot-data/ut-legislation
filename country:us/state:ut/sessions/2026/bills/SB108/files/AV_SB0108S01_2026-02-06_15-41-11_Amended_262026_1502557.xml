<leg xml:space="preserve" billnum="SB0108" sponsor="Lincoln Fillmore" designation="SB" otherSponsor="Doug Fiefia" otherHouse="House" subNumber="01" subSponsor="Lincoln Fillmore" sess="2026GS" fileno="2026FL0335" date="2/6/2026 15:02:433" printDate="02-06 15:41" subVer="1" minVer="3" office="LEGISLATIVE GENERAL COUNSEL" actionDate="" impact="code"><info><nextbuid>15</nextbuid><aminfo anum="0" effdate="05/06/2026"><seclist><sect action="E" src="code" buid="5" uid="C11-72-S101_2026050620260506" sort="11 72 01010020260506" mtype="section" effdate="05/06/2026">11-72-101</sect><sect src="uncod" untype="effdate" buid="14" uid="EF0000" sort="UZEFF" mtype="uncod" effdate="05/06/2026"/></seclist></aminfo><amendinfo level="1"/><aminfo anum="-1" effdate="05/06/2026"><seclist><sect action="E" src="code" buid="5" uid="C11-72-S101_2026050620260506" sort="11 72 01010020260506" mtype="section" effdate="05/06/2026">11-72-101</sect><sect src="uncod" untype="effdate" buid="14" uid="EF0000" sort="UZEFF" mtype="uncod" effdate="05/06/2026"/></seclist></aminfo></info><tbox><sinfo><nextpairid>0</nextpairid></sinfo><st numlevel="1" lineno="1" slineno="0-1">Online Marketplace Amendments</st><sessionhead>2026 GENERAL SESSION</sessionhead><statehead>STATE OF UTAH</statehead><sponsorhead>Chief Sponsor: Lincoln Fillmore</sponsorhead><otherSponsorhead>House Sponsor: Doug Fiefia</otherSponsorhead></tbox><lt numlevel="1" lineno="2" slineno="0-2"><lthead lineno="3">LONG TITLE</lthead><gdhead lineno="4">General Description:</gdhead><gd numlevel="1" lineno="5" slineno="0-5">This bill addresses municipal or county regulation of an online marketplace.</gd><hphead lineno="6">Highlighted Provisions:</hphead><hp numlevel="1" lineno="7" slineno="0-7">This bill:<hl numlevel="1" lineno="8" slineno="0-8" level="1">defines terms;</hl><hl numlevel="1" lineno="9" slineno="0-9" level="1">except under certain circumstances, prohibits a municipality or county from regulating an <ln numlevel="1" lineno="10" slineno="0-10"/>online marketplace; and</hl><hl numlevel="1" lineno="11" slineno="0-11" level="1">addresses municipal or county requests to an online marketplace for information or <ln numlevel="1" lineno="12" slineno="0-12"/>assistance.</hl></hp><moni numlevel="1" lineno="13" slineno="0-13" display="none">Money Appropriated in this Bill:</moni><moniNone lineno="14">None</moniNone><oc numlevel="1" lineno="15" slineno="0-15">Other Special Clauses:</oc><ocNone lineno="16">None</ocNone><sa numlevel="1" lineno="17" slineno="0-17">Utah Code Sections Affected:<saent numlevel="1" lineno="18" slineno="0-18"><snhead>ENACTS:</snhead><sn num="11-72-101" src="code" uid="C11-72-S101_2026050620260506" buid="5" sort="11 72 01010020260506" numlevel="1" lineno="19" slineno="0-19"><bold>11-72-101</bold>, Utah Code Annotated 1953</sn></saent></sa></lt><enacthead lineno="20"/><enact numlevel="1" lineno="21" slineno="0-21">Be it enacted by the Legislature of the state of Utah:</enact><bdy><bsec buid="5" num="11-72-101" type="enact" src="code" uid="C11-72-S101_2026050620260506" sort="11 72 01010020260506" numlevel="1" lineno="22" slineno="1-1" sn="1"><section numlevel="1" lineno="23" slineno="1-2" number="11-72-101" type="enact"><secline lineno="22">Section 1. Section <bold>11-72-101</bold> is enacted to read:</secline><catline lineno="23"><bold>11-72-101<parens/>. Online marketplaces.</bold></catline><subsection ssid="5-1" dnum="_-o:1-i" numlevel="1" lineno="24" slineno="1-3" ea="amend" anum="0" owner="ahaskell" style="1" level="1" placement="noreturn"><display><amend anum="0" ea="amend" pairid="1000" style="1" owner="i" level="1" amendtag="start">(1)</amend></display><amend anum="0" ea="amend" pairid="3" groupid="3" style="1" owner="ahaskell" level="1" amendtag="end">As used in this section:</amend><subsection ssid="5-24" dnum="_-o:a-i" numlevel="1" lineno="25" slineno="1-4" ea="amend" anum="0" owner="ahaskell" style="1" level="2"><display><amend anum="0" ea="amend" pairid="1001" style="1" owner="i" level="1" amendtag="start">(a)</amend></display><amend anum="0" ea="amend" pairid="81" groupid="60" style="1" owner="ahaskell" level="1" amendtag="end">"Online marketplace" means a website or digital platform that:</amend><subsection ssid="5-10" dnum="_-o:i-i" numlevel="1" lineno="26" slineno="1-5" ea="amend" anum="0" owner="ahaskell" style="1" level="3"><display><amend anum="0" ea="amend" pairid="1002" style="1" owner="i" level="1" amendtag="start">(i)</amend></display><amend anum="0" ea="amend" pairid="48" groupid="36" style="1" owner="ahaskell" level="1" amendtag="end">provides, for consideration, regardless of whether the consideration is deducted as <ln numlevel="1" lineno="27" slineno="1-6"/>a fee from a transaction, an online application, platform, program, software, <ln numlevel="1" lineno="28" slineno="1-7"/>system, website, or other medium through which a good or service is advertised in <ln numlevel="1" lineno="29" slineno="1-8"/>this state or is offered to the public as available in this state; and</amend></subsection><subsection ssid="5-11" dnum="_-o:ii-i" numlevel="1" lineno="30" slineno="1-9" ea="amend" anum="0" owner="ahaskell" style="1" level="3"><display><amend anum="0" ea="amend" pairid="1003" style="1" owner="i" level="1" amendtag="start">(ii)</amend></display><amend anum="0" ea="amend" pairid="47" groupid="35" style="1" owner="ahaskell" level="1" amendtag="end">provides, directly or indirectly, a system that:</amend><subsection ssid="5-12" dnum="_-o:A-i" numlevel="1" lineno="31" slineno="1-10" ea="amend" anum="0" owner="ahaskell" style="1" level="4"><display><amend anum="0" ea="amend" pairid="1004" style="1" owner="i" level="1" amendtag="start">(A)</amend></display><amend anum="0" ea="amend" pairid="54" groupid="40" style="1" owner="ahaskell" level="1" amendtag="end">facilitates a transaction between two persons;</amend></subsection><subsection ssid="5-13" dnum="_-o:B-i" numlevel="1" lineno="32" slineno="1-11" ea="amend" anum="0" owner="ahaskell" style="1" level="4"><display><amend anum="0" ea="amend" pairid="1005" style="1" owner="i" level="1" amendtag="start">(B)</amend></display><amend anum="0" ea="amend" pairid="59" groupid="44" style="1" owner="ahaskell" level="1" amendtag="end">transmits or otherwise communicates the offer or acceptance of a transaction <ln numlevel="1" lineno="33" slineno="1-12"/>between two persons; or</amend></subsection><subsection ssid="5-14" dnum="_-o:C-i" numlevel="1" lineno="34" slineno="1-13" ea="amend" anum="0" owner="ahaskell" style="1" level="4"><display><amend anum="0" ea="amend" pairid="1006" style="1" owner="i" level="1" amendtag="start">(C)</amend></display><amend anum="0" ea="amend" pairid="64" groupid="48" style="1" owner="ahaskell" level="1" amendtag="end">allows two or more persons to communicate or connect with each other.</amend></subsection></subsection></subsection><subsection ssid="5-38" dnum="_-o:b-i" numlevel="1" lineno="35" slineno="1-14" ea="amend" anum="0" owner="ahaskell" style="1" level="2"><display><amend anum="0" ea="amend" pairid="1007" style="1" owner="i" level="1" amendtag="start">(b)</amend></display><amend anum="0" ea="amend" pairid="126" groupid="91" style="1" owner="ahaskell" level="1" amendtag="end">"Personal data" means information that is linked or can be reasonably linked to an <ln numlevel="1" lineno="36" slineno="1-15"/>identified person or an identifiable person.</amend></subsection></subsection><subsection ssid="5-17" dnum="_-o:2-i" numlevel="1" lineno="37" slineno="1-16" ea="amend" anum="0" owner="ahaskell" style="1" level="1"><display><amend anum="0" ea="amend" pairid="1008" style="1" owner="i" level="1" amendtag="start">(2)</amend></display><amend anum="0" ea="amend" pairid="76" groupid="56" style="1" owner="ahaskell" level="1" amendtag="end">Except as provided in Subsection (3), a municipality or county may not:</amend><subsection ssid="5-40" dnum="_-o:a-i" numlevel="1" lineno="38" slineno="1-17" ea="amend" anum="0" owner="ahaskell" style="1" level="2"><display><amend anum="0" ea="amend" pairid="1009" style="1" owner="i" level="1" amendtag="start">(a)</amend></display><amend anum="0" ea="amend" pairid="136" groupid="99" style="1" owner="ahaskell" level="1" amendtag="end">regulate the operation of an online marketplace; or</amend></subsection><subsection ssid="5-41" dnum="_-o:b-i" numlevel="1" lineno="39" slineno="1-18" ea="amend" anum="0" owner="ahaskell" style="1" level="2"><display><amend anum="0" ea="amend" pairid="1010" style="1" owner="i" level="1" amendtag="start">(b)</amend></display><amend anum="0" ea="amend" pairid="141" groupid="103" style="1" owner="ahaskell" level="1" endid="182" base="true">require an online marketplace to provide the personal data of the online <ln numlevel="1" lineno="40" slineno="1-19"/>marketplace's </amend><senateStart display="true"/><senateFloorStart/><amend anum="-1" ea="amend" pairid="178" groupid="133" style="A" owner="SF" level="1" sftag="both">website or digital platform </amend><senateFloorEnd/><senateEnd display="true"/><amend anum="0" ea="amend" pairid="182" groupid="137" style="1" owner="ahaskell" level="1" base="true" amendtag="end">users without an administrative <ln numlevel="2" lineno="40a" slineno="1-19a"/>subpoena or court order.</amend></subsection></subsection><subsection ssid="5-33" dnum="_-o:3-i" numlevel="1" lineno="41" slineno="1-20" ea="amend" anum="0" owner="ahaskell" style="1" level="1"><display><amend anum="0" ea="amend" pairid="1011" style="1" owner="i" level="1" amendtag="start">(3)</amend></display><amend anum="0" ea="amend" pairid="108" groupid="79" style="1" owner="ahaskell" level="1" amendtag="end">Subsection (2) does not limit or prohibit a municipality or county from:</amend><subsection ssid="5-34" dnum="_-o:a-i" numlevel="1" lineno="42" slineno="1-21" ea="amend" anum="0" owner="ahaskell" style="1" level="2"><display><amend anum="0" ea="amend" pairid="1012" style="1" owner="i" level="1" amendtag="start">(a)</amend></display><amend anum="0" ea="amend" pairid="111" groupid="81" style="1" owner="ahaskell" level="1" amendtag="end">regulating a person who participates in a transaction facilitated by an online <ln numlevel="1" lineno="43" slineno="1-22"/>marketplace;</amend></subsection><subsection ssid="5-35" dnum="_-o:b-i" numlevel="1" lineno="44" slineno="1-23" ea="amend" anum="0" owner="ahaskell" style="1" level="2"><display><amend anum="0" ea="amend" pairid="1013" style="1" owner="i" level="1" amendtag="start">(b)</amend></display><amend anum="0" ea="amend" pairid="114" groupid="83" style="1" owner="ahaskell" level="1" amendtag="end">adopting or enforcing a short-term rental ordinance:</amend><subsection ssid="5-36" dnum="_-o:i-i" numlevel="1" lineno="45" slineno="1-24" ea="amend" anum="0" owner="ahaskell" style="1" level="3"><display><amend anum="0" ea="amend" pairid="1014" style="1" owner="i" level="1" amendtag="start">(i)</amend></display><amend anum="0" ea="amend" pairid="117" groupid="85" style="1" owner="ahaskell" level="1" amendtag="end">for a municipality, in accordance with Section 10-8-85.4; or</amend></subsection><subsection ssid="5-37" dnum="_-o:ii-i" numlevel="1" lineno="46" slineno="1-25" ea="amend" anum="0" owner="ahaskell" style="1" level="3"><display><amend anum="0" ea="amend" pairid="1015" style="1" owner="i" level="1" amendtag="start">(ii)</amend></display><amend anum="0" ea="amend" pairid="120" groupid="87" style="1" owner="ahaskell" level="1" endid="183" base="true" amendtag="end">for a county, in accordance with Section 17-50-338;</amend><senateStart display="true"/><senateFloorStart/><amendoutstart style="7"/><amend anum="-1" ea="erase" pairid="179" groupid="134" style="7" owner="SF" level="1" sftag="both" deltag="both"> or</amend><amendoutend style="7"/><senateFloorEnd/><senateEnd display="true"/></subsection></subsection><subsection ssid="5-42" dnum="_-o:c-i" numlevel="1" lineno="47" slineno="1-26" ea="amend" anum="0" owner="ahaskell" style="1" level="2"><display><amend anum="0" ea="amend" pairid="1016" style="1" owner="i" level="1" amendtag="start">(c)</amend></display><amend anum="0" ea="amend" pairid="145" groupid="106" style="1" owner="ahaskell" level="1" endid="185" base="true" amendtag="end">seeking cooperation from or submitting voluntary requests to an online marketplace</amend><senateStart display="true"/><senateFloorStart/><amendoutstart style="7"/><amend anum="-1" ea="erase" pairid="180" groupid="135" style="7" owner="SF" level="1" sftag="start" deltag="both">.</amend><amendoutend style="7"/><amend anum="-1" ea="amend" pairid="181" groupid="136" style="A" owner="SF" level="1" amendtag="both" space="true">;</amend></subsection><subsection ssid="5-46" dnum="_-o:d-SF" numlevel="2" lineno="47a" slineno="1-26a" ea="amend" anum="-1" owner="SF" style="-1" level="2" chamber="SF"><display><amend anum="-1" ea="amend" pairid="1017" style="-1" owner="SF" level="1" amendtag="start">(d)</amend></display><amend anum="-1" ea="amend" pairid="177" groupid="132" style="-1" owner="SF" level="1" amendtag="end">enforcing Title 76, Utah Criminal Code; or</amend></subsection><subsection ssid="5-47" dnum="_-o:e-SF" numlevel="2" lineno="47b" slineno="1-26b" ea="amend" anum="-1" owner="SF" style="-1" level="2" chamber="SF"><display><amend anum="-1" ea="amend" pairid="1018" style="-1" owner="SF" level="1" amendtag="start">(e)</amend></display><amend anum="-1" ea="amend" pairid="176" groupid="131" style="-1" owner="SF" level="1" sftag="end" amendtag="end">bringing a civil action to protect the municipality's or county's intellectual <ln numlevel="2" lineno="47c" slineno="1-26c"/>property.</amend><senateFloorEnd/><senateEnd display="true"/></subsection></subsection></section></bsec><bsec buid="14" type="uncod" untype="effdate" src="uncod" uid="EF0000" sort="UZEFF" langlock="true" numlevel="1" lineno="48" slineno="2-1" sn="2"><section type="uncod" untype="effdate" display="false" src="uncod"><secline lineno="48">Section 2.  <bold>Effective Date.</bold></secline><sectionText lineno="49"><amend anum="0" ea="amend" pairid="1" groupid="1" style="1" owner="ahaskell" level="1" amendtag="both">This bill takes effect on <effdate uid="code" date="5/6/2026">May 6, 2026</effdate>.</amend></sectionText></section></bsec></bdy><foot><rev><tm>2-6-26 3:41 PM</tm></rev></foot></leg>