<leg xml:space="preserve" billnum="HB0564" sponsor="Andrew Stoddard" designation="HB" otherSponsor="" otherHouse="Senate" sess="2026GS" fileno="2026FL1285" date="2/13/2026 10:02:27" printDate="02-13 10:05" subVer="0" minVer="0" office="LEGISLATIVE GENERAL COUNSEL" actionDate="" impact="code"><info><nextbuid>8</nextbuid><aminfo anum="0" effdate="05/06/2026"><seclist><sect action="E" src="code" buid="5" uid="C19-2-S109.8_2026050620260506" sort="19 02 01090820260506" mtype="section" effdate="05/06/2026">19-2-109.8</sect><sect src="uncod" untype="effdate" buid="7" uid="EF0000" sort="UZEFF" mtype="uncod" effdate="05/06/2026"/></seclist></aminfo></info><tbox><sinfo><nextpairid>0</nextpairid></sinfo><st numlevel="1" lineno="1" slineno="0-1">Pollution Standards Amendments</st><sessionhead>2026 GENERAL SESSION</sessionhead><statehead>STATE OF UTAH</statehead><sponsorhead>Chief Sponsor: Andrew Stoddard</sponsorhead><otherSponsorhead>Senate Sponsor: </otherSponsorhead></tbox><lt numlevel="1" lineno="2" slineno="0-2"><lthead lineno="3">LONG TITLE</lthead><gdhead lineno="4">General Description:</gdhead><gd numlevel="1" lineno="5" slineno="0-5">This bill addresses pollution standards for particulate matter and nitrogen oxides.</gd><hphead lineno="6">Highlighted Provisions:</hphead><hp numlevel="1" lineno="7" slineno="0-7">This bill:<hl numlevel="1" lineno="8" slineno="0-8" level="1">defines terms; and</hl><hl numlevel="1" lineno="9" slineno="0-9" level="1">establishes a total annual emissions limit for PM2.5 and nitrogen oxides from point <ln numlevel="1" lineno="10" slineno="0-10"/>sources in certain counties.</hl></hp><moni numlevel="1" lineno="11" slineno="0-11" display="none">Money Appropriated in this Bill:</moni><moniNone lineno="12">None</moniNone><oc numlevel="1" lineno="13" slineno="0-13">Other Special Clauses:</oc><ocNone lineno="14">None</ocNone><sa numlevel="1" lineno="15" slineno="0-15">Utah Code Sections Affected:<saent numlevel="1" lineno="16" slineno="0-16"><snhead>ENACTS:</snhead><sn num="19-2-109.8" src="code" uid="C19-2-S109.8_2026050620260506" buid="5" sort="19 02 01090820260506" numlevel="1" lineno="17" slineno="0-17"><bold>19-2-109.8</bold>, Utah Code Annotated 1953</sn></saent></sa></lt><enacthead lineno="18"/><enact numlevel="1" lineno="19" slineno="0-19">Be it enacted by the Legislature of the state of Utah:</enact><bdy><bsec buid="5" num="19-2-109.8" type="enact" src="code" uid="C19-2-S109.8_2026050620260506" sort="19 02 01090820260506" numlevel="1" lineno="20" slineno="1-1" sn="1"><section numlevel="1" lineno="21" slineno="1-2" number="19-2-109.8" type="enact"><secline lineno="20">Section 1. Section <bold>19-2-109.8</bold> is enacted to read:</secline><catline lineno="21"><bold>19-2-109.8<parens/>. Total annual emissions limit -- Particulate matter -- Nitrogen oxides.</bold></catline><subsection ssid="5-1" dnum="_-o:1-i" numlevel="1" lineno="22" slineno="1-3" ea="amend" anum="0" owner="jchristopherson" style="1" level="1" placement="noreturn"><display><amend anum="0" ea="amend" pairid="1000" style="1" owner="i" level="1" amendtag="start">(1)</amend></display><amend anum="0" ea="amend" pairid="13" groupid="10" style="1" owner="jchristopherson" level="1" amendtag="end">As used in this section:</amend><subsection ssid="5-10" dnum="_-o:a-i" numlevel="1" lineno="23" slineno="1-4" ea="amend" anum="0" owner="jchristopherson" style="1" level="2" space="false"><display><amend anum="0" ea="amend" pairid="1001" style="1" owner="i" level="1" amendtag="start">(a)</amend></display><subsection ssid="5-18" dnum="_-o:i-i" ea="amend" anum="0" owner="jchristopherson" style="1" level="3" placement="sameline"><display><amend anum="0" ea="amend" pairid="1002" style="1" owner="i" level="1">(i)</amend></display><amend anum="0" ea="amend" pairid="39" groupid="30" style="1" owner="jchristopherson" level="1" amendtag="end">"Major nonattainment county" means a county:</amend><subsection ssid="5-11" dnum="_-o:A-i" numlevel="1" lineno="24" slineno="1-5" ea="amend" anum="0" owner="jchristopherson" style="1" level="4" tab="1"><display><amend anum="0" ea="amend" pairid="1003" style="1" owner="i" level="1" amendtag="start">(A)</amend></display><amend anum="0" ea="amend" pairid="47" groupid="35" style="1" owner="jchristopherson" level="1" amendtag="end">of the first or second class, as described in Section <xref depth="3" refnumber="17-60-104">17-60-104</xref>; and</amend></subsection><subsection ssid="5-12" dnum="_-o:B-i" numlevel="1" lineno="25" slineno="1-6" ea="amend" anum="0" owner="jchristopherson" style="1" level="4" tab="1"><display><amend anum="0" ea="amend" pairid="1004" style="1" owner="i" level="1" amendtag="start">(B)</amend></display><amend anum="0" ea="amend" pairid="52" groupid="39" style="1" owner="jchristopherson" level="1" amendtag="end">in a nonattainment area, as that term is defined in 42 U.S.C. Sec. 7501, for <ln numlevel="1" lineno="26" slineno="1-7"/>ozone, PM2.5, or nitrogen oxides.</amend></subsection></subsection><subsection ssid="5-13" dnum="_-o:ii-i" numlevel="1" lineno="27" slineno="1-8" ea="amend" anum="0" owner="jchristopherson" style="1" level="3"><display><amend anum="0" ea="amend" pairid="1005" style="1" owner="i" level="1" amendtag="start">(ii)</amend></display><amend anum="0" ea="amend" pairid="57" groupid="43" style="1" owner="jchristopherson" level="1" amendtag="end">"Major nonattainment county" includes:</amend><subsection ssid="5-14" dnum="_-o:A-i" numlevel="1" lineno="28" slineno="1-9" ea="amend" anum="0" owner="jchristopherson" style="1" level="4"><display><amend anum="0" ea="amend" pairid="1006" style="1" owner="i" level="1" amendtag="start">(A)</amend></display><amend anum="0" ea="amend" pairid="62" groupid="47" style="1" owner="jchristopherson" level="1" amendtag="end">Davis County;</amend></subsection><subsection ssid="5-15" dnum="_-o:B-i" numlevel="1" lineno="29" slineno="1-10" ea="amend" anum="0" owner="jchristopherson" style="1" level="4"><display><amend anum="0" ea="amend" pairid="1007" style="1" owner="i" level="1" amendtag="start">(B)</amend></display><amend anum="0" ea="amend" pairid="67" groupid="51" style="1" owner="jchristopherson" level="1" amendtag="end">Salt Lake County;</amend></subsection><subsection ssid="5-16" dnum="_-o:C-i" numlevel="1" lineno="30" slineno="1-11" ea="amend" anum="0" owner="jchristopherson" style="1" level="4"><display><amend anum="0" ea="amend" pairid="1008" style="1" owner="i" level="1" amendtag="start">(C)</amend></display><amend anum="0" ea="amend" pairid="72" groupid="55" style="1" owner="jchristopherson" level="1" amendtag="end">Utah County; and</amend></subsection><subsection ssid="5-17" dnum="_-o:D-i" numlevel="1" lineno="31" slineno="1-12" ea="amend" anum="0" owner="jchristopherson" style="1" level="4"><display><amend anum="0" ea="amend" pairid="1009" style="1" owner="i" level="1" amendtag="start">(D)</amend></display><amend anum="0" ea="amend" pairid="77" groupid="59" style="1" owner="jchristopherson" level="1" amendtag="end">Weber County.</amend></subsection></subsection></subsection><subsection ssid="5-8" dnum="_-o:b-i" numlevel="1" lineno="32" slineno="1-13" ea="amend" anum="0" owner="jchristopherson" style="1" level="2"><display><amend anum="0" ea="amend" pairid="1010" style="1" owner="i" level="1" amendtag="start">(b)</amend></display><amend anum="0" ea="amend" pairid="38" groupid="29" style="1" owner="jchristopherson" level="1" amendtag="end">"PM2.5" means airborne particulate matter approximately 2.5 micrometers or <ln numlevel="1" lineno="33" slineno="1-14"/>smaller in diameter.</amend></subsection></subsection><subsection ssid="5-3" dnum="_-o:2-i" numlevel="1" lineno="34" slineno="1-15" ea="amend" anum="0" owner="jchristopherson" style="1" level="1"><display><amend anum="0" ea="amend" pairid="1011" style="1" owner="i" level="1" amendtag="start">(2)</amend></display><amend anum="0" ea="amend" pairid="14" groupid="11" style="1" owner="jchristopherson" level="1" amendtag="end">The total annual emissions from point sources in major nonattainment counties may not <ln numlevel="1" lineno="35" slineno="1-16"/>exceed:</amend><subsection ssid="5-6" dnum="_-o:a-i" numlevel="1" lineno="36" slineno="1-17" ea="amend" anum="0" owner="jchristopherson" style="1" level="2"><display><amend anum="0" ea="amend" pairid="1012" style="1" owner="i" level="1" amendtag="start">(a)</amend></display><amend anum="0" ea="amend" pairid="28" groupid="21" style="1" owner="jchristopherson" level="1" amendtag="end">1418 tons of PM2.5 per year; and</amend></subsection><subsection ssid="5-19" dnum="_-o:b-i" numlevel="1" lineno="37" slineno="1-18" ea="amend" anum="0" owner="jchristopherson" style="1" level="2"><display><amend anum="0" ea="amend" pairid="1013" style="1" owner="i" level="1" amendtag="start">(b)</amend></display><amend anum="0" ea="amend" pairid="84" groupid="63" style="1" owner="jchristopherson" level="1" amendtag="end">8870 tons of nitrogen oxides per year.</amend></subsection></subsection></section></bsec><bsec buid="7" type="uncod" untype="effdate" src="uncod" uid="EF0000" sort="UZEFF" langlock="true" numlevel="1" lineno="38" slineno="2-1" sn="2"><section type="uncod" untype="effdate" display="false" src="uncod"><secline lineno="38">Section 2.  <bold>Effective Date.</bold></secline><sectionText lineno="39"><amend anum="0" ea="amend" pairid="1" groupid="1" style="1" owner="jchristopherson" level="1" amendtag="both">This bill takes effect on <effdate uid="code" date="5/6/2026">May 6, 2026</effdate>.</amend></sectionText></section></bsec></bdy><foot><rev><tm>2-13-26 10:05 AM</tm></rev></foot></leg>