<leg xml:space="preserve" billnum="HB0538" sponsor="Ryan D. Wilcox" designation="HB" otherSponsor="Daniel McCay" otherHouse="Senate" sess="2026GS" fileno="2026FL0384" date="2/10/2026 14:02:357" printDate="02-23 14:27" subVer="0" minVer="0" office="LEGISLATIVE GENERAL COUNSEL" actionDate="" impact="code"><info><nextbuid>4</nextbuid><aminfo anum="0" effdate="01/01/2028"><seclist><sect action="X" src="code" buid="1" uid="C36-3-S201_2028010120280101" fromuid="C36-3-S201_2020051220200512" sort="36 03 02010020280101" mtype="section" effdate="01/01/2028">36-3-201</sect><sect src="uncod" untype="effdate" buid="3" uid="EF0000" sort="UZEFF" mtype="uncod" effdate="05/06/2026"/></seclist></aminfo></info><tbox><sinfo><nextpairid>0</nextpairid></sinfo><st numlevel="1" lineno="1" slineno="0-1">Legislative Session Amendments</st><sessionhead>2026 GENERAL SESSION</sessionhead><statehead>STATE OF UTAH</statehead><sponsorhead>Chief Sponsor: Ryan D. Wilcox</sponsorhead><otherSponsorhead>Senate Sponsor: Daniel McCay</otherSponsorhead></tbox><lt numlevel="1" lineno="2" slineno="0-2"><lthead lineno="3">LONG TITLE</lthead><gdhead lineno="4">General Description:</gdhead><gd numlevel="1" lineno="5" slineno="0-5">This bill, contingent on passage of a proposed constitutional amendment, provides the <ln numlevel="1" lineno="6" slineno="0-6"/>beginning date for the Legislature's annual sessions.</gd><hphead lineno="7">Highlighted Provisions:</hphead><hp numlevel="1" lineno="8" slineno="0-8">This bill:<hl numlevel="1" lineno="9" slineno="0-9" level="1">contingent on passage of a proposed constitutional amendment, establishes the beginning <ln numlevel="1" lineno="10" slineno="0-10"/>date of the Legislature's annual budget session and each of the Legislature's general <ln numlevel="1" lineno="11" slineno="0-11"/>sessions.</hl></hp><moni numlevel="1" lineno="12" slineno="0-12" display="none">Money Appropriated in this Bill:</moni><moniNone lineno="13">None</moniNone><oc numlevel="1" lineno="14" slineno="0-14">Other Special Clauses:<ocl type="effdate" sort="2" numlevel="1" lineno="15" slineno="0-15">This bill provides a special effective date.</ocl></oc><sa numlevel="1" lineno="16" slineno="0-16">Utah Code Sections Affected:<sarnr numlevel="1" lineno="17" slineno="0-17"><snhead>REPEALS AND REENACTS:</snhead><sn num="36-3-201" src="code" uid="C36-3-S201_2028010120280101" buid="1" sort="36 03 02010020280101" numlevel="1" lineno="18" slineno="0-18"><bold>36-3-201</bold>, as enacted by Laws of Utah 2020, Chapter 383</sn></sarnr></sa></lt><enacthead lineno="19"/><enact numlevel="1" lineno="20" slineno="0-20">Be it enacted by the Legislature of the state of Utah:</enact><bdy><bsec buid="1" num="36-3-201" type="repreenact" src="code" uid="C36-3-S201_2028010120280101" sort="36 03 02010020280101" numlevel="1" lineno="21" slineno="1-1" sn="1"><section numlevel="1" lineno="22" slineno="1-2" number="36-3-201" type="repreenact"><secline lineno="21">Section 1. Section <bold>36-3-201</bold> is repealed and reenacted to read:</secline><catline lineno="22"><bold>36-3-201<parens/>. Beginning date of annual budget and general sessions.</bold></catline><subsection ssid="1-2" dnum="_-o:1-i" numlevel="1" lineno="23" slineno="1-3" ea="amend" anum="0" owner="jchristopherson" style="1" level="1" placement="noreturn"><display><amend anum="0" ea="amend" pairid="1000" style="1" owner="i" level="1" amendtag="start">(1)</amend></display><amend anum="0" ea="amend" pairid="8" groupid="6" style="1" owner="jchristopherson" level="1" amendtag="end">The annual budget session of the Legislature shall begin the fourth Monday in February.</amend></subsection><subsection ssid="1-4" dnum="_-o:2-i" numlevel="1" lineno="24" slineno="1-4" ea="amend" anum="0" owner="jchristopherson" style="1" level="1"><display><amend anum="0" ea="amend" pairid="1001" style="1" owner="i" level="1" amendtag="start">(2)</amend></display><amend anum="0" ea="amend" pairid="16" groupid="12" style="1" owner="jchristopherson" level="1" amendtag="end">The first annual general session of the Legislature shall begin the first Monday in May.</amend></subsection><subsection ssid="1-5" dnum="_-o:3-i" numlevel="1" lineno="25" slineno="1-5" ea="amend" anum="0" owner="jchristopherson" style="1" level="1"><display><amend anum="0" ea="amend" pairid="1002" style="1" owner="i" level="1" amendtag="start">(3)</amend></display><amend anum="0" ea="amend" pairid="19" groupid="14" style="1" owner="jchristopherson" level="1" amendtag="end">The second annual general session of the Legislature shall begin the second Monday in <ln numlevel="1" lineno="26" slineno="1-6"/>September.</amend></subsection></section></bsec><bsec buid="3" type="uncod" untype="effdate" src="uncod" uid="EF0000" sort="UZEFF" langlock="false" numlevel="1" lineno="27" slineno="2-1" sn="2"><section type="uncod" untype="effdate" display="false" src="uncod"><secline lineno="27">Section 2.  <bold>Effective Date.</bold></secline><sectionText lineno="28"><amend anum="0" ea="amend" pairid="1" groupid="1" style="1" owner="jchristopherson" level="1" amendtag="both">This bill takes effect January 1, 2028, if the amendment to the Utah Constitution <ln numlevel="1" lineno="29" slineno="2-3"/>proposed by H.J.R. 22, Proposal to Amend Utah Constitution - Legislative Session, 2026 <ln numlevel="1" lineno="30" slineno="2-4"/>General Session, passes the Legislature and is approved by a majority of those voting on it at <ln numlevel="1" lineno="31" slineno="2-5"/>the next regular general election.</amend></sectionText></section></bsec></bdy><foot><rev><tm>2-10-26 2:16 PM</tm></rev></foot></leg>