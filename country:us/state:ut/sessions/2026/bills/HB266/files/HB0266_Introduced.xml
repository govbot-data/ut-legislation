<leg xml:space="preserve" billnum="HB0266" sponsor="Doug Welton" designation="HB" otherSponsor="Michael K. McKell" otherHouse="Senate" sess="2026GS" fileno="2026FL1294" date="01-15-26" printDate="01-19 15:13" subVer="0" minVer="0" office="LEGISLATIVE GENERAL COUNSEL" actionDate="" impact="code"><info><nextbuid>3</nextbuid><aminfo anum="0" effdate="05/06/2026"><seclist><sect action="E" src="code" buid="1" uid="C72-4-S225_2026050620260506" sort="72 04 02250020260506" mtype="section" effdate="05/06/2026">72-4-225</sect><sect src="uncod" untype="effdate" buid="2" uid="EF0000" sort="UZEFF" mtype="uncod" effdate="05/06/2026"/></seclist></aminfo></info><tbox><sinfo/><st numlevel="1" lineno="1" slineno="0-1">Highway Designation Changes</st><sessionhead>2026 GENERAL SESSION</sessionhead><statehead>STATE OF UTAH</statehead><sponsorhead>Chief Sponsor: Doug Welton</sponsorhead><otherSponsorhead>Senate Sponsor: Michael K. McKell</otherSponsorhead></tbox><lt numlevel="1" lineno="2" slineno="0-2"><lthead lineno="3">LONG TITLE</lthead><gdhead lineno="4">General Description:</gdhead><gd numlevel="1" lineno="5" slineno="0-5">This bill enacts provisions related to the naming of Route 198 in Utah County.</gd><hphead lineno="6">Highlighted Provisions:</hphead><hp numlevel="1" lineno="7" slineno="0-7">This bill:<hl numlevel="1" lineno="8" slineno="0-8" level="1">establishes the name of Route 198 from Main Street in Payson to Main Street in <ln numlevel="1" lineno="9" slineno="0-9"/>Santaquin as the Sgt. Billy D. Hooser Memorial Highway.</hl></hp><moni numlevel="1" lineno="10" slineno="0-10" display="none">Money Appropriated in this Bill:</moni><moniNone lineno="11">None</moniNone><oc numlevel="1" lineno="12" slineno="0-12">Other Special Clauses:</oc><ocNone lineno="13">None</ocNone><sa numlevel="1" lineno="14" slineno="0-14">Utah Code Sections Affected:<saent numlevel="1" lineno="15" slineno="0-15"><snhead>ENACTS:</snhead><sn num="72-4-225" src="code" uid="C72-4-S225_2026050620260506" buid="1" sort="72 04 02250020260506" numlevel="1" lineno="16" slineno="0-16"><bold>72-4-225</bold>, Utah Code Annotated 1953</sn></saent></sa></lt><enacthead lineno="17"/><enact numlevel="1" lineno="18" slineno="0-18">Be it enacted by the Legislature of the state of Utah:</enact><bdy><bsec buid="1" num="72-4-225" type="enact" src="code" uid="C72-4-S225_2026050620260506" sort="72 04 02250020260506" numlevel="1" lineno="19" slineno="1-1" sn="1"><section numlevel="1" lineno="20" slineno="1-2" number="72-4-225" type="enact"><secline lineno="19">Section 1, Section <bold>72-4-225</bold> is enacted to read:</secline><catline lineno="20"><bold>72-4-225. Sgt. Billy D. Hooser Memorial Highway.</bold></catline><subsection ssid="1-1" dnum="_-o:1-i" numlevel="1" lineno="21" slineno="1-3" ea="amend" anum="0" owner="jchristopherson" style="1" level="1" placement="noreturn"><display><amend anum="0" ea="amend" pairid="1000" style="1" owner="i" level="1" amendtag="start">(1)</amend></display><amend anum="0" ea="amend" pairid="7" groupid="5" style="1" owner="jchristopherson" level="1" amendtag="end">There is established the Sgt. Billy D. Hooser Memorial Highway composed of the <ln numlevel="1" lineno="22" slineno="1-4"/>portion of existing Route 198 in Utah County from Main Street in Payson to Main Street <ln numlevel="1" lineno="23" slineno="1-5"/>in Santaquin.</amend></subsection><subsection ssid="1-2" dnum="_-o:2-i" numlevel="1" lineno="24" slineno="1-6" ea="amend" anum="0" owner="jchristopherson" style="1" level="1"><display><amend anum="0" ea="amend" pairid="1001" style="1" owner="i" level="1" amendtag="start">(2)</amend></display><amend anum="0" ea="amend" pairid="12" groupid="9" style="1" owner="jchristopherson" level="1" amendtag="end">In addition to other official designations, the Department of Transportation shall <ln numlevel="1" lineno="25" slineno="1-7"/>designate the portion of the highway identified in Subsection <xref depth="4" refnumber="72-4-225(1)">(1)</xref> as the Sgt. Billy D. <ln numlevel="1" lineno="26" slineno="1-8"/>Hooser Memorial Highway on future state highway maps.</amend></subsection><subsection ssid="1-3" dnum="_-o:3-i" numlevel="1" lineno="27" slineno="1-9" ea="amend" anum="0" owner="jchristopherson" style="1" level="1"><display><amend anum="0" ea="amend" pairid="1002" style="1" owner="i" level="1" amendtag="start">(3)</amend></display><amend anum="0" ea="amend" pairid="16" groupid="12" style="1" owner="jchristopherson" level="1" amendtag="end">As soon as practicable, the Department of Transportation shall install appropriate signs <ln numlevel="1" lineno="28" slineno="1-10"/>along portions of the highway indicating the designation as the Sgt. Billy D. Hooser <ln numlevel="1" lineno="29" slineno="1-11"/>Memorial Highway as described in Subsection <xref depth="4" refnumber="72-4-225(1)">(1)</xref>.</amend></subsection></section></bsec><bsec buid="2" type="uncod" untype="effdate" src="uncod" uid="EF0000" sort="UZEFF" langlock="true" numlevel="1" lineno="30" slineno="2-1" sn="2"><section type="uncod" untype="effdate" display="false" src="uncod"><secline lineno="30">Section 2.  <bold>Effective Date.</bold></secline><sectionText lineno="31"><amend anum="0" ea="amend" pairid="1" groupid="1" style="1" owner="jchristopherson" level="1" amendtag="both">This bill takes effect on <effdate uid="code" date="5/6/2026">May 6, 2026</effdate>.</amend></sectionText></section></bsec></bdy><foot><rev><tm>1-15-26 11:44 AM</tm></rev></foot></leg>