<leg xml:space="preserve" billnum="HB0558" sponsor="Ryan D. Wilcox" designation="HB" otherSponsor="" otherHouse="Senate" sess="2026GS" fileno="2026FL0091" date="2/13/2026 09:02:530" printDate="02-13 09:19" subVer="0" minVer="0" office="LEGISLATIVE GENERAL COUNSEL" actionDate="" impact="code"><info><nextbuid>19</nextbuid><aminfo anum="0" effdate="05/06/2026"><seclist><sect action="A" src="code" buid="14" uid="C20A-9-S203.5_2026050620260506" fromuid="C20A-9-S203.5_2016051020160510" sort="20A09 02030520260506" mtype="section" effdate="05/06/2026">20A-9-203.5</sect><sect src="uncod" untype="effdate" buid="18" uid="EF0000" sort="UZEFF" mtype="uncod" effdate="05/06/2026"/></seclist></aminfo></info><tbox><sinfo><nextpairid>0</nextpairid></sinfo><st numlevel="1" lineno="1" slineno="0-1">Elections Amendments</st><sessionhead>2026 GENERAL SESSION</sessionhead><statehead>STATE OF UTAH</statehead><sponsorhead>Chief Sponsor: Ryan D. Wilcox</sponsorhead><otherSponsorhead>Senate Sponsor: </otherSponsorhead></tbox><lt numlevel="1" lineno="2" slineno="0-2"><lthead lineno="3">LONG TITLE</lthead><gdhead lineno="4">General Description:</gdhead><gd numlevel="1" lineno="5" slineno="0-5">This bill requires the posting of certain information relating to a candidate for public office.</gd><hphead lineno="6">Highlighted Provisions:</hphead><hp numlevel="1" lineno="7" slineno="0-7">This bill:<hl numlevel="1" lineno="8" slineno="0-8" level="1">requires an election officer to post the following information relating to a candidate for <ln numlevel="1" lineno="9" slineno="0-9"/>public office:<hl numlevel="1" lineno="10" slineno="0-10" level="2">the name and campaign contact information of the candidate;</hl><hl numlevel="1" lineno="11" slineno="0-11" level="2">the office that the candidate is seeking; and</hl><hl numlevel="1" lineno="12" slineno="0-12" level="2">the political party affiliation of the candidate, regardless of whether the candidate is a <ln numlevel="1" lineno="13" slineno="0-13"/>candidate for partisan or nonpartisan office or seeking retention election. </hl></hl></hp><moni numlevel="1" lineno="14" slineno="0-14" display="none">Money Appropriated in this Bill:</moni><moniNone lineno="15">None</moniNone><oc numlevel="1" lineno="16" slineno="0-16">Other Special Clauses:</oc><ocNone lineno="17">None</ocNone><sa numlevel="1" lineno="18" slineno="0-18">Utah Code Sections Affected:<saamd numlevel="1" lineno="19" slineno="0-19"><snhead>AMENDS:</snhead><sn num="20A-9-203.5" src="code" uid="C20A-9-S203.5_2026050620260506" buid="14" sort="20A09 02030520260506" numlevel="1" lineno="20" slineno="0-20"><bold>20A-9-203.5</bold>, as enacted by Laws of Utah 2016, Chapter 48</sn></saamd></sa></lt><enacthead lineno="21"/><enact numlevel="1" lineno="22" slineno="0-22">Be it enacted by the Legislature of the state of Utah:</enact><bdy><bsec buid="14" num="20A-9-203.5" type="amend" src="code" uid="C20A-9-S203.5_2026050620260506" sort="20A09 02030520260506" numlevel="1" lineno="23" slineno="1-1" sn="1"><section number="20A-9-203.5" numlevel="1" lineno="24" slineno="1-2" type="amend"><secline lineno="23">Section 1. Section <bold>20A-9-203.5</bold> is amended to read:</secline><catline lineno="24"><bold>20A-9-203.5<parens/>. Requirement to post candidate information on website.</bold></catline><sectionText lineno="25"><tab/><amendoutstart style="2"/><amend anum="0" ea="erase" pairid="11" groupid="9" style="2" owner="jchristopherson" level="1" deltag="both">The clerk of a county or a municipality</amend><amendoutend style="2"/></sectionText><subsection ssid="14-3" dnum="_-o:1-i" numlevel="1" lineno="26" slineno="1-4" ea="amend" anum="0" owner="jchristopherson" style="1" level="1"><display><amend anum="0" ea="amend" pairid="1000" style="1" owner="i" level="1" amendtag="start">(1)</amend></display><amend anum="0" ea="amend" pairid="8" groupid="6" style="1" owner="jchristopherson" level="1" amendtag="end">Except as provided in Subsection <xref depth="4" refnumber="20A-9-203.5(2)">(2)</xref>, an election officer</amend> shall, within three business <ln numlevel="1" lineno="27" slineno="1-5"/>days after the day on which the <amendoutstart style="2"/><amend anum="0" ea="erase" pairid="12" groupid="10" style="2" owner="jchristopherson" level="1" deltag="both">clerk</amend><amendoutend style="2"/><amend anum="0" ea="amend" pairid="9" groupid="7" style="1" owner="jchristopherson" level="1" amendtag="both" space="true">election officer</amend> accepts a declaration of <ln numlevel="1" lineno="28" slineno="1-6"/>candidacy, post the following information on the <amend anum="0" ea="amend" pairid="10" groupid="8" style="1" owner="jchristopherson" level="1" amendtag="both">election officer's </amend>website<amendoutstart style="2"/><amend anum="0" ea="erase" pairid="39" groupid="33" style="2" owner="jchristopherson" level="1" deltag="both"> of the county <ln numlevel="1" lineno="29" slineno="1-7"/>or municipality</amend><amendoutend style="2"/>:<subsection ssid="14-null-1" dnum="1-o:a-i" numlevel="1" lineno="30" slineno="1-8" level="2"><display><amendoutstart style="2"/><amend anum="0" ea="erase" pairid="1001" style="2" owner="o" level="1" deltag="both">(1)</amend><amendoutend style="2"/><amend anum="0" ea="amend" pairid="1002" style="1" owner="i" level="1" amendtag="both" space="true">(a)</amend></display>the name and campaign contact information of the candidate;<amendoutstart style="2"/><amend anum="0" ea="erase" pairid="14" groupid="12" style="2" owner="jchristopherson" level="1" deltag="both"> and</amend><amendoutend style="2"/></subsection><subsection ssid="14-null-2" dnum="2-o:b-i" numlevel="1" lineno="31" slineno="1-9" level="2"><display><amendoutstart style="2"/><amend anum="0" ea="erase" pairid="1002" style="2" owner="o" level="1" deltag="both">(2)</amend><amendoutend style="2"/><amend anum="0" ea="amend" pairid="1003" style="1" owner="i" level="1" amendtag="both" space="true">(b)</amend></display>the office that the candidate is seeking<amendoutstart style="2"/><amend anum="0" ea="erase" pairid="24" groupid="21" style="2" owner="jchristopherson" level="1" deltag="both">.</amend><amendoutend style="2"/><amend anum="0" ea="amend" pairid="22" groupid="19" style="1" owner="jchristopherson" level="1" amendtag="both" space="true">; and</amend></subsection><subsection ssid="14-4" dnum="_-o:c-i" numlevel="1" lineno="32" slineno="1-10" ea="amend" anum="0" owner="jchristopherson" style="1" level="2"><display><amend anum="0" ea="amend" pairid="1003" style="1" owner="i" level="1" amendtag="start">(c)</amend></display><amend anum="0" ea="amend" pairid="21" groupid="18" style="1" owner="jchristopherson" level="1" amendtag="end">regardless of whether the office sought by the candidate is a partisan or nonpartisan <ln numlevel="1" lineno="33" slineno="1-11"/>office, and regardless of whether the election is a retention election:</amend><subsection ssid="14-5" dnum="_-o:i-i" numlevel="1" lineno="34" slineno="1-12" ea="amend" anum="0" owner="jchristopherson" style="1" level="3"><display><amend anum="0" ea="amend" pairid="1004" style="1" owner="i" level="1" amendtag="start">(i)</amend></display><amend anum="0" ea="amend" pairid="29" groupid="25" style="1" owner="jchristopherson" level="1" amendtag="end">the political party with which the candidate is affiliated; or</amend></subsection><subsection ssid="14-6" dnum="_-o:ii-i" numlevel="1" lineno="35" slineno="1-13" ea="amend" anum="0" owner="jchristopherson" style="1" level="3"><display><amend anum="0" ea="amend" pairid="1005" style="1" owner="i" level="1" amendtag="start">(ii)</amend></display><amend anum="0" ea="amend" pairid="34" groupid="29" style="1" owner="jchristopherson" level="1" amendtag="end">if the candidate is not affiliated with a political party, that the candidate is not <ln numlevel="1" lineno="36" slineno="1-14"/>affiliated with a political party.</amend></subsection></subsection></subsection><subsection ssid="14-7" dnum="_-o:2-i" numlevel="1" lineno="37" slineno="1-15" ea="amend" anum="0" owner="jchristopherson" style="1" level="1"><display><amend anum="0" ea="amend" pairid="1006" style="1" owner="i" level="1" amendtag="start">(2)</amend></display><amend anum="0" ea="amend" pairid="38" groupid="32" style="1" owner="jchristopherson" level="1" amendtag="end">For an election officer who does not have a website, the election officer shall, within <ln numlevel="1" lineno="38" slineno="1-16"/>three business days after the day on which the election officer accepts a declaration of <ln numlevel="1" lineno="39" slineno="1-17"/>candidacy, publish the information described in Subsection <xref depth="4" refnumber="20A-9-203.5(1)">(1)</xref> on the Utah Public <ln numlevel="1" lineno="40" slineno="1-18"/>Notice Website.</amend></subsection></section></bsec><bsec buid="18" type="uncod" untype="effdate" src="uncod" uid="EF0000" sort="UZEFF" langlock="true" numlevel="1" lineno="41" slineno="2-1" sn="2"><section type="uncod" untype="effdate" display="false" src="uncod"><secline lineno="41">Section 2.  <bold>Effective Date.</bold></secline><sectionText lineno="42"><amend anum="0" ea="amend" pairid="1" groupid="1" style="1" owner="jchristopherson" level="1" amendtag="both">This bill takes effect on <effdate uid="code" date="5/6/2026">May 6, 2026</effdate>.</amend></sectionText></section></bsec></bdy><foot><rev><tm>2-13-26 9:19 AM</tm></rev></foot></leg>