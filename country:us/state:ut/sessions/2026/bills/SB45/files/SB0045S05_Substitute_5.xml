<leg xml:space="preserve" billnum="SB0045" sponsor="Michael K. McKell" designation="SB" otherSponsor="Katy Hall" otherHouse="House" subNumber="05" subSponsor="Matt MacPherson" sess="2026GS" fileno="2026FL1099" date="3/4/2026 09:03:683" printDate="03-04 09:04" subVer="5" minVer="0" office="LEGISLATIVE GENERAL COUNSEL" actionDate="" impact="code"><info><nextbuid>3</nextbuid><aminfo anum="0" effdate="05/06/2026"><seclist><sect action="E" src="code" buid="1" uid="C26B-7-S126_2026050620260506" sort="26B07 01260020260506" mtype="section" effdate="05/06/2026">26B-7-126</sect><sect src="uncod" untype="effdate" buid="2" uid="EF0000" sort="UZEFF" mtype="uncod" effdate="05/06/2026"/></seclist></aminfo></info><tbox><sinfo><nextpairid>0</nextpairid></sinfo><st numlevel="1" lineno="1" slineno="0-1">Word of Wisdom Amendments</st><sessionhead>2026 GENERAL SESSION</sessionhead><statehead>STATE OF UTAH</statehead><sponsorhead>Chief Sponsor: Michael K. McKell</sponsorhead><otherSponsorhead>House Sponsor: Katy Hall</otherSponsorhead></tbox><lt numlevel="1" lineno="2" slineno="0-2"><lthead lineno="3">LONG TITLE</lthead><gdhead lineno="4">General Description:</gdhead><gd numlevel="1" lineno="5" slineno="0-5">This bill enacts a word of wisdom.</gd><hphead lineno="6">Highlighted Provisions:</hphead><hp numlevel="1" lineno="7" slineno="0-7">This bill:<hl numlevel="1" lineno="8" slineno="0-8" level="1">enacts a word of wisdom.</hl></hp><moni numlevel="1" lineno="9" slineno="0-9" display="none">Money Appropriated in this Bill:</moni><moniNone lineno="10">None</moniNone><oc numlevel="1" lineno="11" slineno="0-11">Other Special Clauses:</oc><ocNone lineno="12">None</ocNone><sa numlevel="1" lineno="13" slineno="0-13">Utah Code Sections Affected:<saent numlevel="1" lineno="14" slineno="0-14"><snhead>ENACTS:</snhead><sn num="26B-7-126" src="code" uid="C26B-7-S126_2026050620260506" buid="1" sort="26B07 01260020260506" numlevel="1" lineno="15" slineno="0-15"><bold>26B-7-126</bold>, Utah Code Annotated 1953</sn></saent></sa></lt><enacthead lineno="16"/><enact numlevel="1" lineno="17" slineno="0-17">Be it enacted by the Legislature of the state of Utah:</enact><bdy><bsec buid="1" num="26B-7-126" type="enact" src="code" uid="C26B-7-S126_2026050620260506" sort="26B07 01260020260506" numlevel="1" lineno="18" slineno="1-1" sn="1"><section numlevel="1" lineno="19" slineno="1-2" number="26B-7-126" type="enact"><secline lineno="18">Section 1. Section <bold>26B-7-126</bold> is enacted to read:</secline><catline lineno="19"><bold>26B-7-126<parens/>. Word of Wisdom.</bold></catline><subsection ssid="1-1" dnum="_-o:1-i" numlevel="1" lineno="20" slineno="1-3" ea="amend" anum="0" owner="jchristopherson" style="1" level="1" placement="noreturn"><display><amend anum="0" ea="amend" pairid="1000" style="1" owner="i" level="1" amendtag="start">(1)</amend></display><amend anum="0" ea="amend" pairid="3" groupid="3" style="1" owner="jchristopherson" level="1" amendtag="end">A Word of Wisdom, for the benefit of state residents.</amend></subsection><subsection ssid="1-2" dnum="_-o:2-i" numlevel="1" lineno="21" slineno="1-4" ea="amend" anum="0" owner="jchristopherson" style="1" level="1"><display><amend anum="0" ea="amend" pairid="1001" style="1" owner="i" level="1" amendtag="start">(2)</amend></display><amend anum="0" ea="amend" pairid="6" groupid="5" style="1" owner="jchristopherson" level="1" amendtag="end">Not by commandment or constraint, but by the word of wisdom.</amend></subsection><subsection ssid="1-3" dnum="_-o:3-i" numlevel="1" lineno="22" slineno="1-5" ea="amend" anum="0" owner="jchristopherson" style="1" level="1"><display><amend anum="0" ea="amend" pairid="1002" style="1" owner="i" level="1" amendtag="start">(3)</amend></display><amend anum="0" ea="amend" pairid="9" groupid="7" style="1" owner="jchristopherson" level="1" amendtag="end">Given for a principle with promise, adapted to the capacity of the weak and the weakest <ln numlevel="1" lineno="23" slineno="1-6"/>of all state residents, who are or can be called state residents.</amend></subsection><subsection ssid="1-22" dnum="_-o:4-i" numlevel="1" lineno="24" slineno="1-7" ea="amend" anum="0" owner="jchristopherson" style="1" level="1"><display><amend anum="0" ea="amend" pairid="1003" style="1" owner="i" level="1" amendtag="start">(4)</amend></display><amend anum="0" ea="amend" pairid="69" groupid="47" style="1" owner="jchristopherson" level="1" amendtag="end">In consequence of evils and designs which do and will exist in the hearts of conspiring <ln numlevel="1" lineno="25" slineno="1-8"/>individuals in the last days.</amend></subsection><subsection ssid="1-23" dnum="_-o:5-i" numlevel="1" lineno="26" slineno="1-9" ea="amend" anum="0" owner="jchristopherson" style="1" level="1"><display><amend anum="0" ea="amend" pairid="1004" style="1" owner="i" level="1" amendtag="start">(5)</amend></display><amend anum="0" ea="amend" pairid="74" groupid="51" style="1" owner="jchristopherson" level="1" amendtag="end">That inasmuch as any individual drinketh wine or strong drink among you, behold it is <ln numlevel="1" lineno="27" slineno="1-10"/>not good, only in assembling yourselves together to offer up your sacraments.</amend></subsection><subsection ssid="1-6" dnum="_-o:6-i" numlevel="1" lineno="28" slineno="1-11" ea="amend" anum="0" owner="jchristopherson" style="1" level="1"><display><amend anum="0" ea="amend" pairid="1005" style="1" owner="i" level="1" amendtag="start">(6)</amend></display><amend anum="0" ea="amend" pairid="18" groupid="13" style="1" owner="jchristopherson" level="1" amendtag="end">And, behold, this should be wine, yea, pure wine of the grape of the vine, of your own <ln numlevel="1" lineno="29" slineno="1-12"/>make.</amend></subsection><subsection ssid="1-7" dnum="_-o:7-i" numlevel="1" lineno="30" slineno="1-13" ea="amend" anum="0" owner="jchristopherson" style="1" level="1"><display><amend anum="0" ea="amend" pairid="1006" style="1" owner="i" level="1" amendtag="start">(7)</amend></display><amend anum="0" ea="amend" pairid="21" groupid="15" style="1" owner="jchristopherson" level="1" amendtag="end">And, again, strong drinks are not for the belly, but for the washing of your bodies.</amend></subsection><subsection ssid="1-8" dnum="_-o:8-i" numlevel="1" lineno="31" slineno="1-14" ea="amend" anum="0" owner="jchristopherson" style="1" level="1"><display><amend anum="0" ea="amend" pairid="1007" style="1" owner="i" level="1" amendtag="start">(8)</amend></display><amend anum="0" ea="amend" pairid="24" groupid="17" style="1" owner="jchristopherson" level="1" amendtag="end">And again, tobacco is not for the body, neither for the belly, and is not good for <ln numlevel="1" lineno="32" slineno="1-15"/>individuals, but is a herb for bruises and all sick cattle, to be used with judgment and <ln numlevel="1" lineno="33" slineno="1-16"/>skill.</amend></subsection><subsection ssid="1-9" dnum="_-o:9-i" numlevel="1" lineno="34" slineno="1-17" ea="amend" anum="0" owner="jchristopherson" style="1" level="1"><display><amend anum="0" ea="amend" pairid="1008" style="1" owner="i" level="1" amendtag="start">(9)</amend></display><amend anum="0" ea="amend" pairid="27" groupid="19" style="1" owner="jchristopherson" level="1" amendtag="end">And again, hot drinks are not for the body or belly.</amend></subsection><subsection ssid="1-10" dnum="_-o:10-i" numlevel="1" lineno="35" slineno="1-18" ea="amend" anum="0" owner="jchristopherson" style="1" level="1"><display><amend anum="0" ea="amend" pairid="1009" style="1" owner="i" level="1" amendtag="start">(10)</amend></display><amend anum="0" ea="amend" pairid="30" groupid="21" style="1" owner="jchristopherson" level="1" amendtag="end">And again, verily I say unto you, all wholesome herbs ordained for the constitution, <ln numlevel="1" lineno="36" slineno="1-19"/>nature, and use of individuals.</amend></subsection><subsection ssid="1-11" dnum="_-o:11-i" numlevel="1" lineno="37" slineno="1-20" ea="amend" anum="0" owner="jchristopherson" style="1" level="1"><display><amend anum="0" ea="amend" pairid="1010" style="1" owner="i" level="1" amendtag="start">(11)</amend></display><amend anum="0" ea="amend" pairid="33" groupid="23" style="1" owner="jchristopherson" level="1" amendtag="end">Every herb in the season thereof, and every fruit in the season thereof; all these to be <ln numlevel="1" lineno="38" slineno="1-21"/>used with prudence and thanksgiving.</amend></subsection><subsection ssid="1-12" dnum="_-o:12-i" numlevel="1" lineno="39" slineno="1-22" ea="amend" anum="0" owner="jchristopherson" style="1" level="1"><display><amend anum="0" ea="amend" pairid="1011" style="1" owner="i" level="1" amendtag="start">(12)</amend></display><amend anum="0" ea="amend" pairid="36" groupid="25" style="1" owner="jchristopherson" level="1" amendtag="end">Yea, flesh also of beasts and of the fowls of the air, nevertheless they are to be used <ln numlevel="1" lineno="40" slineno="1-23"/>sparingly;</amend></subsection><subsection ssid="1-13" dnum="_-o:13-i" numlevel="1" lineno="41" slineno="1-24" ea="amend" anum="0" owner="jchristopherson" style="1" level="1"><display><amend anum="0" ea="amend" pairid="1012" style="1" owner="i" level="1" amendtag="start">(13)</amend></display><amend anum="0" ea="amend" pairid="39" groupid="27" style="1" owner="jchristopherson" level="1" amendtag="end">And only in times of winter, or of cold, or famine.</amend></subsection><subsection ssid="1-14" dnum="_-o:14-i" numlevel="1" lineno="42" slineno="1-25" ea="amend" anum="0" owner="jchristopherson" style="1" level="1"><display><amend anum="0" ea="amend" pairid="1013" style="1" owner="i" level="1" amendtag="start">(14)</amend></display><amend anum="0" ea="amend" pairid="42" groupid="29" style="1" owner="jchristopherson" level="1" amendtag="end">All grain is to be the staff of life, not only for individuals but for the beasts of the field, <ln numlevel="1" lineno="43" slineno="1-26"/>and the fowls of heaven, and all wild animals that run or creep on the earth;</amend></subsection><subsection ssid="1-15" dnum="_-o:15-i" numlevel="1" lineno="44" slineno="1-27" ea="amend" anum="0" owner="jchristopherson" style="1" level="1"><display><amend anum="0" ea="amend" pairid="1014" style="1" owner="i" level="1" amendtag="start">(15)</amend></display><amend anum="0" ea="amend" pairid="45" groupid="31" style="1" owner="jchristopherson" level="1" amendtag="end">And these to be used only in times of famine and excess of hunger.</amend></subsection><subsection ssid="1-16" dnum="_-o:16-i" numlevel="1" lineno="45" slineno="1-28" ea="amend" anum="0" owner="jchristopherson" style="1" level="1"><display><amend anum="0" ea="amend" pairid="1015" style="1" owner="i" level="1" amendtag="start">(16)</amend></display><amend anum="0" ea="amend" pairid="48" groupid="33" style="1" owner="jchristopherson" level="1" amendtag="end">All grain is good for the food of individuals; as also the fruit of the vine; that which <ln numlevel="1" lineno="46" slineno="1-29"/>yieldeth fruit, whether in the ground or above the ground.</amend></subsection><subsection ssid="1-17" dnum="_-o:17-i" numlevel="1" lineno="47" slineno="1-30" ea="amend" anum="0" owner="jchristopherson" style="1" level="1"><display><amend anum="0" ea="amend" pairid="1016" style="1" owner="i" level="1" amendtag="start">(17)</amend></display><amend anum="0" ea="amend" pairid="51" groupid="35" style="1" owner="jchristopherson" level="1" amendtag="end">Nevertheless, wheat for individuals, and corn for the ox, and oats for the horse, and rye <ln numlevel="1" lineno="48" slineno="1-31"/>for the fowls and for swine, and for all beasts of the field, and barley for all useful <ln numlevel="1" lineno="49" slineno="1-32"/>animals, and for mild drinks, as also other grain.</amend></subsection><subsection ssid="1-18" dnum="_-o:18-i" numlevel="1" lineno="50" slineno="1-33" ea="amend" anum="0" owner="jchristopherson" style="1" level="1"><display><amend anum="0" ea="amend" pairid="1017" style="1" owner="i" level="1" amendtag="start">(18)</amend></display><amend anum="0" ea="amend" pairid="54" groupid="37" style="1" owner="jchristopherson" level="1" amendtag="end">And all state residents who remember to keep and do these sayings, walking in <ln numlevel="1" lineno="51" slineno="1-34"/>obedience to the commandments, shall receive health in their navel and marrow to their <ln numlevel="1" lineno="52" slineno="1-35"/>bones;</amend></subsection><subsection ssid="1-19" dnum="_-o:19-i" numlevel="1" lineno="53" slineno="1-36" ea="amend" anum="0" owner="jchristopherson" style="1" level="1"><display><amend anum="0" ea="amend" pairid="1018" style="1" owner="i" level="1" amendtag="start">(19)</amend></display><amend anum="0" ea="amend" pairid="57" groupid="39" style="1" owner="jchristopherson" level="1" amendtag="end">And shall find wisdom and great treasures of knowledge, even hidden treasures;</amend></subsection><subsection ssid="1-20" dnum="_-o:20-i" numlevel="1" lineno="54" slineno="1-37" ea="amend" anum="0" owner="jchristopherson" style="1" level="1"><display><amend anum="0" ea="amend" pairid="1019" style="1" owner="i" level="1" amendtag="start">(20)</amend></display><amend anum="0" ea="amend" pairid="60" groupid="41" style="1" owner="jchristopherson" level="1" amendtag="end">And shall run and not be weary, and shall walk and not faint.</amend></subsection></section></bsec><bsec buid="2" type="uncod" untype="effdate" src="uncod" uid="EF0000" sort="UZEFF" langlock="true" numlevel="1" lineno="55" slineno="2-1" sn="2"><section type="uncod" untype="effdate" display="false" src="uncod"><secline lineno="55">Section 2.  <bold>Effective Date.</bold></secline><sectionText lineno="56"><amend anum="0" ea="amend" pairid="1" groupid="1" style="1" owner="jchristopherson" level="1" amendtag="both">This bill takes effect on <effdate uid="code" date="5/6/2026">May 6, 2026</effdate>.</amend></sectionText></section></bsec></bdy><foot><rev><tm>3-4-26 9:04 AM</tm></rev></foot></leg>