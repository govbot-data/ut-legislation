<leg xml:space="preserve" billnum="HB0509" sponsor="Doug Owens" designation="HB" otherSponsor="" otherHouse="Senate" sess="2026GS" fileno="2026FL1429" date="2/6/2026 10:02:270" printDate="02-06 10:11" subVer="0" minVer="0" office="LEGISLATIVE GENERAL COUNSEL" actionDate="" impact="code"><info><nextbuid>3</nextbuid><aminfo anum="0" effdate="05/06/2026"><seclist><sect action="A" src="code" buid="1" uid="C79-2-S406_2026050620260506" fromuid="C79-2-S406_2024050120240501" sort="79 02 04060020260506" mtype="section" effdate="05/06/2026">79-2-406</sect><sect src="uncod" untype="effdate" buid="2" uid="EF0000" sort="UZEFF" mtype="uncod" effdate="05/06/2026"/></seclist></aminfo></info><tbox><sinfo><nextpairid>0</nextpairid></sinfo><st numlevel="1" lineno="1" slineno="0-1">Wetlands Protection Modifications</st><sessionhead>2026 GENERAL SESSION</sessionhead><statehead>STATE OF UTAH</statehead><sponsorhead>Chief Sponsor: Doug Owens</sponsorhead><otherSponsorhead>Senate Sponsor: </otherSponsorhead></tbox><lt numlevel="1" lineno="2" slineno="0-2"><lthead lineno="3">LONG TITLE</lthead><gdhead lineno="4">General Description:</gdhead><gd numlevel="1" lineno="5" slineno="0-5">This bill creates a study related to wetland health and protection.</gd><hphead lineno="6">Highlighted Provisions:</hphead><hp numlevel="1" lineno="7" slineno="0-7">This bill:<hl numlevel="1" lineno="8" slineno="0-8" level="1">directs the Department of Natural Resources to:<hl numlevel="1" lineno="9" slineno="0-9" level="2">complete a study on wetlands in the state;</hl><hl numlevel="1" lineno="10" slineno="0-10" level="2">make recommendations for legislative and administrative action on improving wetland <ln numlevel="1" lineno="11" slineno="0-11"/>health and mitigating wetland loss; and</hl><hl numlevel="1" lineno="12" slineno="0-12" level="2">report the study findings and recommendations to the Natural Resources, Agriculture, <ln numlevel="1" lineno="13" slineno="0-13"/>and Environment Interim Committee; and</hl></hl><hl numlevel="1" lineno="14" slineno="0-14" level="1">makes technical and conforming changes.</hl></hp><moni numlevel="1" lineno="15" slineno="0-15" display="none">Money Appropriated in this Bill:</moni><moniNone lineno="16">None</moniNone><oc numlevel="1" lineno="17" slineno="0-17">Other Special Clauses:</oc><ocNone lineno="18">None</ocNone><sa numlevel="1" lineno="19" slineno="0-19">Utah Code Sections Affected:<saamd numlevel="1" lineno="20" slineno="0-20"><snhead>AMENDS:</snhead><sn num="79-2-406" src="code" uid="C79-2-S406_2026050620260506" buid="1" sort="79 02 04060020260506" numlevel="1" lineno="21" slineno="0-21"><bold>79-2-406</bold>, as last amended by Laws of Utah 2024, Chapter 88</sn></saamd></sa></lt><enacthead lineno="22"/><enact numlevel="1" lineno="23" slineno="0-23">Be it enacted by the Legislature of the state of Utah:</enact><bdy><bsec buid="1" num="79-2-406" type="amend" src="code" uid="C79-2-S406_2026050620260506" sort="79 02 04060020260506" numlevel="1" lineno="24" slineno="1-1" sn="1"><section number="79-2-406" numlevel="1" lineno="25" slineno="1-2" type="amend"><secline lineno="24">Section 1. Section <bold>79-2-406</bold> is amended to read:</secline><catline lineno="25"><bold>79-2-406<parens/>. Wetlands study.</bold></catline><subsection ssid="1-null-1" dnum="1-o" numlevel="1" lineno="26" slineno="1-3" level="1" placement="noreturn"><display>(1)</display>As used in this section, "committee" means the Natural Resources, Agriculture, and <ln numlevel="1" lineno="27" slineno="1-4"/>Environment Interim Committee.</subsection><subsection ssid="1-16" dnum="_-o:2-i" numlevel="1" lineno="28" slineno="1-5" ea="amend" anum="0" owner="jchristopherson" style="1" level="1"><display><amend anum="0" ea="amend" pairid="1001" style="1" owner="i" level="1" amendtag="start">(2)</amend></display><amend anum="0" ea="amend" pairid="51" groupid="33" style="1" owner="jchristopherson" level="1" amendtag="end">Before October 30, 2027, the department shall complete a study on the status of <ln numlevel="1" lineno="29" slineno="1-6"/>wetlands in the state.</amend></subsection><subsection ssid="1-17" dnum="_-o:3-i" numlevel="1" lineno="30" slineno="1-7" ea="amend" anum="0" owner="jchristopherson" style="1" level="1"><display><amend anum="0" ea="amend" pairid="1002" style="1" owner="i" level="1" amendtag="start">(3)</amend></display><amend anum="0" ea="amend" pairid="69" groupid="46" style="1" owner="jchristopherson" level="1" amendtag="end">The study described in Subsection <xref depth="4" refnumber="79-2-406(2)">(2)</xref> shall include:</amend><subsection ssid="1-19" dnum="_-o:a-i" numlevel="1" lineno="31" slineno="1-8" ea="amend" anum="0" owner="jchristopherson" style="1" level="2"><display><amend anum="0" ea="amend" pairid="1003" style="1" owner="i" level="1" amendtag="start">(a)</amend></display><amend anum="0" ea="amend" pairid="68" groupid="45" style="1" owner="jchristopherson" level="1" amendtag="end">a determination on how wetland acreage in the state has changed within the previous <marker pairid="173"><ln numlevel="1" lineno="32" slineno="1-9"/>five </marker>years;</amend></subsection><subsection ssid="1-27" dnum="_-o:b-i" numlevel="1" lineno="33" slineno="1-10" ea="amend" anum="0" owner="jchristopherson" style="1" level="2"><display><amend anum="0" ea="amend" pairid="1004" style="1" owner="i" level="1" amendtag="start">(b)</amend></display><amend anum="0" ea="amend" pairid="113" groupid="79" style="1" owner="jchristopherson" level="1" amendtag="end">any reclassification or potential reclassification of wetlands in the previous <marker pairid="174">five </marker>years <ln numlevel="1" lineno="34" slineno="1-11"/>based on changes to federal law;</amend></subsection><subsection ssid="1-20" dnum="_-o:c-i" numlevel="1" lineno="35" slineno="1-12" ea="amend" anum="0" owner="jchristopherson" style="1" level="2"><display><amend anum="0" ea="amend" pairid="1005" style="1" owner="i" level="1" amendtag="start">(c)</amend></display><amend anum="0" ea="amend" pairid="75" groupid="51" style="1" owner="jchristopherson" level="1" amendtag="end">the impact of wetland loss on:</amend><subsection ssid="1-23" dnum="_-o:i-i" numlevel="1" lineno="36" slineno="1-13" ea="amend" anum="0" owner="jchristopherson" style="1" level="3"><display><amend anum="0" ea="amend" pairid="1006" style="1" owner="i" level="1" amendtag="start">(i)</amend></display><amend anum="0" ea="amend" pairid="91" groupid="62" style="1" owner="jchristopherson" level="1" amendtag="end">outdoor recreation, including:</amend><subsection ssid="1-25" dnum="_-o:A-i" numlevel="1" lineno="37" slineno="1-14" ea="amend" anum="0" owner="jchristopherson" style="1" level="4"><display><amend anum="0" ea="amend" pairid="1007" style="1" owner="i" level="1" amendtag="start">(A)</amend></display><amend anum="0" ea="amend" pairid="98" groupid="68" style="1" owner="jchristopherson" level="1" amendtag="end">the hunting of duck and other migratory game birds; and</amend></subsection><subsection ssid="1-26" dnum="_-o:B-i" numlevel="1" lineno="38" slineno="1-15" ea="amend" anum="0" owner="jchristopherson" style="1" level="4"><display><amend anum="0" ea="amend" pairid="1008" style="1" owner="i" level="1" amendtag="start">(B)</amend></display><amend anum="0" ea="amend" pairid="121" groupid="86" style="1" owner="jchristopherson" level="1" amendtag="end">any loss of recreational opportunities on lakes and rivers in the state;</amend></subsection></subsection><subsection ssid="1-21" dnum="_-o:ii-i" numlevel="1" lineno="39" slineno="1-16" ea="amend" anum="0" owner="jchristopherson" style="1" level="3"><display><amend anum="0" ea="amend" pairid="1009" style="1" owner="i" level="1" amendtag="start">(ii)</amend></display><amend anum="0" ea="amend" pairid="100" groupid="70" style="1" owner="jchristopherson" level="1" amendtag="end">water quality in rivers and lakes adjacent to wetlands; and</amend></subsection><subsection ssid="1-32" dnum="_-o:iii-i" numlevel="1" lineno="40" slineno="1-17" ea="amend" anum="0" owner="jchristopherson" style="1" level="3"><display><amend anum="0" ea="amend" pairid="1010" style="1" owner="i" level="1" amendtag="start">(iii)</amend></display><amend anum="0" ea="amend" pairid="170" groupid="120" style="1" owner="jchristopherson" level="1" amendtag="end">aquatic species in greatest need of conservation; and</amend></subsection></subsection><subsection ssid="1-22" dnum="_-o:d-i" numlevel="1" lineno="41" slineno="1-18" ea="amend" anum="0" owner="jchristopherson" style="1" level="2"><display><amend anum="0" ea="amend" pairid="1011" style="1" owner="i" level="1" amendtag="start">(d)</amend></display><amend anum="0" ea="amend" pairid="86" groupid="58" style="1" owner="jchristopherson" level="1" amendtag="end">recommendations for legislative and administration action to:</amend><subsection ssid="1-28" dnum="_-o:i-i" numlevel="1" lineno="42" slineno="1-19" ea="amend" anum="0" owner="jchristopherson" style="1" level="3"><display><amend anum="0" ea="amend" pairid="1012" style="1" owner="i" level="1" amendtag="start">(i)</amend></display><amend anum="0" ea="amend" pairid="120" groupid="85" style="1" owner="jchristopherson" level="1" amendtag="end">improve the health of wetlands in the state; and</amend></subsection><subsection ssid="1-29" dnum="_-o:ii-i" numlevel="1" lineno="43" slineno="1-20" ea="amend" anum="0" owner="jchristopherson" style="1" level="3"><display><amend anum="0" ea="amend" pairid="1013" style="1" owner="i" level="1" amendtag="start">(ii)</amend></display><amend anum="0" ea="amend" pairid="127" groupid="91" style="1" owner="jchristopherson" level="1" amendtag="end">mitigate wetland loss and degradation.</amend></subsection></subsection></subsection><subsection ssid="1-15" dnum="_-o:4-i" numlevel="1" lineno="44" slineno="1-21" ea="amend" anum="0" owner="jchristopherson" style="1" level="1"><display><amend anum="0" ea="amend" pairid="1014" style="1" owner="i" level="1" amendtag="start">(4)</amend></display><amend anum="0" ea="amend" pairid="42" groupid="27" style="1" owner="jchristopherson" level="1" amendtag="end">The department shall report to the committee:</amend><subsection ssid="1-30" dnum="_-o:a-i" numlevel="1" lineno="45" slineno="1-22" ea="amend" anum="0" owner="jchristopherson" style="1" level="2"><display><amend anum="0" ea="amend" pairid="1015" style="1" owner="i" level="1" amendtag="start">(a)</amend></display><amend anum="0" ea="amend" pairid="163" groupid="114" style="1" owner="jchristopherson" level="1" amendtag="end">before November 30, 2026, a progress report of the study findings and <ln numlevel="1" lineno="46" slineno="1-23"/>recommendations described in Subsection <xref depth="4" refnumber="79-2-406(3)">(3)</xref>; and</amend></subsection><subsection ssid="1-31" dnum="_-o:b-i" numlevel="1" lineno="47" slineno="1-24" ea="amend" anum="0" owner="jchristopherson" style="1" level="2"><display><amend anum="0" ea="amend" pairid="1016" style="1" owner="i" level="1" amendtag="start">(b)</amend></display><amend anum="0" ea="amend" pairid="168" groupid="118" style="1" owner="jchristopherson" level="1" amendtag="end">before October 30, 2027, a complete report of the study findings and <ln numlevel="1" lineno="48" slineno="1-25"/>recommendations described in Subsection <xref depth="4" refnumber="79-2-406(3)">(3)</xref>.</amend></subsection></subsection><subsection ssid="1-null-2" dnum="2-o:_-i" numlevel="1" lineno="49" slineno="1-26" ea="erase" anum="0" owner="jchristopherson" style="2" level="1"><display><amendoutstart style="2"/><amend anum="0" ea="erase" pairid="1017" style="2" owner="o" level="1" deltag="start">(2)</amend></display><amend anum="0" ea="erase" pairid="4" groupid="3" style="2" owner="jchristopherson" level="1" deltag="end">The department shall publish, on the department's website, the land use permits <ln numlevel="1" lineno="50" slineno="1-27"/>collected by the Utah Geological Survey pursuant to Subsection <xref refnumber="79-3-202(1)(q)" depth="4">79-3-202(1)(q)</xref>.</amend><amendoutend style="2"/></subsection><subsection ssid="1-null-3" dnum="3-o:_-i" numlevel="1" lineno="51" slineno="1-28" ea="erase" anum="0" owner="jchristopherson" style="2" level="1" space="false"><display><amendoutstart style="2"/><amend anum="0" ea="erase" pairid="1018" style="2" owner="o" level="1" deltag="start">(3)</amend></display><subsection ssid="1-null-4" dnum="a-o:_-i" ea="erase" anum="0" owner="jchristopherson" style="2" level="2" placement="sameline"><display><amend anum="0" ea="erase" pairid="1019" style="2" owner="o" level="1">(a)</amend></display><amend anum="0" ea="erase" pairid="150" groupid="102" style="2" owner="jchristopherson" level="1" deltag="end">The department shall study and make recommendations to the committee on the <ln numlevel="1" lineno="52" slineno="1-29"/>viability of an in-lieu fee program for wetland mitigation, including:</amend><amendoutend style="2"/><subsection ssid="1-null-5" dnum="i-o:_-i" numlevel="1" lineno="53" slineno="1-30" ea="erase" anum="0" owner="jchristopherson" style="2" level="3" tab="1"><display><amendoutstart style="2"/><amend anum="0" ea="erase" pairid="1020" style="2" owner="o" level="1" deltag="start">(i)</amend></display><amend anum="0" ea="erase" pairid="47" groupid="30" style="2" owner="jchristopherson" level="1" deltag="end">the viability of the state establishing and administering an in-lieu fee program; and</amend><amendoutend style="2"/></subsection><subsection ssid="1-null-6" dnum="ii-o:_-i" numlevel="1" lineno="54" slineno="1-31" ea="erase" anum="0" owner="jchristopherson" style="2" level="3" tab="1"><display><amendoutstart style="2"/><amend anum="0" ea="erase" pairid="1021" style="2" owner="o" level="1" deltag="start">(ii)</amend></display><amend anum="0" ea="erase" pairid="50" groupid="32" style="2" owner="jchristopherson" level="1" deltag="end">the viability of the state partnering with a private organization to establish and <ln numlevel="1" lineno="55" slineno="1-32"/>administer an in-lieu fee program.</amend><amendoutend style="2"/></subsection></subsection><subsection ssid="1-null-7" dnum="b-o:_-i" numlevel="1" lineno="56" slineno="1-33" ea="erase" anum="0" owner="jchristopherson" style="2" level="2"><display><amendoutstart style="2"/><amend anum="0" ea="erase" pairid="1022" style="2" owner="o" level="1" deltag="start">(b)</amend></display><amend anum="0" ea="erase" pairid="151" groupid="103" style="2" owner="jchristopherson" level="1" deltag="end">As part of the study described in Subsection (3)(a), the department shall consult <ln numlevel="1" lineno="57" slineno="1-34"/>with public and private individuals and entities that may be necessary or helpful to <ln numlevel="1" lineno="58" slineno="1-35"/>the establishment or administration of an in-lieu fee program for wetland mitigation, <ln numlevel="1" lineno="59" slineno="1-36"/>which may include:</amend><amendoutend style="2"/><subsection ssid="1-null-8" dnum="i-o:_-i" numlevel="1" lineno="60" slineno="1-37" ea="erase" anum="0" owner="jchristopherson" style="2" level="3"><display><amendoutstart style="2"/><amend anum="0" ea="erase" pairid="1023" style="2" owner="o" level="1" deltag="start">(i)</amend></display><amend anum="0" ea="erase" pairid="152" groupid="104" style="2" owner="jchristopherson" level="1" deltag="end">the Utah Department of Environmental Quality;</amend><amendoutend style="2"/></subsection><subsection ssid="1-null-9" dnum="ii-o:_-i" numlevel="1" lineno="61" slineno="1-38" ea="erase" anum="0" owner="jchristopherson" style="2" level="3"><display><amendoutstart style="2"/><amend anum="0" ea="erase" pairid="1024" style="2" owner="o" level="1" deltag="start">(ii)</amend></display><amend anum="0" ea="erase" pairid="153" groupid="105" style="2" owner="jchristopherson" level="1" deltag="end">the United States Army Corps of Engineers;</amend><amendoutend style="2"/></subsection><subsection ssid="1-null-10" dnum="iii-o:_-i" numlevel="1" lineno="62" slineno="1-39" ea="erase" anum="0" owner="jchristopherson" style="2" level="3"><display><amendoutstart style="2"/><amend anum="0" ea="erase" pairid="1025" style="2" owner="o" level="1" deltag="start">(iii)</amend></display><amend anum="0" ea="erase" pairid="154" groupid="106" style="2" owner="jchristopherson" level="1" deltag="end">the United States Fish and Wildlife Service;</amend><amendoutend style="2"/></subsection><subsection ssid="1-null-11" dnum="iv-o:_-i" numlevel="1" lineno="63" slineno="1-40" ea="erase" anum="0" owner="jchristopherson" style="2" level="3"><display><amendoutstart style="2"/><amend anum="0" ea="erase" pairid="1026" style="2" owner="o" level="1" deltag="start">(iv)</amend></display><amend anum="0" ea="erase" pairid="155" groupid="107" style="2" owner="jchristopherson" level="1" deltag="end">the United States Environmental Protection Agency; or</amend><amendoutend style="2"/></subsection><subsection ssid="1-null-12" dnum="v-o:_-i" numlevel="1" lineno="64" slineno="1-41" ea="erase" anum="0" owner="jchristopherson" style="2" level="3"><display><amendoutstart style="2"/><amend anum="0" ea="erase" pairid="1027" style="2" owner="o" level="1" deltag="start">(v)</amend></display><amend anum="0" ea="erase" pairid="156" groupid="108" style="2" owner="jchristopherson" level="1" deltag="end">a non-profit entity that has experience with the establishment and administration <ln numlevel="1" lineno="65" slineno="1-42"/>of in-lieu fee programs.</amend><amendoutend style="2"/></subsection></subsection><subsection ssid="1-null-13" dnum="c-o:_-i" numlevel="1" lineno="66" slineno="1-43" ea="erase" anum="0" owner="jchristopherson" style="2" level="2"><display><amendoutstart style="2"/><amend anum="0" ea="erase" pairid="1028" style="2" owner="o" level="1" deltag="start">(c)</amend></display><amend anum="0" ea="erase" pairid="157" groupid="109" style="2" owner="jchristopherson" level="1" deltag="end">The department shall provide a report on the status of the department's study during <ln numlevel="1" lineno="67" slineno="1-44"/>or before the committee's November interim meeting in 2022.</amend><amendoutend style="2"/></subsection><subsection ssid="1-null-14" dnum="d-o:_-i" numlevel="1" lineno="68" slineno="1-45" ea="erase" anum="0" owner="jchristopherson" style="2" level="2"><display><amendoutstart style="2"/><amend anum="0" ea="erase" pairid="1029" style="2" owner="o" level="1" deltag="start">(d)</amend></display><amend anum="0" ea="erase" pairid="158" groupid="110" style="2" owner="jchristopherson" level="1" deltag="end">The department shall provide a final report of the department's study and <ln numlevel="1" lineno="69" slineno="1-46"/>recommendations, including any recommended legislation, during or before the <ln numlevel="1" lineno="70" slineno="1-47"/>committee's first interim meeting in 2023.</amend><amendoutend style="2"/></subsection></subsection></section></bsec><bsec buid="2" type="uncod" untype="effdate" src="uncod" uid="EF0000" sort="UZEFF" langlock="true" numlevel="1" lineno="71" slineno="2-1" sn="2"><section type="uncod" untype="effdate" display="false" src="uncod"><secline lineno="71">Section 2.  <bold>Effective Date.</bold></secline><sectionText lineno="72"><amend anum="0" ea="amend" pairid="1" groupid="1" style="1" owner="jchristopherson" level="1" amendtag="both">This bill takes effect on <effdate uid="code" date="5/6/2026">May 6, 2026</effdate>.</amend></sectionText></section></bsec></bdy><foot><rev><tm>2-6-26 10:11 AM</tm></rev></foot></leg>