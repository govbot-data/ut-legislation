<leg xml:space="preserve" billnum="HB0332" sponsor="Tiara Auxier" designation="HB" otherSponsor="" otherHouse="Senate" sess="2026GS" fileno="2026FL1406" date="1/22/2026 14:01:460" printDate="01-22 14:01" subVer="0" minVer="0" office="LEGISLATIVE GENERAL COUNSEL" actionDate="" impact="code"><info><nextbuid>3</nextbuid><aminfo anum="0" effdate="05/06/2026"><seclist><sect action="E" src="code" buid="1" uid="C17D-2-S303_2026050620260506" sort="17D02 03030020260506" mtype="section" effdate="05/06/2026">17D-2-303</sect><sect src="uncod" untype="effdate" buid="2" uid="EF0000" sort="UZEFF" mtype="uncod" effdate="05/06/2026"/></seclist></aminfo></info><tbox><sinfo><nextpairid>0</nextpairid></sinfo><st numlevel="1" lineno="1" slineno="0-1">Local Building Authority Amendments</st><sessionhead>2026 GENERAL SESSION</sessionhead><statehead>STATE OF UTAH</statehead><sponsorhead>Chief Sponsor: Tiara Auxier</sponsorhead><otherSponsorhead>Senate Sponsor: </otherSponsorhead></tbox><lt numlevel="1" lineno="2" slineno="0-2"><lthead lineno="3">LONG TITLE</lthead><gdhead lineno="4">General Description:</gdhead><gd numlevel="1" lineno="5" slineno="0-5">This bill amends the authority of a local building authority.</gd><hphead lineno="6">Highlighted Provisions:</hphead><hp numlevel="1" lineno="7" slineno="0-7">This bill:<hl numlevel="1" lineno="8" slineno="0-8" level="1">prohibits a local building authority from executing a project previously rejected by the <ln numlevel="1" lineno="9" slineno="0-9"/>voters of certain creating local entities.</hl></hp><moni numlevel="1" lineno="10" slineno="0-10" display="none">Money Appropriated in this Bill:</moni><moniNone lineno="11">None</moniNone><oc numlevel="1" lineno="12" slineno="0-12">Other Special Clauses:</oc><ocNone lineno="13">None</ocNone><sa numlevel="1" lineno="14" slineno="0-14">Utah Code Sections Affected:<saent numlevel="1" lineno="15" slineno="0-15"><snhead>ENACTS:</snhead><sn num="17D-2-303" src="code" uid="C17D-2-S303_2026050620260506" buid="1" sort="17D02 03030020260506" numlevel="1" lineno="16" slineno="0-16"><bold>17D-2-303</bold>, Utah Code Annotated 1953</sn></saent></sa></lt><enacthead lineno="17"/><enact numlevel="1" lineno="18" slineno="0-18">Be it enacted by the Legislature of the state of Utah:</enact><bdy><bsec buid="1" num="17D-2-303" type="enact" src="code" uid="C17D-2-S303_2026050620260506" sort="17D02 03030020260506" numlevel="1" lineno="19" slineno="1-1" sn="1"><section numlevel="1" lineno="20" slineno="1-2" number="17D-2-303" type="enact"><secline lineno="19">Section 1. Section <bold>17D-2-303</bold> is enacted to read:</secline><catline lineno="20"><bold>17D-2-303<parens/>. Voter-rejected project prohibited.</bold></catline><sectionText lineno="21"><para/><amend anum="0" ea="amend" pairid="2" groupid="2" style="1" owner="jchristopherson" level="1" amendtag="both">A local building authority may not construct, acquire, improve, extend, or finance a <ln numlevel="1" lineno="22" slineno="1-4"/>project on behalf of the county, city, town, or school district that created the local building <ln numlevel="1" lineno="23" slineno="1-5"/>authority if the project, a portion of the project, or a substantially similar project, was rejected <ln numlevel="1" lineno="24" slineno="1-6"/>by the voters of a county, city, town, or school district.</amend></sectionText></section></bsec><bsec buid="2" type="uncod" untype="effdate" src="uncod" uid="EF0000" sort="UZEFF" langlock="true" numlevel="1" lineno="25" slineno="2-1" sn="2"><section type="uncod" untype="effdate" display="false" src="uncod"><secline lineno="25">Section 2.  <bold>Effective Date.</bold></secline><sectionText lineno="26"><amend anum="0" ea="amend" pairid="1" groupid="1" style="1" owner="jchristopherson" level="1" amendtag="both">This bill takes effect on <effdate uid="code" date="5/6/2026">May 6, 2026</effdate>.</amend></sectionText></section></bsec></bdy><foot><rev><tm>1-22-26 2:01 PM</tm></rev></foot></leg>