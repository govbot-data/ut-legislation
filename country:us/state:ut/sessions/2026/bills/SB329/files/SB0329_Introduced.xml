<leg xml:space="preserve" billnum="SB0329" sponsor="Nate Blouin" designation="SB" otherSponsor="" otherHouse="House" sess="2026GS" fileno="2026FL1420" date="3/2/2026 16:03:587" printDate="03-02 16:01" subVer="0" minVer="0" office="LEGISLATIVE GENERAL COUNSEL" actionDate="" impact="code"><info><nextbuid>3</nextbuid><aminfo anum="0" effdate="05/06/2026"><seclist><sect action="R" src="code" buid="1" uid="C63G-27-S102_2026050620260506" fromuid="C63G-27-S102_2023050320230503" sort="63G27 01020020260506" mtype="section" effdate="05/06/2026">63G-27-102</sect><sect action="R" src="code" buid="1" uid="C63G-27-S201_2026050620260506" fromuid="C63G-27-S201_2023050320230503" sort="63G27 02010020260506" mtype="section" effdate="05/06/2026">63G-27-201</sect><sect action="R" src="code" buid="1" uid="C63G-27-S202_2026050620260506" fromuid="C63G-27-S202_2023050320230503" sort="63G27 02020020260506" mtype="section" effdate="05/06/2026">63G-27-202</sect><sect src="uncod" untype="effdate" buid="2" uid="EF0000" sort="UZEFF" mtype="uncod" effdate="05/06/2026"/></seclist></aminfo></info><tbox><sinfo><nextpairid>0</nextpairid></sinfo><st numlevel="1" lineno="1" slineno="0-1">Public Contracting and Boycott Amendments</st><sessionhead>2026 GENERAL SESSION</sessionhead><statehead>STATE OF UTAH</statehead><sponsorhead>Chief Sponsor: Nate Blouin</sponsorhead><otherSponsorhead>House Sponsor: </otherSponsorhead></tbox><lt numlevel="1" lineno="2" slineno="0-2"><lthead lineno="3">LONG TITLE</lthead><gdhead lineno="4">General Description:</gdhead><gd numlevel="1" lineno="5" slineno="0-5">This bill repeals Title 63G, Chapter 27, Public Contract Boycott Restrictions. </gd><hphead lineno="6">Highlighted Provisions:</hphead><hp numlevel="1" lineno="7" slineno="0-7">This bill:<hl numlevel="1" lineno="8" slineno="0-8" level="1">repeals provisions that prohibit a public entity from entering into a contract with a <ln numlevel="1" lineno="9" slineno="0-9"/>company based on the company's participation in a boycott of the State of Israel or an <ln numlevel="1" lineno="10" slineno="0-10"/>economic boycott;</hl><hl numlevel="1" lineno="11" slineno="0-11" level="1">repeals definitions and requirements related to boycott actions, economic boycotts, and <ln numlevel="1" lineno="12" slineno="0-12"/>related contracting certifications;</hl><hl numlevel="1" lineno="13" slineno="0-13" level="1">repeals contract-certification, notice, and termination provisions applicable to public <ln numlevel="1" lineno="14" slineno="0-14"/>entities and contractors; and</hl><hl numlevel="1" lineno="15" slineno="0-15" level="1">repeals provisions prohibiting interference with state programs or commercial <ln numlevel="1" lineno="16" slineno="0-16"/>relationships related to boycott-based contracting restrictions.</hl></hp><moni numlevel="1" lineno="17" slineno="0-17" display="none">Money Appropriated in this Bill:</moni><moniNone lineno="18">None</moniNone><oc numlevel="1" lineno="19" slineno="0-19">Other Special Clauses:</oc><ocNone lineno="20">None</ocNone><sa numlevel="1" lineno="21" slineno="0-21">Utah Code Sections Affected:<sarep numlevel="1" lineno="22" slineno="0-22"><snhead>REPEALS:</snhead><sn num="63G-27-102" src="code" uid="C63G-27-S102_2026050620260506" buid="1" sort="63G27 01020020260506" numlevel="1" lineno="23" slineno="0-23"><bold>63G-27-102</bold>, as last amended by Laws of Utah 2023, Chapter 243</sn><sn num="63G-27-201" src="code" uid="C63G-27-S201_2026050620260506" buid="1" sort="63G27 02010020260506" numlevel="1" lineno="24" slineno="0-24"><bold>63G-27-201</bold>, as last amended by Laws of Utah 2023, Chapter 243</sn><sn num="63G-27-202" src="code" uid="C63G-27-S202_2026050620260506" buid="1" sort="63G27 02020020260506" numlevel="1" lineno="25" slineno="0-25"><bold>63G-27-202</bold>, as enacted by Laws of Utah 2023, Chapter 243</sn></sarep></sa></lt><enacthead lineno="26"/><enact numlevel="1" lineno="27" slineno="0-27">Be it enacted by the Legislature of the state of Utah:</enact><bdy><bsec buid="1" type="repealer" src="code" sort="TRepealer" numlevel="1" lineno="28" slineno="1-1" sn="1"><secline>Section 1. <bold>Repealer.</bold></secline><rhead lineno="29"/><sectionText><repsec num="63G-27-102" uid="C63G-27-S102_2026050620260506" sort="63G27 01020020260506" src="code" sn="1" numlevel="1" lineno="30" slineno="1-3"><parens/>Definitions.</repsec><repsec num="63G-27-201" uid="C63G-27-S201_2026050620260506" sort="63G27 02010020260506" src="code" sn="1" numlevel="1" lineno="31" slineno="1-4"><parens/>Prohibition on contracting.</repsec><repsec num="63G-27-202" uid="C63G-27-S202_2026050620260506" sort="63G27 02020020260506" src="code" sn="1" numlevel="1" lineno="32" slineno="1-5"><parens/>Prohibition on interference with state programs and commercial <ln numlevel="1" lineno="33" slineno="1-6"/>relationships.</repsec></sectionText></bsec><bsec buid="2" type="uncod" untype="effdate" src="uncod" uid="EF0000" sort="UZEFF" langlock="true" numlevel="1" lineno="34" slineno="2-1" sn="2"><section type="uncod" untype="effdate" display="false" src="uncod"><secline lineno="34">Section 2.  <bold>Effective Date.</bold></secline><sectionText lineno="35"><amend anum="0" ea="amend" pairid="1" groupid="1" style="1" owner="jchristopherson" level="1" amendtag="both">This bill takes effect on <effdate uid="code" date="5/6/2026">May 6, 2026</effdate>.</amend></sectionText></section></bsec></bdy><foot><rev><tm>3-2-26 4:01 PM</tm></rev></foot></leg>