<leg xml:space="preserve" billnum="HB0258" sponsor="Nicholeen P. Peck" designation="HB" otherSponsor="" otherHouse="Senate" sess="2026GS" fileno="2026FL1074" date="1/14/2026 13:01:970" printDate="01-14 13:28" subVer="0" minVer="0" office="LEGISLATIVE GENERAL COUNSEL" actionDate="" impact="code"><info><nextbuid>3</nextbuid><aminfo anum="0" effdate="05/06/2026"><seclist><sect action="E" src="code" buid="1" uid="C31A-22-S663_2026050620260506" sort="31A22 06630020260506" mtype="section" effdate="05/06/2026">31A-22-663</sect><sect src="uncod" untype="effdate" buid="2" uid="EF0000" sort="UZEFF" mtype="uncod" effdate="05/06/2026"/></seclist></aminfo></info><tbox><sinfo><nextpairid>0</nextpairid></sinfo><st numlevel="1" lineno="1" slineno="0-1">Insurance Coverage Amendments</st><sessionhead>2026 GENERAL SESSION</sessionhead><statehead>STATE OF UTAH</statehead><sponsorhead>Chief Sponsor: Nicholeen P. Peck</sponsorhead><otherSponsorhead>Senate Sponsor: </otherSponsorhead></tbox><lt numlevel="1" lineno="2" slineno="0-2"><lthead lineno="3">LONG TITLE</lthead><gdhead lineno="4">General Description:</gdhead><gd numlevel="1" lineno="5" slineno="0-5">This bill amends provisions related to insurance coverage.</gd><hphead lineno="6">Highlighted Provisions:</hphead><hp numlevel="1" lineno="7" slineno="0-7">This bill:<hl numlevel="1" lineno="8" slineno="0-8" level="1">requires a health benefit plan to cover procedures, treatment, and therapy to reverse sex <ln numlevel="1" lineno="9" slineno="0-9"/>transition procedures if the health benefit plan covers a sex transition procedure.</hl></hp><moni numlevel="1" lineno="10" slineno="0-10" display="none">Money Appropriated in this Bill:</moni><moniNone lineno="11">None</moniNone><oc numlevel="1" lineno="12" slineno="0-12">Other Special Clauses:</oc><ocNone lineno="13">None</ocNone><sa numlevel="1" lineno="14" slineno="0-14">Utah Code Sections Affected:<saent numlevel="1" lineno="15" slineno="0-15"><snhead>ENACTS:</snhead><sn num="31A-22-663" src="code" uid="C31A-22-S663_2026050620260506" buid="1" sort="31A22 06630020260506" numlevel="1" lineno="16" slineno="0-16"><bold>31A-22-663</bold>, Utah Code Annotated 1953</sn></saent></sa></lt><enacthead lineno="17"/><enact numlevel="1" lineno="18" slineno="0-18">Be it enacted by the Legislature of the state of Utah:</enact><bdy><bsec buid="1" num="31A-22-663" type="enact" src="code" uid="C31A-22-S663_2026050620260506" sort="31A22 06630020260506" numlevel="1" lineno="19" slineno="1-1" sn="1"><section numlevel="1" lineno="20" slineno="1-2" number="31A-22-663" type="enact"><secline lineno="19">Section 1. Section <bold>31A-22-663</bold> is enacted to read:</secline><catline lineno="20"><bold>31A-22-663<parens/>. Coverage for reversal of sex transition procedures.</bold></catline><subsection ssid="1-1" dnum="_-o:1-i" numlevel="1" lineno="21" slineno="1-3" ea="amend" anum="0" owner="jchristopherson" style="1" level="1" placement="noreturn"><display><amend anum="0" ea="amend" pairid="1000" style="1" owner="i" level="1" amendtag="start">(1)</amend></display><amend anum="0" ea="amend" pairid="17" groupid="13" style="1" owner="jchristopherson" level="1" amendtag="end">As used in this section, "sex transition procedure" means:</amend><subsection ssid="1-3" dnum="_-o:a-i" numlevel="1" lineno="22" slineno="1-4" ea="amend" anum="0" owner="jchristopherson" style="1" level="2"><display><amend anum="0" ea="amend" pairid="1001" style="1" owner="i" level="1" amendtag="start">(a)</amend></display><amend anum="0" ea="amend" pairid="16" groupid="12" style="1" owner="jchristopherson" level="1" amendtag="end">hormonal transgender treatment as defined in Section <xref depth="3" refnumber="58-1-603">58-1-603</xref>;</amend></subsection><subsection ssid="1-4" dnum="_-o:b-i" numlevel="1" lineno="23" slineno="1-5" ea="amend" anum="0" owner="jchristopherson" style="1" level="2"><display><amend anum="0" ea="amend" pairid="1002" style="1" owner="i" level="1" amendtag="start">(b)</amend></display><amend anum="0" ea="amend" pairid="23" groupid="18" style="1" owner="jchristopherson" level="1" amendtag="end">a primary sex characteristic surgical procedure as defined in Section <xref depth="3" refnumber="58-67-102">58-67-102</xref>; or</amend></subsection><subsection ssid="1-5" dnum="_-o:c-i" numlevel="1" lineno="24" slineno="1-6" ea="amend" anum="0" owner="jchristopherson" style="1" level="2"><display><amend anum="0" ea="amend" pairid="1003" style="1" owner="i" level="1" amendtag="start">(c)</amend></display><amend anum="0" ea="amend" pairid="29" groupid="23" style="1" owner="jchristopherson" level="1" amendtag="end">a secondary sex characteristic surgical procedure as defined in Section <xref depth="3" refnumber="58-67-102">58-67-102</xref>.</amend></subsection></subsection><subsection ssid="1-2" dnum="_-o:2-i" numlevel="1" lineno="25" slineno="1-7" ea="amend" anum="0" owner="jchristopherson" style="1" level="1"><display><amend anum="0" ea="amend" pairid="1004" style="1" owner="i" level="1" amendtag="start">(2)</amend></display><amend anum="0" ea="amend" pairid="10" groupid="7" style="1" owner="jchristopherson" level="1" amendtag="end">A health benefit plan that covers any sex transition procedure shall also cover any <ln numlevel="1" lineno="26" slineno="1-8"/>procedure, treatment, or therapy necessary to reverse an individual's sex transition <ln numlevel="1" lineno="27" slineno="1-9"/>procedure.</amend></subsection></section></bsec><bsec buid="2" type="uncod" untype="effdate" src="uncod" uid="EF0000" sort="UZEFF" langlock="true" numlevel="1" lineno="28" slineno="2-1" sn="2"><section type="uncod" untype="effdate" display="false" src="uncod"><secline lineno="28">Section 2.  <bold>Effective Date.</bold></secline><sectionText lineno="29"><amend anum="0" ea="amend" pairid="1" groupid="1" style="1" owner="jchristopherson" level="1" amendtag="both">This bill takes effect on <effdate uid="code" date="5/6/2026">May 6, 2026</effdate>.</amend></sectionText></section></bsec></bdy><foot><rev><tm>1-14-26 1:28 PM</tm></rev></foot></leg>