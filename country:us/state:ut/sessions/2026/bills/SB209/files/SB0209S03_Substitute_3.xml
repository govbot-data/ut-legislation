<leg xml:space="preserve" billnum="SB0209" sponsor="Derrin R. Owens" designation="SB" otherSponsor="Troy Shelley" otherHouse="House" subNumber="03" subSponsor="Derrin R. Owens" sess="2026GS" fileno="2026FL0907" date="2/11/2026 14:02:987" printDate="02-24 11:56" subVer="3" minVer="0" office="LEGISLATIVE GENERAL COUNSEL" actionDate="" impact="code"><info><nextbuid>3</nextbuid><aminfo anum="0" effdate="05/06/2026"><seclist><sect action="E" src="code" buid="1" uid="C79-4-S609_2026050620260506" sort="79 04 06090020260506" mtype="section" effdate="05/06/2026">79-4-609</sect><sect src="uncod" untype="effdate" buid="2" uid="EF0000" sort="UZEFF" mtype="uncod" effdate="05/06/2026"/></seclist></aminfo></info><tbox><sinfo><nextpairid>4</nextpairid></sinfo><st numlevel="1" lineno="1" slineno="0-1">Gooseberry Narrows State Park Study</st><sessionhead>2026 GENERAL SESSION</sessionhead><statehead>STATE OF UTAH</statehead><sponsorhead>Chief Sponsor: Derrin R. Owens</sponsorhead><otherSponsorhead>House Sponsor: Troy Shelley</otherSponsorhead></tbox><lt numlevel="1" lineno="2" slineno="0-2"><lthead lineno="3">LONG TITLE</lthead><gdhead lineno="4">General Description:</gdhead><gd numlevel="1" lineno="5" slineno="0-5">This bill addresses a study for the creation of Gooseberry Narrows State Park.</gd><hphead lineno="6">Highlighted Provisions:</hphead><hp numlevel="1" lineno="7" slineno="0-7">This bill:<hl numlevel="1" lineno="8" slineno="0-8" level="1">defines the gooseberry narrows; </hl><hl numlevel="1" lineno="9" slineno="0-9" level="1">requires the Division of State Parks (division) to study the feasibility and potential cost of <ln numlevel="1" lineno="10" slineno="0-10"/>developing and constructing a state park and dam in the gooseberry narrows; and</hl><hl numlevel="1" lineno="11" slineno="0-11" level="1"> requires the division to report the results of the study to the Natural Resources, <ln numlevel="1" lineno="12" slineno="0-12"/>Agriculture, and Environment Interim Committee.<marker pairid="0"/><marker pairid="1"/><marker pairid="2"/><marker pairid="3"/></hl></hp><moni numlevel="1" lineno="13" slineno="0-13" display="none">Money Appropriated in this Bill:</moni><moniNone lineno="14">None</moniNone><oc numlevel="1" lineno="15" slineno="0-15">Other Special Clauses:</oc><ocNone lineno="16">None</ocNone><sa numlevel="1" lineno="17" slineno="0-17">Utah Code Sections Affected:<saent numlevel="1" lineno="18" slineno="0-18"><snhead>ENACTS:</snhead><sn num="79-4-609" src="code" uid="C79-4-S609_2026050620260506" buid="1" sort="79 04 06090020260506" numlevel="1" lineno="19" slineno="0-19"><bold>79-4-609</bold>, Utah Code Annotated 1953</sn></saent></sa></lt><enacthead lineno="20"/><enact numlevel="1" lineno="21" slineno="0-21">Be it enacted by the Legislature of the state of Utah:</enact><bdy><bsec buid="1" num="79-4-609" type="enact" src="code" uid="C79-4-S609_2026050620260506" sort="79 04 06090020260506" numlevel="1" lineno="22" slineno="1-1" sn="1"><section numlevel="1" lineno="23" slineno="1-2" number="79-4-609" type="enact"><secline lineno="22">Section 1. Section <bold>79-4-609</bold> is enacted to read:</secline><catline lineno="23"><bold>79-4-609<parens/>. Gooseberry Narrows State Park -- Study -- Report.</bold></catline><subsection ssid="1-1" dnum="_-o:1-i" numlevel="1" lineno="24" slineno="1-3" ea="amend" anum="0" owner="jchristopherson" style="1" level="1" placement="noreturn"><display><amend anum="0" ea="amend" pairid="1000" style="1" owner="i" level="1" amendtag="start">(1)</amend></display><amend anum="0" ea="amend" pairid="11" groupid="8" style="1" owner="jchristopherson" level="1" amendtag="end">As used in this section, "gooseberry narrows" means the land on Gooseberry Creek <ln numlevel="1" lineno="25" slineno="1-4"/>between the Lower Gooseberry Dam and Fairview Lakes described by the map and legal <ln numlevel="1" lineno="26" slineno="1-5"/>description on file with the division.</amend></subsection><subsection ssid="1-35" dnum="_-o:2-i" numlevel="1" lineno="27" slineno="1-6" ea="amend" anum="0" owner="jchristopherson" style="1" level="1" space="false"><display><amend anum="0" ea="amend" pairid="1001" style="1" owner="i" level="1" amendtag="start">(2)</amend></display><subsection ssid="1-38" dnum="_-o:a-i" ea="amend" anum="0" owner="jchristopherson" style="1" level="2" placement="sameline"><display><amend anum="0" ea="amend" pairid="1002" style="1" owner="i" level="1">(a)</amend></display><amend anum="0" ea="amend" pairid="166" groupid="114" style="1" owner="jchristopherson" level="1" amendtag="end">The division shall study the feasibility of creating Gooseberry Narrows State Park, <ln numlevel="1" lineno="28" slineno="1-7"/>including:</amend><subsection ssid="1-43" dnum="_-o:i-i" numlevel="1" lineno="29" slineno="1-8" ea="amend" anum="0" owner="jchristopherson" style="1" level="3" tab="1"><display><amend anum="0" ea="amend" pairid="1003" style="1" owner="i" level="1" amendtag="start">(i)</amend></display><amend anum="0" ea="amend" pairid="211" groupid="146" style="1" owner="jchristopherson" level="1" amendtag="end">any necessary requirement for the development or construction of a dam and <ln numlevel="1" lineno="30" slineno="1-9"/>reservoir in the gooseberry narrows; <marker pairid="218">a</marker><marker pairid="219">n</marker><marker pairid="220">d</marker></amend></subsection><subsection ssid="1-36" dnum="_-o:ii-i" numlevel="1" lineno="31" slineno="1-10" ea="amend" anum="0" owner="jchristopherson" style="1" level="3" tab="1"><display><amend anum="0" ea="amend" pairid="1004" style="1" owner="i" level="1" amendtag="start">(ii)</amend></display><amend anum="0" ea="amend" pairid="179" groupid="125" style="1" owner="jchristopherson" level="1" amendtag="end">the expected cost to the state of:</amend><subsection ssid="1-44" dnum="_-o:A-i" numlevel="1" lineno="32" slineno="1-11" ea="amend" anum="0" owner="jchristopherson" style="1" level="4"><display><amend anum="0" ea="amend" pairid="1005" style="1" owner="i" level="1" amendtag="start">(A)</amend></display><amend anum="0" ea="amend" pairid="214" groupid="148" style="1" owner="jchristopherson" level="1" amendtag="end">transferring, exchanging, or purchasing all federally managed lands in the <ln numlevel="1" lineno="33" slineno="1-12"/>gooseberry narrows;</amend></subsection><subsection ssid="1-37" dnum="_-o:B-i" numlevel="1" lineno="34" slineno="1-13" ea="amend" anum="0" owner="jchristopherson" style="1" level="4"><display><amend anum="0" ea="amend" pairid="1006" style="1" owner="i" level="1" amendtag="start">(B)</amend></display><amend anum="0" ea="amend" pairid="203" groupid="141" style="1" owner="jchristopherson" level="1" amendtag="end">constructing and developing infrastructure needed for a state park in the <ln numlevel="1" lineno="35" slineno="1-14"/>gooseberry narrows; and</amend></subsection><subsection ssid="1-40" dnum="_-o:C-i" numlevel="1" lineno="36" slineno="1-15" ea="amend" anum="0" owner="jchristopherson" style="1" level="4"><display><amend anum="0" ea="amend" pairid="1007" style="1" owner="i" level="1" amendtag="start">(C)</amend></display><amend anum="0" ea="amend" pairid="210" groupid="145" style="1" owner="jchristopherson" level="1" amendtag="end">constructing and developing a dam and reservoir in the gooseberry narrows.</amend></subsection></subsection></subsection></subsection><subsection ssid="1-39" dnum="_-o:3-i" numlevel="1" lineno="37" slineno="1-16" ea="amend" anum="0" owner="jchristopherson" style="1" level="1"><display><amend anum="0" ea="amend" pairid="1008" style="1" owner="i" level="1" amendtag="start">(3)</amend></display><amend anum="0" ea="amend" pairid="190" groupid="133" style="1" owner="jchristopherson" level="1" amendtag="end">Before November 30, 2026, the division shall report the results of the study described in <ln numlevel="1" lineno="38" slineno="1-17"/>Subsection <xref depth="4" refnumber="79-4-609(2)">(2)</xref> to the Natural Resources, Agriculture, and Environment Interim <ln numlevel="1" lineno="39" slineno="1-18"/>Committee.</amend></subsection></section></bsec><bsec buid="2" type="uncod" untype="effdate" src="uncod" uid="EF0000" sort="UZEFF" langlock="true" numlevel="1" lineno="40" slineno="2-1" sn="2"><section type="uncod" untype="effdate" display="false" src="uncod"><secline lineno="40">Section 2.  <bold>Effective Date.</bold></secline><sectionText lineno="41"><amend anum="0" ea="amend" pairid="1" groupid="1" style="1" owner="jchristopherson" level="1" amendtag="both">This bill takes effect on <effdate uid="code" date="5/6/2026">May 6, 2026</effdate>.</amend></sectionText></section></bsec></bdy><foot><rev><tm>2-11-26 2:38 PM</tm></rev></foot></leg>