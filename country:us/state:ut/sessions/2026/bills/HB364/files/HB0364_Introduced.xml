<leg xml:space="preserve" billnum="HB0364" sponsor="John Arthur" designation="HB" otherSponsor="" otherHouse="Senate" sess="2026GS" fileno="2026FL1370" date="1/26/2026 09:01:457" printDate="01-26 09:05" subVer="0" minVer="0" office="LEGISLATIVE GENERAL COUNSEL" actionDate="" impact="code"><info><nextbuid>4</nextbuid><aminfo anum="0" effdate="07/01/2026"><seclist><sect action="E" src="code" buid="1" uid="C53G-11-S210_2026070120260701" sort="53G11 02100020260701" mtype="section" effdate="07/01/2026">53G-11-210</sect><sect src="uncod" untype="effdate" buid="3" uid="EF0000" sort="UZEFF" mtype="uncod" effdate="05/06/2026"/></seclist></aminfo></info><tbox><sinfo><nextpairid>0</nextpairid></sinfo><st numlevel="1" lineno="1" slineno="0-1">Certified Teacher Librarian Amendments</st><sessionhead>2026 GENERAL SESSION</sessionhead><statehead>STATE OF UTAH</statehead><sponsorhead>Chief Sponsor: John Arthur</sponsorhead><otherSponsorhead>Senate Sponsor: </otherSponsorhead></tbox><lt numlevel="1" lineno="2" slineno="0-2"><lthead lineno="3">LONG TITLE</lthead><gdhead lineno="4">General Description:</gdhead><gd numlevel="1" lineno="5" slineno="0-5">This bill requires a school district or regional education service agency to staff a full-time <ln numlevel="1" lineno="6" slineno="0-6"/>certified teacher librarian.</gd><hphead lineno="7">Highlighted Provisions:</hphead><hp numlevel="1" lineno="8" slineno="0-8">This bill:<hl numlevel="1" lineno="9" slineno="0-9" level="1">defines terms;</hl><hl numlevel="1" lineno="10" slineno="0-10" level="1">requires a school district or a regional education service agency to staff a certified teacher <ln numlevel="1" lineno="11" slineno="0-11"/>librarian to:<hl numlevel="1" lineno="12" slineno="0-12" level="2">oversee the curation of materials in a school's library;</hl><hl numlevel="1" lineno="13" slineno="0-13" level="2">develop certain curricula;</hl><hl numlevel="1" lineno="14" slineno="0-14" level="2">assist schools in complying with certain state statutes; and</hl><hl numlevel="1" lineno="15" slineno="0-15" level="2">provide professional learning and mentorship; and</hl></hl><hl numlevel="1" lineno="16" slineno="0-16" level="1">requires the State Board of Education to:<hl numlevel="1" lineno="17" slineno="0-17" level="2">distribute funds the Legislature appropriates; and</hl><hl numlevel="1" lineno="18" slineno="0-18" level="2">make relevant rules.</hl></hl></hp><moni numlevel="1" lineno="19" slineno="0-19" display="none">Money Appropriated in this Bill:</moni><moniNone lineno="20">None</moniNone><oc numlevel="1" lineno="21" slineno="0-21">Other Special Clauses:<ocl type="effdate" sort="2" numlevel="1" lineno="22" slineno="0-22">This bill provides a special effective date.</ocl></oc><sa numlevel="1" lineno="23" slineno="0-23">Utah Code Sections Affected:<saent numlevel="1" lineno="24" slineno="0-24"><snhead>ENACTS:</snhead><sn num="53G-11-210" src="code" uid="C53G-11-S210_2026070120260701" buid="1" sort="53G11 02100020260701" numlevel="1" lineno="25" slineno="0-25"><bold>53G-11-210</bold>, Utah Code Annotated 1953</sn></saent></sa></lt><enacthead lineno="26"/><enact numlevel="1" lineno="27" slineno="0-27">Be it enacted by the Legislature of the state of Utah:</enact><bdy><bsec buid="1" num="53G-11-210" type="enact" src="code" uid="C53G-11-S210_2026070120260701" sort="53G11 02100020260701" numlevel="1" lineno="28" slineno="1-1" sn="1"><section numlevel="1" lineno="29" slineno="1-2" number="53G-11-210" type="enact"><secline lineno="28">Section 1. Section <bold>53G-11-210</bold> is enacted to read:</secline><catline lineno="29"><bold>53G-11-210<parens/>. Certified teacher librarian.</bold></catline><subsection ssid="1-1" dnum="_-o:1-i" numlevel="1" lineno="30" slineno="1-3" ea="amend" anum="0" owner="jchristopherson" style="1" level="1" placement="noreturn"><display><amend anum="0" ea="amend" pairid="1000" style="1" owner="i" level="1" amendtag="start">(1)</amend></display><amend anum="0" ea="amend" pairid="13" groupid="10" style="1" owner="jchristopherson" level="1" amendtag="end">As used in this section:</amend><subsection ssid="1-20" dnum="_-o:a-i" numlevel="1" lineno="31" slineno="1-4" ea="amend" anum="0" owner="jchristopherson" style="1" level="2"><display><amend anum="0" ea="amend" pairid="1001" style="1" owner="i" level="1" amendtag="start">(a)</amend></display><amend anum="0" ea="amend" pairid="103" groupid="75" style="1" owner="jchristopherson" level="1" amendtag="end">"Certified teacher librarian" means a full-time employee of a school district or <ln numlevel="1" lineno="32" slineno="1-5"/>regional education service agency, who:</amend><subsection ssid="1-4" dnum="_-o:i-i" numlevel="1" lineno="33" slineno="1-6" ea="amend" anum="0" owner="jchristopherson" style="1" level="3"><display><amend anum="0" ea="amend" pairid="1002" style="1" owner="i" level="1" amendtag="start">(i)</amend></display><amend anum="0" ea="amend" pairid="24" groupid="19" style="1" owner="jchristopherson" level="1" amendtag="end">oversees and works to improve the curation and development of a library <ln numlevel="1" lineno="34" slineno="1-7"/>collection within a:</amend><subsection ssid="1-24" dnum="_-o:A-i" numlevel="1" lineno="35" slineno="1-8" ea="amend" anum="0" owner="jchristopherson" style="1" level="4"><display><amend anum="0" ea="amend" pairid="1003" style="1" owner="i" level="1" amendtag="start">(A)</amend></display><amend anum="0" ea="amend" pairid="122" groupid="90" style="1" owner="jchristopherson" level="1" amendtag="end">school district; or</amend></subsection><subsection ssid="1-25" dnum="_-o:B-i" numlevel="1" lineno="36" slineno="1-9" ea="amend" anum="0" owner="jchristopherson" style="1" level="4"><display><amend anum="0" ea="amend" pairid="1004" style="1" owner="i" level="1" amendtag="start">(B)</amend></display><amend anum="0" ea="amend" pairid="127" groupid="94" style="1" owner="jchristopherson" level="1" amendtag="end">regional education service agency;</amend></subsection></subsection><subsection ssid="1-28" dnum="_-o:ii-i" numlevel="1" lineno="37" slineno="1-10" ea="amend" anum="0" owner="jchristopherson" style="1" level="3"><display><amend anum="0" ea="amend" pairid="1005" style="1" owner="i" level="1" amendtag="start">(ii)</amend></display><amend anum="0" ea="amend" pairid="138" groupid="103" style="1" owner="jchristopherson" level="1" amendtag="end">works to improve student academic achievement in reading and other content <ln numlevel="1" lineno="38" slineno="1-11"/>areas;</amend></subsection><subsection ssid="1-6" dnum="_-o:iii-i" numlevel="1" lineno="39" slineno="1-12" ea="amend" anum="0" owner="jchristopherson" style="1" level="3"><display><amend anum="0" ea="amend" pairid="1006" style="1" owner="i" level="1" amendtag="start">(iii)</amend></display><amend anum="0" ea="amend" pairid="33" groupid="26" style="1" owner="jchristopherson" level="1" amendtag="end">assists a school with navigating the sensitive material requirements described in <ln numlevel="1" lineno="40" slineno="1-13"/>Section <xref depth="3" refnumber="53G-10-103">53G-10-103</xref>;</amend></subsection><subsection ssid="1-7" dnum="_-o:iv-i" numlevel="1" lineno="41" slineno="1-14" ea="amend" anum="0" owner="jchristopherson" style="1" level="3"><display><amend anum="0" ea="amend" pairid="1007" style="1" owner="i" level="1" amendtag="start">(iv)</amend></display><amend anum="0" ea="amend" pairid="49" groupid="38" style="1" owner="jchristopherson" level="1" amendtag="end">develops curricula and best practices for teaching state standards regarding <ln numlevel="1" lineno="42" slineno="1-15"/>library media;</amend></subsection><subsection ssid="1-26" dnum="_-o:v-i" numlevel="1" lineno="43" slineno="1-16" ea="amend" anum="0" owner="jchristopherson" style="1" level="3"><display><amend anum="0" ea="amend" pairid="1008" style="1" owner="i" level="1" amendtag="start">(v)</amend></display><amend anum="0" ea="amend" pairid="131" groupid="97" style="1" owner="jchristopherson" level="1" amendtag="end">facilitates collaboration between teachers and school librarians to support student <ln numlevel="1" lineno="44" slineno="1-17"/>academic achievement; and</amend></subsection><subsection ssid="1-8" dnum="_-o:vi-i" numlevel="1" lineno="45" slineno="1-18" ea="amend" anum="0" owner="jchristopherson" style="1" level="3"><display><amend anum="0" ea="amend" pairid="1009" style="1" owner="i" level="1" amendtag="start">(vi)</amend></display><amend anum="0" ea="amend" pairid="48" groupid="37" style="1" owner="jchristopherson" level="1" amendtag="end">provides professional learning and mentoring to teachers and school librarians, <ln numlevel="1" lineno="46" slineno="1-19"/>including:</amend><subsection ssid="1-9" dnum="_-o:A-i" numlevel="1" lineno="47" slineno="1-20" ea="amend" anum="0" owner="jchristopherson" style="1" level="4"><display><amend anum="0" ea="amend" pairid="1010" style="1" owner="i" level="1" amendtag="start">(A)</amend></display><amend anum="0" ea="amend" pairid="60" groupid="46" style="1" owner="jchristopherson" level="1" amendtag="end">core library practices and operations;</amend></subsection><subsection ssid="1-10" dnum="_-o:B-i" numlevel="1" lineno="48" slineno="1-21" ea="amend" anum="0" owner="jchristopherson" style="1" level="4"><display><amend anum="0" ea="amend" pairid="1011" style="1" owner="i" level="1" amendtag="start">(B)</amend></display><amend anum="0" ea="amend" pairid="77" groupid="59" style="1" owner="jchristopherson" level="1" amendtag="end">research backed best practices for instruction and student engagement;</amend></subsection><subsection ssid="1-11" dnum="_-o:C-i" numlevel="1" lineno="49" slineno="1-22" ea="amend" anum="0" owner="jchristopherson" style="1" level="4"><display><amend anum="0" ea="amend" pairid="1012" style="1" owner="i" level="1" amendtag="start">(C)</amend></display><amend anum="0" ea="amend" pairid="76" groupid="58" style="1" owner="jchristopherson" level="1" amendtag="end">research backed best practices for promotion of literacy and reading <ln numlevel="1" lineno="50" slineno="1-23"/>motivation;</amend></subsection><subsection ssid="1-27" dnum="_-o:D-i" numlevel="1" lineno="51" slineno="1-24" ea="amend" anum="0" owner="jchristopherson" style="1" level="4"><display><amend anum="0" ea="amend" pairid="1013" style="1" owner="i" level="1" amendtag="start">(D)</amend></display><amend anum="0" ea="amend" pairid="137" groupid="102" style="1" owner="jchristopherson" level="1" amendtag="end">integration of information literacy, news literacy, media literacy, and digital <ln numlevel="1" lineno="52" slineno="1-25"/>literacy across all content areas; and</amend></subsection><subsection ssid="1-12" dnum="_-o:E-i" numlevel="1" lineno="53" slineno="1-26" ea="amend" anum="0" owner="jchristopherson" style="1" level="4"><display><amend anum="0" ea="amend" pairid="1014" style="1" owner="i" level="1" amendtag="start">(E)</amend></display><amend anum="0" ea="amend" pairid="84" groupid="63" style="1" owner="jchristopherson" level="1" amendtag="end">library technology and systems.</amend></subsection></subsection></subsection><subsection ssid="1-21" dnum="_-o:b-i" numlevel="1" lineno="54" slineno="1-27" ea="amend" anum="0" owner="jchristopherson" style="1" level="2"><display><amend anum="0" ea="amend" pairid="1015" style="1" owner="i" level="1" amendtag="start">(b)</amend></display><amend anum="0" ea="amend" pairid="104" groupid="76" style="1" owner="jchristopherson" level="1" amendtag="end">"Regional education service agency" means the same as that term is defined in <ln numlevel="1" lineno="55" slineno="1-28"/>Section <xref depth="3" refnumber="53G-4-410">53G-4-410</xref>.</amend></subsection></subsection><subsection ssid="1-2" dnum="_-o:2-i" numlevel="1" lineno="56" slineno="1-29" ea="amend" anum="0" owner="jchristopherson" style="1" level="1"><display><amend anum="0" ea="amend" pairid="1016" style="1" owner="i" level="1" amendtag="start">(2)</amend></display><amend anum="0" ea="amend" pairid="12" groupid="9" style="1" owner="jchristopherson" level="1" amendtag="end">Before July 1, 2031, each school district shall staff a full-time certified teacher librarian <ln numlevel="1" lineno="57" slineno="1-30"/>at:</amend><subsection ssid="1-22" dnum="_-o:a-i" numlevel="1" lineno="58" slineno="1-31" ea="amend" anum="0" owner="jchristopherson" style="1" level="2"><display><amend anum="0" ea="amend" pairid="1017" style="1" owner="i" level="1" amendtag="start">(a)</amend></display><amend anum="0" ea="amend" pairid="112" groupid="82" style="1" owner="jchristopherson" level="1" amendtag="end">the school district; or</amend></subsection><subsection ssid="1-23" dnum="_-o:b-i" numlevel="1" lineno="59" slineno="1-32" ea="amend" anum="0" owner="jchristopherson" style="1" level="2"><display><amend anum="0" ea="amend" pairid="1018" style="1" owner="i" level="1" amendtag="start">(b)</amend></display><amend anum="0" ea="amend" pairid="117" groupid="86" style="1" owner="jchristopherson" level="1" amendtag="end">the school district's regional education service agency.</amend></subsection></subsection><subsection ssid="1-3" dnum="_-o:3-i" numlevel="1" lineno="60" slineno="1-33" ea="amend" anum="0" owner="jchristopherson" style="1" level="1"><display><amend anum="0" ea="amend" pairid="1019" style="1" owner="i" level="1" amendtag="start">(3)</amend></display><amend anum="0" ea="amend" pairid="64" groupid="50" style="1" owner="jchristopherson" level="1" amendtag="end">The state board shall:</amend><subsection ssid="1-15" dnum="_-o:a-i" numlevel="1" lineno="61" slineno="1-34" ea="amend" anum="0" owner="jchristopherson" style="1" level="2"><display><amend anum="0" ea="amend" pairid="1020" style="1" owner="i" level="1" amendtag="start">(a)</amend></display><amend anum="0" ea="amend" pairid="93" groupid="67" style="1" owner="jchristopherson" level="1" amendtag="end">subject to legislative appropriations, distribute funds to a school district or regional <ln numlevel="1" lineno="62" slineno="1-35"/>education service agency to staff a full-<marker pairid="158"/>time certified teacher librarian, in accordance <ln numlevel="1" lineno="63" slineno="1-36"/>with Subsection <xref depth="4" refnumber="53G-11-210(2)">(2)</xref>; and</amend></subsection><subsection ssid="1-16" dnum="_-o:b-i" numlevel="1" lineno="64" slineno="1-37" ea="amend" anum="0" owner="jchristopherson" style="1" level="2"><display><amend anum="0" ea="amend" pairid="1021" style="1" owner="i" level="1" amendtag="start">(b)</amend></display><amend anum="0" ea="amend" pairid="98" groupid="71" style="1" owner="jchristopherson" level="1" amendtag="end">make rules, in accordance with Title 63G, Chapter 3, Utah Administrative <ln numlevel="1" lineno="65" slineno="1-38"/>Rulemaking Act, to establish:</amend><subsection ssid="1-29" dnum="_-o:i-i" numlevel="1" lineno="66" slineno="1-39" ea="amend" anum="0" owner="jchristopherson" style="1" level="3"><display><amend anum="0" ea="amend" pairid="1022" style="1" owner="i" level="1" amendtag="start">(i)</amend></display><amend anum="0" ea="amend" pairid="146" groupid="109" style="1" owner="jchristopherson" level="1" amendtag="end">minimum qualifications; or</amend></subsection><subsection ssid="1-30" dnum="_-o:ii-i" numlevel="1" lineno="67" slineno="1-40" ea="amend" anum="0" owner="jchristopherson" style="1" level="3"><display><amend anum="0" ea="amend" pairid="1023" style="1" owner="i" level="1" amendtag="start">(ii)</amend></display><amend anum="0" ea="amend" pairid="151" groupid="113" style="1" owner="jchristopherson" level="1" amendtag="end">licensure requirements for a certified teacher librarian.</amend></subsection></subsection></subsection></section></bsec><bsec buid="3" type="uncod" untype="effdate" src="uncod" uid="EF0000" sort="UZEFF" langlock="true" numlevel="1" lineno="68" slineno="2-1" sn="2"><section type="uncod" untype="effdate" display="false" src="uncod"><secline lineno="68">Section 2.  <bold>Effective Date.</bold></secline><sectionText lineno="69"><amend anum="0" ea="amend" pairid="1" groupid="1" style="1" owner="jchristopherson" level="1" amendtag="both">This bill takes effect on <effdate uid="code" date="7/1/2026">July 1, 2026</effdate>.</amend></sectionText></section></bsec></bdy><foot><rev><tm>1-26-26 9:05 AM</tm></rev></foot></leg>