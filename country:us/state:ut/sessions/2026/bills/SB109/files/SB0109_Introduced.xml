 src="code" uid="C78B-3-S1301_2026050620260506" buid="9" sort="78B03 13010020260506" numlevel="1" lineno="15" slineno="0-15"><bold>78B-3-1301</bold>, Utah Code Annotated 1953</sn><sn num="78B-3-1302" src="code" uid="C78B-3-S1302_2026050620260506" buid="7" sort="78B03 13020020260506" numlevel="1" lineno="16" slineno="0-16"><bold>78B-3-1302</bold>, Utah Code Annotated 1953</sn></saent></sa></lt><enacthead lineno="17"/><enact numlevel="1" lineno="18" slineno="0-18">Be it enacted by the Legislature of the state of Utah:</enact><bdy><bsec buid="9" num="78B-3-1301" type="enact" src="code" uid="C78B-3-S1301_2026050620260506" sort="78B03 13010020260506" numlevel="1" lineno="19" slineno="1-1" sn="1"><section numlevel="1" lineno="21" slineno="1-3" number="78B-3-1301" type="enact"><secline lineno="19">Section 1. Section <bold>78B-3-1301</bold> is enacted to read:</secline><headpart number="78B-3-13" numlevel="1" lineno="20" slineno="1-2">13. Abolished Rights of Action</headpart><catline lineno="21"><bold>78B-3-1301<parens/>. Definitions for part.</bold></catline><sectionText lineno="22"><para/><amend anum="0" ea="amend" pairid="2" groupid="2" style="1" owner="jchristopherson" level="1" amendtag="both">Reserved.</amend></sectionText></section></bsec><bsec buid="7" num="78B-3-1302" type="enact" src="code" uid="C78B-3-S1302_2026050620260506" sort="78B03 13020020260506" numlevel="1" lineno="23" slineno="2-1" sn="2"><section numlevel="1" lineno="24" slineno="2-2" number="78B-3-1302" type="enact"><secline lineno="23">Section 2. Section <bold>78B-3-1302</bold> is enacted to read:</secline><catline lineno="24"><bold>78B-3-1302<parens/>. Alienation of affections.</bold></catline><sectionText lineno="25"><para/><amend anum="0" ea="amend" pairid="2" groupid="2" style="1" owner="jchristopherson" level="1" amendtag="both">There is no right of action for alienation of affections.</amend></sectionText></section></bsec><bsec buid="10" type="uncod" untype="effdate" src="uncod" uid="EF0000" sort="UZEFF" langlock="true" numlevel="1" lineno="26" slineno="3-1" sn="3"><section type="uncod" untype="effdate" display="false" src="uncod"><secline lineno="26">Section 3.  <bold>Effective Date.</bold></secline><sectionText lineno="27"><amend anum="0" ea="amend" pairid="1" groupid="1" style="1" owner="jchristopherson" level="1" amendtag="both">This bill takes effect on <effdate uid="code" date="5/6/2026">May 6, 2026</effdate>.</amend></sectionText></section></bsec></bdy><foot><rev><tm>1-8-26 3:48 PM</tm></rev></foot></leg>