<leg xml:space="preserve" billnum="HB0350" sponsor="Kristen Chevrier" designation="HB" otherSponsor="Heidi Balderree" otherHouse="Senate" sess="2026GS" fileno="2026FL0271" date="1/23/2026 09:01:623" printDate="01-23 12:38" subVer="0" minVer="0" office="LEGISLATIVE GENERAL COUNSEL" actionDate="" impact="code"><info><nextbuid>7</nextbuid><aminfo anum="0" effdate="07/01/2026"><seclist><sect action="A" src="code" buid="5" uid="C53G-9-S205.2_2026070120260701" fromuid="C53G-9-S205.2_2025050720250507" sort="53G09 02050220260701" mtype="section" effdate="07/01/2026">53G-9-205.2</sect><sect src="uncod" untype="effdate" buid="6" uid="EF0000" sort="UZEFF" mtype="uncod" effdate="07/01/2026"/></seclist></aminfo></info><tbox><sinfo><nextpairid>0</nextpairid></sinfo><st numlevel="1" lineno="1" slineno="0-1">Foods Available at Schools Amendments</st><sessionhead>2026 GENERAL SESSION</sessionhead><statehead>STATE OF UTAH</statehead><sponsorhead>Chief Sponsor: Kristen Chevrier</sponsorhead><otherSponsorhead>Senate Sponsor: Heidi Balderree</otherSponsorhead></tbox><lt numlevel="1" lineno="2" slineno="0-2"><lthead lineno="3">LONG TITLE</lthead><gdhead lineno="4">General Description:</gdhead><gd numlevel="1" lineno="5" slineno="0-5">This bill amends provisions related to food additive prohibitions in a public school.</gd><hphead lineno="6">Highlighted Provisions:</hphead><hp numlevel="1" lineno="7" slineno="0-7">This bill:<hl numlevel="1" lineno="8" slineno="0-8" level="1">amends the list of prohibited food additives;</hl><hl numlevel="1" lineno="9" slineno="0-9" level="1">adds an exception related to food that is donated;</hl><hl numlevel="1" lineno="10" slineno="0-10" level="1">removes an exception related to small schools; and</hl><hl numlevel="1" lineno="11" slineno="0-11" level="1">makes technical and conforming changes.</hl></hp><moni numlevel="1" lineno="12" slineno="0-12" display="none">Money Appropriated in this Bill:</moni><moniNone lineno="13">None</moniNone><oc numlevel="1" lineno="14" slineno="0-14">Other Special Clauses:<ocl type="effdate" sort="2" numlevel="1" lineno="15" slineno="0-15">This bill provides a special effective date.</ocl></oc><sa numlevel="1" lineno="16" slineno="0-16">Utah Code Sections Affected:<saamd numlevel="1" lineno="17" slineno="0-17"><snhead>AMENDS:</snhead><sn num="53G-9-205.2" src="code" uid="C53G-9-S205.2_2026070120260701" buid="5" sort="53G09 02050220260701" numlevel="1" lineno="18" slineno="0-18"><bold>53G-9-205.2</bold>, as enacted by Laws of Utah 2025, Chapter 466</sn></saamd></sa></lt><enacthead lineno="19"/><enact numlevel="1" lineno="20" slineno="0-20">Be it enacted by the Legislature of the state of Utah:</enact><bdy><bsec buid="5" num="53G-9-205.2" type="amend" src="code" uid="C53G-9-S205.2_2026070120260701" sort="53G09 02050220260701" numlevel="1" lineno="21" slineno="1-1" sn="1"><section number="53G-9-205.2" numlevel="1" lineno="22" slineno="1-2" type="amend"><secline lineno="21">Section 1. Section <bold>53G-9-205.2</bold> is amended to read:</secline><catline lineno="22"><bold>53G-9-205.2<parens/>. Definitions -- Prohibited food additives -- Exceptions.</bold></catline><subsection ssid="5-null-1" dnum="1-o" numlevel="1" lineno="23" slineno="1-3" level="1" placement="noreturn"><display>(1)</display>As used in this section:<subsection ssid="5-null-2" dnum="a-o" numlevel="1" lineno="24" slineno="1-4" level="2"><display>(a)</display>"FD<char set="6" char="6"/>C" means the Federal Food, Drug, and Cosmetics Act, 21 C.F.R. Part 74.</subsection><subsection ssid="5-null-3" dnum="b-o" numlevel="1" lineno="25" slineno="1-5" level="2"><display>(b)</display>"Public school" means the same as that term is defined in Section <xref depth="3" refnumber="53G-9-205.1">53G-9-205.1</xref>.</subsection><subsection ssid="5-null-4" dnum="c-o" numlevel="1" lineno="26" slineno="1-6" level="2"><display>(c)</display>"School day" means the same as that terms is defined in Section <xref depth="3" refnumber="53G-6-201">53G-6-201</xref>.</subsection></subsection><subsection ssid="5-null-5" dnum="2-o" numlevel="1" lineno="27" slineno="1-7" level="1" space="false"><display>(2)</display><subsection ssid="5-null-6" dnum="a-o" level="2" placement="sameline"><display>(a)</display><amendoutstart style="2"/><amend anum="0" ea="erase" pairid="7" groupid="6" style="2" owner="jchristopherson" level="1" deltag="both">Beginning in the 2026-2027 school year, a </amend><amendoutend style="2"/><amend anum="0" ea="amend" pairid="6" groupid="5" style="1" owner="jchristopherson" level="1" amendtag="both" space="true">A </amend>public school may not sell, donate, <ln numlevel="1" lineno="28" slineno="1-8"/>offer, or serve on school grounds during the school day, food that contains:<subsection ssid="5-null-7" dnum="i-o" numlevel="1" lineno="29" slineno="1-9" level="3" tab="1"><display>(i)</display>potassium bromate;</subsection><subsection ssid="5-null-8" dnum="ii-o" numlevel="1" lineno="30" slineno="1-10" level="3" tab="1"><display>(ii)</display>propylparaben;</subsection><subsection ssid="5-25" dnum="_-o:iii-i" numlevel="1" lineno="31" slineno="1-11" ea="amend" anum="0" owner="jchristopherson" style="1" level="3" tab="1"><display><amend anum="0" ea="amend" pairid="1008" style="1" owner="i" level="1" amendtag="start">(iii)</amend></display><amend anum="0" ea="amend" pairid="5" groupid="4" style="1" owner="jchristopherson" level="1" amendtag="end">titanium dioxide;</amend></subsection><subsection ssid="5-null-9" dnum="iii-o:iv-i" numlevel="1" lineno="32" slineno="1-12" level="3" tab="1"><display><amendoutstart style="2"/><amend anum="0" ea="erase" pairid="1009" style="2" owner="o" level="1" deltag="both">(iii)</amend><amendoutend style="2"/><amend anum="0" ea="amend" pairid="1010" style="1" owner="i" level="1" amendtag="both" space="true">(iv)</amend></display>FD<char set="6" char="6"/>C Blue No. 1;</subsection><subsection ssid="5-null-10" dnum="iv-o:v-i" numlevel="1" lineno="33" slineno="1-13" level="3" tab="1"><display><amendoutstart style="2"/><amend anum="0" ea="erase" pairid="1010" style="2" owner="o" level="1" deltag="both">(iv)</amend><amendoutend style="2"/><amend anum="0" ea="amend" pairid="1011" style="1" owner="i" level="1" amendtag="both" space="true">(v)</amend></display>FD<char set="6" char="6"/>C Blue No. 2;</subsection><subsection ssid="5-null-11" dnum="v-o:vi-i" numlevel="1" lineno="34" slineno="1-14" level="3" tab="1"><display><amendoutstart style="2"/><amend anum="0" ea="erase" pairid="1011" style="2" owner="o" level="1" deltag="both">(v)</amend><amendoutend style="2"/><amend anum="0" ea="amend" pairid="1012" style="1" owner="i" level="1" amendtag="both" space="true">(vi)</amend></display>FD<char set="6" char="6"/>C Green No. 3;</subsection><subsection ssid="5-null-12" dnum="vi-o:vii-i" numlevel="1" lineno="35" slineno="1-15" level="3" tab="1"><display><amendoutstart style="2"/><amend anum="0" ea="erase" pairid="1012" style="2" owner="o" level="1" deltag="both">(vi)</amend><amendoutend style="2"/><amend anum="0" ea="amend" pairid="1013" style="1" owner="i" level="1" amendtag="both" space="true">(vii)</amend></display>FD<char set="6" char="6"/>C Red No. 3;</subsection><subsection ssid="5-null-13" dnum="vii-o:viii-i" numlevel="1" lineno="36" slineno="1-16" level="3" tab="1"><display><amendoutstart style="2"/><amend anum="0" ea="erase" pairid="1013" style="2" owner="o" level="1" deltag="both">(vii)</amend><amendoutend style="2"/><amend anum="0" ea="amend" pairid="1014" style="1" owner="i" level="1" amendtag="both" space="true">(viii)</amend></display>FD<char set="6" char="6"/>C Red No. 40;</subsection><subsection ssid="5-null-14" dnum="viii-o:ix-i" numlevel="1" lineno="37" slineno="1-17" level="3" tab="1"><display><amendoutstart style="2"/><amend anum="0" ea="erase" pairid="1014" style="2" owner="o" level="1" deltag="both">(viii)</amend><amendoutend style="2"/><amend anum="0" ea="amend" pairid="1015" style="1" owner="i" level="1" amendtag="both" space="true">(ix)</amend></display>FD<char set="6" char="6"/>C Yellow No. 5; and</subsection><subsection ssid="5-null-15" dnum="ix-o:x-i" numlevel="1" lineno="38" slineno="1-18" level="3" tab="1"><display><amendoutstart style="2"/><amend anum="0" ea="erase" pairid="1015" style="2" owner="o" level="1" deltag="both">(ix)</amend><amendoutend style="2"/><amend anum="0" ea="amend" pairid="1016" style="1" owner="i" level="1" amendtag="both" space="true">(x)</amend></display>FD<char set="6" char="6"/>C Yellow No. 6.</subsection></subsection><subsection ssid="5-null-16" dnum="b-o" numlevel="1" lineno="39" slineno="1-19" level="2"><display>(b)</display>Except as provided in Subsection <xref tempid="253" depth="4" refnumber="(3)">(3)</xref>, a person who sells, donates, offers, or serves a <ln numlevel="1" lineno="40" slineno="1-20"/>consumable item during the school day shall comply with the requirements under this <ln numlevel="1" lineno="41" slineno="1-21"/>section.</subsection></subsection><subsection ssid="5-null-17" dnum="3-o" numlevel="1" lineno="42" slineno="1-22" level="1" space="false"><display>(3)</display><subsection ssid="5-null-18" dnum="a-o:_-i" ea="erase" anum="0" owner="jchristopherson" style="2" level="2" placement="sameline"><display><amendoutstart style="2"/><amend anum="0" ea="erase" pairid="1018" style="2" owner="o" level="1" deltag="both">(a)</amend><amendoutend style="2"/></display>Notwithstanding Subsection <xref tempid="667" depth="4" refnumber="(2)">(2)</xref>(b):<subsection ssid="5-null-19" dnum="i-o:a-i" numlevel="1" lineno="43" slineno="1-23" level="2" tab="1"><display><amendoutstart style="2"/><amend anum="0" ea="erase" pairid="1019" style="2" owner="o" level="1" deltag="both">(i)</amend><amendoutend style="2"/><amend anum="0" ea="amend" pairid="1020" style="1" owner="i" level="1" amendtag="both" space="true">(a)</amend></display>a student's parent may provide students with a food item described in Subsection <xref tempid="403" depth="4" refnumber="(2)(a)"><ln numlevel="1" lineno="44" slineno="1-24"/>(2)(a)</xref> during the school day;</subsection><subsection ssid="5-null-20" dnum="ii-o:b-i" numlevel="1" lineno="45" slineno="1-25" level="2" tab="1"><display><amendoutstart style="2"/><amend anum="0" ea="erase" pairid="1020" style="2" owner="o" level="1" deltag="both">(ii)</amend><amendoutend style="2"/><amend anum="0" ea="amend" pairid="1021" style="1" owner="i" level="1" amendtag="both" space="true">(b)</amend></display>a teacher may provide students with a food item described in Subsection <xref tempid="332" depth="4" refnumber="(2)(a)">(2)(a)</xref> <ln numlevel="1" lineno="46" slineno="1-26"/>if the teacher obtains permission from the students' parents at the start of each school <ln numlevel="1" lineno="47" slineno="1-27"/>semester; <amendoutstart style="2"/><amend anum="0" ea="erase" pairid="13" groupid="10" style="2" owner="jchristopherson" level="1" deltag="both">and</amend><amendoutend style="2"/></subsection><subsection ssid="5-null-21" dnum="iii-o:c-i" numlevel="1" lineno="48" slineno="1-28" level="2" tab="1"><display><amendoutstart style="2"/><amend anum="0" ea="erase" pairid="1021" style="2" owner="o" level="1" deltag="both">(iii)</amend><amendoutend style="2"/><amend anum="0" ea="amend" pairid="1022" style="1" owner="i" level="1" amendtag="start" space="true">(c)</amend></display><amend anum="0" ea="amend" pairid="15" groupid="12" style="1" owner="jchristopherson" level="1" amendtag="end">an individual may donate a food item described in Subsection <xref depth="4" refnumber="53G-9-205.2(2)(a)">(2)(a)</xref> to a <ln numlevel="1" lineno="49" slineno="1-29"/>school's food pantry;</amend></subsection><subsection ssid="5-26" dnum="_-o:d-i" numlevel="1" lineno="50" slineno="1-30" ea="amend" anum="0" owner="jchristopherson" style="1" level="2" tab="1"><display><amend anum="0" ea="amend" pairid="1022" style="1" owner="i" level="1" amendtag="start">(d)</amend></display><amend anum="0" ea="amend" pairid="21" groupid="17" style="1" owner="jchristopherson" level="1" amendtag="end">a public school may accept and distribute to a student a food item:</amend><subsection ssid="5-27" dnum="_-o:i-i" numlevel="1" lineno="51" slineno="1-31" ea="amend" anum="0" owner="jchristopherson" style="1" level="3"><display><amend anum="0" ea="amend" pairid="1023" style="1" owner="i" level="1" amendtag="start">(i)</amend></display><amend anum="0" ea="amend" pairid="20" groupid="16" style="1" owner="jchristopherson" level="1" amendtag="end">described in Subsection <xref depth="4" refnumber="53G-9-205.2(2)(a)">(2)(a)</xref>; and</amend></subsection><subsection ssid="5-28" dnum="_-o:ii-i" numlevel="1" lineno="52" slineno="1-32" ea="amend" anum="0" owner="jchristopherson" style="1" level="3"><display><amend anum="0" ea="amend" pairid="1024" style="1" owner="i" level="1" amendtag="start">(ii)</amend></display><amend anum="0" ea="amend" pairid="27" groupid="22" style="1" owner="jchristopherson" level="1" amendtag="end">donated under Subsection <xref depth="4" refnumber="53G-9-205.2(3)(c)">(3)(c)</xref>; and</amend></subsection></subsection><subsection ssid="5-29" dnum="_-o:e-i" numlevel="1" lineno="53" slineno="1-33" ea="amend" anum="0" owner="jchristopherson" style="1" level="2" tab="1"><display><amend anum="0" ea="amend" pairid="1025" style="1" owner="i" level="1" amendtag="both">(e)</amend></display>a person may sell a food item described in Subsection <xref tempid="538" depth="4" refnumber="(2)">(2)</xref>(a):<subsection ssid="5-null-22" dnum="A-o:i-i" numlevel="1" lineno="54" slineno="1-34" level="3"><display><amendoutstart style="2"/><amend anum="0" ea="erase" pairid="1026" style="2" owner="o" level="1" deltag="both">(A)</amend><amendoutend style="2"/><amend anum="0" ea="amend" pairid="1027" style="1" owner="i" level="1" amendtag="both" space="true">(i)</amend></display>as a concession item at a school-sponsored event or extra-curricular activity; <ln numlevel="1" lineno="55" slineno="1-35"/>or</subsection><subsection ssid="5-null-23" dnum="B-o:ii-i" numlevel="1" lineno="56" slineno="1-36" level="3"><display><amendoutstart style="2"/><amend anum="0" ea="erase" pairid="1027" style="2" owner="o" level="1" deltag="both">(B)</amend><amendoutend style="2"/><amend anum="0" ea="amend" pairid="1028" style="1" owner="i" level="1" amendtag="both" space="true">(ii)</amend></display>in a vending machine.</subsection></subsection></subsection><subsection ssid="5-null-24" dnum="b-o:_-i" numlevel="1" lineno="57" slineno="1-37" ea="erase" anum="0" owner="jchristopherson" style="2" level="2"><display><amendoutstart style="2"/><amend anum="0" ea="erase" pairid="1028" style="2" owner="o" level="1" deltag="start">(b)</amend></display><amend anum="0" ea="erase" pairid="35" groupid="27" style="2" owner="jchristopherson" level="1" deltag="end">This section does not apply to a charter school or school district that has 5,500 <ln numlevel="1" lineno="58" slineno="1-38"/>students or fewer.</amend><amendoutend style="2"/></subsection></subsection></section></bsec><bsec buid="6" type="uncod" untype="effdate" src="uncod" uid="EF0000" sort="UZEFF" langlock="true" numlevel="1" lineno="59" slineno="2-1" sn="2"><section type="uncod" untype="effdate" display="false" src="uncod"><secline lineno="59">Section 2.  <bold>Effective Date.</bold></secline><sectionText lineno="60"><amend anum="0" ea="amend" pairid="1" groupid="1" style="1" owner="jchristopherson" level="1" amendtag="both">This bill takes effect on <effdate uid="code" date="7/1/2026">July 1, 2026</effdate>.</amend></sectionText></section></bsec></bdy><foot><rev><tm>1-23-26 9:52 AM</tm></rev></foot></leg>