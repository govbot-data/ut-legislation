<leg xml:space="preserve" billnum="HR0003" sponsor="Norman K Thurston" designation="HR" otherSponsor="" otherHouse="Senate" sess="2026GS" fileno="2026FL0491" date="2/10/2026 10:02:813" printDate="02-10 10:49" subVer="0" minVer="3" office="LEGISLATIVE GENERAL COUNSEL" actionDate="" impact="hrules"><info><nextbuid>5</nextbuid><aminfo anum="0" effdate="01/01/1800"><seclist><sect action="E" src="rule" buid="4" uid="HR2-5-S102_1800010118000101" sort="H02 05 01020018000101" mtype="section" effdate="01/01/1800">HR2-5-102</sect><sect src="uncod" untype="effdate" buid="2" uid="EF0000" sort="UZEFF" mtype="uncod" effdate="01/01/1800"/></seclist></aminfo><amendinfo level="1"/><aminfo anum="-1" effdate="01/01/1800"><seclist><sect action="E" src="rule" buid="4" uid="HR2-5-S102_1800010118000101" sort="H02 05 01020018000101" mtype="section" effdate="01/01/1800">HR2-5-102</sect><sect src="uncod" untype="effdate" buid="2" uid="EF0000" sort="UZEFF" mtype="uncod" effdate="01/01/1800"/></seclist></aminfo></info><tbox><sinfo><nextpairid>0</nextpairid></sinfo><st numlevel="1" lineno="1" slineno="0-1">House Rules Resolution - Abandoning Legislation</st><sessionhead>2026 GENERAL SESSION</sessionhead><statehead>STATE OF UTAH</statehead><sponsorhead>Chief Sponsor: Norman K Thurston</sponsorhead></tbox><lt numlevel="1" lineno="2" slineno="0-2"><lthead lineno="3">LONG TITLE</lthead><gdhead lineno="4">General Description:</gdhead><gd numlevel="1" lineno="5" slineno="0-5">This House rules resolution authorizes abandoning legislation.</gd><hphead lineno="6">Highlighted Provisions:</hphead><hp numlevel="1" lineno="7" slineno="0-7">This resolution:<hl numlevel="1" lineno="8" slineno="0-8" level="1">defines terms; and</hl><hl numlevel="1" lineno="9" slineno="0-9" level="1">establishes a process for a chief sponsor to abandon the chief sponsor's legislation.</hl></hp><moni numlevel="1" lineno="10" slineno="0-10" display="none">Money Appropriated in this Bill:</moni><moniNone lineno="11">None</moniNone><oc numlevel="1" lineno="12" slineno="0-12">Other Special Clauses:<ocl type="effdate" sort="2" numlevel="1" lineno="13" slineno="0-13">This resolution provides a special effective date.</ocl></oc><ra numlevel="1" lineno="14" slineno="0-14">Legislative Rules Affected:<raent numlevel="1" lineno="15" slineno="0-15"><snhead>ENACTS:</snhead><sn num="HR2-5-102" src="rule" uid="HR2-5-S102_1800010118000101" buid="4" sort="H02 05 01020018000101" numlevel="1" lineno="16" slineno="0-16"><bold>HR2-5-102</bold></sn></raent></ra></lt><enacthead lineno="17"/><enact numlevel="1" lineno="18" slineno="0-18">Be it resolved by the House of Representatives of the state of Utah:</enact><bdy><bsec buid="4" num="HR2-5-102" type="enact" src="rule" uid="HR2-5-S102_1800010118000101" sort="H02 05 01020018000101" numlevel="1" lineno="19" slineno="1-1" sn="1"><section numlevel="1" lineno="20" slineno="1-2" number="HR2-5-102" type="enact"><secline lineno="19">Section 1. <bold>HR2-5-102</bold> is enacted to read:</secline><catline lineno="20"><bold>HR2-5-102<parens/>. Abandoning legislation.</bold></catline><subsection ssid="4-13" dnum="_-o:1-i" numlevel="1" lineno="21" slineno="1-3" ea="amend" anum="0" owner="jchristopherson" style="1" level="1" placement="noreturn"><display><amend anum="0" ea="amend" pairid="1000" style="1" owner="i" level="1" amendtag="start">(1)</amend></display><amend anum="0" ea="amend" pairid="45" groupid="31" style="1" owner="jchristopherson" level="1" amendtag="end">As used in this rule:</amend><subsection ssid="4-2" dnum="_-o:a-i" numlevel="1" lineno="22" slineno="1-4" ea="amend" anum="0" owner="jchristopherson" style="1" level="2"><display><amend anum="0" ea="amend" pairid="1001" style="1" owner="i" level="1" amendtag="start">(a)</amend></display><amend anum="0" ea="amend" pairid="7" groupid="6" style="1" owner="jchristopherson" level="1" amendtag="end">"Chief sponsor" means the member of the House of Representatives who:</amend><subsection ssid="4-3" dnum="_-o:i-i" numlevel="1" lineno="23" slineno="1-5" ea="amend" anum="0" owner="jchristopherson" style="1" level="3"><display><amend anum="0" ea="amend" pairid="1002" style="1" owner="i" level="1" amendtag="start">(i)</amend></display><amend anum="0" ea="amend" pairid="10" groupid="8" style="1" owner="jchristopherson" level="1" amendtag="end">approves a request for legislation for numbering; or</amend></subsection><subsection ssid="4-4" dnum="_-o:ii-i" numlevel="1" lineno="24" slineno="1-6" ea="amend" anum="0" owner="jchristopherson" style="1" level="3"><display><amend anum="0" ea="amend" pairid="1003" style="1" owner="i" level="1" amendtag="start">(ii)</amend></display><amend anum="0" ea="amend" pairid="13" groupid="10" style="1" owner="jchristopherson" level="1" amendtag="end">becomes the chief sponsor of legislation in accordance with <xref depth="3" refnumber="HR2-5-101">HR2-5-101</xref> or <xref depth="3" refnumber="JR4-2-101"><ln numlevel="1" lineno="25" slineno="1-7"/>JR4-2-101</xref>.</amend></subsection></subsection><subsection ssid="4-5" dnum="_-o:b-i" numlevel="1" lineno="26" slineno="1-8" ea="amend" anum="0" owner="jchristopherson" style="1" level="2"><display><amend anum="0" ea="amend" pairid="1004" style="1" owner="i" level="1" amendtag="start">(b)</amend></display><amend anum="0" ea="amend" pairid="16" groupid="12" style="1" owner="jchristopherson" level="1" amendtag="end">"Legislation" means a bill or resolution introduced for consideration by the <ln numlevel="1" lineno="27" slineno="1-9"/>Legislature.</amend></subsection></subsection><subsection ssid="4-6" dnum="_-o:2-i" numlevel="1" lineno="28" slineno="1-10" ea="amend" anum="0" owner="jchristopherson" style="1" level="1"><display><amend anum="0" ea="amend" pairid="1005" style="1" owner="i" level="1" amendtag="start">(2)</amend></display><amend anum="0" ea="amend" pairid="19" groupid="14" style="1" owner="jchristopherson" level="1" amendtag="end">A chief sponsor may abandon the chief sponsor's legislation by submitting to the chief <ln numlevel="1" lineno="29" slineno="1-11"/>clerk, before the legislation passes the Senate on third reading, an abandoning legislation <ln numlevel="1" lineno="30" slineno="1-12"/>form.</amend></subsection><subsection ssid="4-7" dnum="_-o:3-i:_-HF" numlevel="1" lineno="31" slineno="1-13" ea="erase" anum="-1" owner="HF" style="7" level="1" chamber="HF"><display><houseStart display="true"/><houseFloorStart/><amendoutstart style="7"/><amend anum="-1" ea="erase" pairid="1006" style="7" owner="HF" level="1" hftag="start" deltag="start">(3)</amend></display><amend anum="-1" ea="erase" pairid="76" groupid="55" style="7" owner="HF" level="1" hftag="end" deltag="end">Upon receipt of a completed abandoning legislation form, the chief clerk shall <ln numlevel="2" lineno="31a" slineno="1-13a"/>request </amend><amendoutend style="7"/><houseFloorEnd/><houseEnd display="true"/><amend anum="0" ea="amend" pairid="81" groupid="60" style="1" owner="jchristopherson" level="1" base="true" amendtag="both"><ln numlevel="1" lineno="32" slineno="1-14"/></amend><houseStart display="true"/><houseFloorStart/><amendoutstart style="7"/><amend anum="-1" ea="erase" pairid="77" groupid="56" style="7" owner="HF" level="1" hftag="start" deltag="both">that the legislation be returned, if applicable.</amend><amendoutend style="7"/></subsection><subsection ssid="4-8" dnum="_-o:4-i:3-HF" numlevel="1" lineno="33" slineno="1-15" ea="amend" anum="0" owner="jchristopherson" style="1" level="1"><display><amendoutstart style="7"/><amend anum="-1" ea="erase" pairid="1007" style="7" owner="HF" level="1" deltag="both">(4)</amend><amendoutend style="7"/><amend anum="-1" ea="amend" pairid="1008" style="-1" owner="HF" level="1" hftag="end" amendtag="start" space="true">(3)</amend><houseFloorEnd/><houseEnd display="true"/></display><amend anum="0" ea="amend" pairid="25" groupid="18" style="1" owner="jchristopherson" level="1" endid="85" base="true" amendtag="end">Once </amend><houseStart display="true"/><houseFloorStart/><amendoutstart style="7"/><amend anum="-1" ea="erase" pairid="78" groupid="57" style="7" owner="HF" level="1" hftag="start" deltag="both">abandoned legislation is returned to the chief clerk</amend><amendoutend style="7"/><amend anum="-1" ea="amend" pairid="79" groupid="58" style="A" owner="HF" level="1" hftag="end" amendtag="start" space="true">the <ln numlevel="2" lineno="33a" slineno="1-15a"/>chief clerk is in possession of the abandoned legislation</amend><houseFloorEnd/><houseEnd display="true"/><amend anum="0" ea="amend" pairid="84" groupid="63" style="1" owner="jchristopherson" level="1" base="true">, the chief clerk shall file the <ln numlevel="1" lineno="34" slineno="1-16"/></amend><houseStart display="true"/><houseFloorStart/><amend anum="-1" ea="amend" pairid="80" groupid="59" style="A" owner="HF" level="1" hftag="both">abandoned </amend><houseFloorEnd/><houseEnd display="true"/><amend anum="0" ea="amend" pairid="85" groupid="64" style="1" owner="jchristopherson" level="1" base="true" amendtag="end">legislation.</amend></subsection><subsection ssid="4-10" dnum="_-o:5-i:4-HF" numlevel="1" lineno="35" slineno="1-17" ea="amend" anum="0" owner="jchristopherson" style="1" level="1"><display><houseStart display="true"/><houseFloorStart/><amendoutstart style="7"/><amend anum="-1" ea="erase" pairid="1008" style="7" owner="HF" level="1" hftag="start" deltag="both">(5)</amend><amendoutend style="7"/><amend anum="-1" ea="amend" pairid="1009" style="-1" owner="HF" level="1" hftag="end" amendtag="start" space="true">(4)</amend><houseFloorEnd/><houseEnd display="true"/></display><amend anum="0" ea="amend" pairid="31" groupid="22" style="1" owner="jchristopherson" level="1" amendtag="end">No later than one legislative day after the day on which a chief <ln numlevel="2" lineno="35a" slineno="1-17a"/>sponsor submits an <ln numlevel="1" lineno="36" slineno="1-18"/>abandoning legislation form, the presiding officer shall publicly announce that the chief <ln numlevel="1" lineno="37" slineno="1-19"/>sponsor abandoned the legislation.</amend></subsection><subsection ssid="4-11" dnum="_-o:6-i:5-HF" numlevel="1" lineno="38" slineno="1-20" ea="amend" anum="0" owner="jchristopherson" style="1" level="1" space="false"><display><houseStart display="true"/><houseFloorStart/><amendoutstart style="7"/><amend anum="-1" ea="erase" pairid="1009" style="7" owner="HF" level="1" hftag="start" deltag="both">(6)</amend><amendoutend style="7"/><amend anum="-1" ea="amend" pairid="1010" style="-1" owner="HF" level="1" hftag="end" amendtag="start" space="true">(5)</amend><houseFloorEnd/><houseEnd display="true"/></display><subsection ssid="4-14" dnum="_-o:a-i" ea="amend" anum="0" owner="jchristopherson" style="1" level="2" placement="sameline"><display><amend anum="0" ea="amend" pairid="1010" style="1" owner="i" level="1">(a)</amend></display><amend anum="0" ea="amend" pairid="57" groupid="41" style="1" owner="jchristopherson" level="1" amendtag="end">Abandoning legislation has the effect of striking the enacting <ln numlevel="2" lineno="38a" slineno="1-20a"/>clause.</amend></subsection><subsection ssid="4-15" dnum="_-o:b-i" numlevel="1" lineno="39" slineno="1-21" ea="amend" anum="0" owner="jchristopherson" style="1" level="2"><display><amend anum="0" ea="amend" pairid="1011" style="1" owner="i" level="1" amendtag="start">(b)</amend></display><amend anum="0" ea="amend" pairid="55" groupid="39" style="1" owner="jchristopherson" level="1" amendtag="end">Legislation may not be revived once the chief sponsor submits an abandoning <ln numlevel="1" lineno="40" slineno="1-22"/>legislation form.</amend></subsection></subsection><subsection ssid="4-12" dnum="_-o:7-i:6-HF" numlevel="1" lineno="41" slineno="1-23" ea="amend" anum="0" owner="jchristopherson" style="1" level="1"><display><houseStart display="true"/><houseFloorStart/><amendoutstart style="7"/><amend anum="-1" ea="erase" pairid="1012" style="7" owner="HF" level="1" hftag="start" deltag="both">(7)</amend><amendoutend style="7"/><amend anum="-1" ea="amend" pairid="1013" style="-1" owner="HF" level="1" hftag="end" amendtag="start" space="true">(6)</amend><houseFloorEnd/><houseEnd display="true"/></display><amend anum="0" ea="amend" pairid="37" groupid="26" style="1" owner="jchristopherson" level="1" amendtag="end">For legislation abandoned under this rule, the Office of Legislative <ln numlevel="2" lineno="41a" slineno="1-23a"/>Research and <ln numlevel="1" lineno="42" slineno="1-24"/>General Counsel shall note the abandonment on the legislation's webpage.</amend></subsection><subsection ssid="4-16" dnum="_-o:8-i:7-HF" numlevel="1" lineno="43" slineno="1-25" ea="amend" anum="0" owner="jchristopherson" style="1" level="1"><display><houseStart display="true"/><houseFloorStart/><amendoutstart style="7"/><amend anum="-1" ea="erase" pairid="1013" style="7" owner="HF" level="1" hftag="start" deltag="both">(8)</amend><amendoutend style="7"/><amend anum="-1" ea="amend" pairid="1014" style="-1" owner="HF" level="1" hftag="end" amendtag="start" space="true">(7)</amend><houseFloorEnd/><houseEnd display="true"/></display><amend anum="0" ea="amend" pairid="63" groupid="44" style="1" owner="jchristopherson" level="1" amendtag="end">Nothing in this rule precludes a representative from introducing new <ln numlevel="2" lineno="43a" slineno="1-25a"/>legislation <ln numlevel="1" lineno="44" slineno="1-26"/>identical to the legislation abandoned under this rule.</amend></subsection></section></bsec><bsec buid="2" type="uncod" untype="effdate" src="uncod" uid="EF0000" sort="UZEFF" langlock="false" numlevel="1" lineno="45" slineno="2-1" sn="2"><section type="uncod" untype="effdate" display="false" src="uncod"><secline lineno="45">Section 2.  <bold>Effective Date.</bold></secline><sectionText lineno="46"><amend anum="0" ea="amend" pairid="1" groupid="1" style="1" owner="jchristopherson" level="1" amendtag="both">This resolution takes effect May 6, 2026.</amend></sectionText></section></bsec></bdy><foot><rev><tm>2-10-26 10:49 AM</tm></rev></foot></leg>